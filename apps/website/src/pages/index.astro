  <!-- ════════ SCRIPTS ════════ -->
  <script>
    document.addEventListener('astro:page-load', () => {

      // ── Logo typewriter ──────────────────────────────────
      const logoInner = document.querySelector('.header__logo .logo-inner') as HTMLElement | null;
      if (logoInner) {
        const WORD = 'scheml';
        const SPEED = 72;
        const DELAY = 300;
        logoInner.textContent = '';
        logoInner.classList.remove('typing');
        let i = 0;
        setTimeout(() => {
          logoInner.classList.add('typing');
          const iv = setInterval(() => {
            logoInner.textContent = WORD.slice(0, ++i);
            if (i >= WORD.length) { clearInterval(iv); logoInner.classList.remove('typing'); }
          }, SPEED);
        }, DELAY);
      }

      // ── Scroll progress ──────────────────────────────────
      const progressEl = document.getElementById('scrollProgress');
      if (progressEl) {
        window.addEventListener('scroll', () => {
          const pct = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
          progressEl.style.width = `${pct}%`;
        }, { passive: true });
      }

      // ── Trait selector + code tab logic ──────────────────
      const traitBtns = document.querySelectorAll<HTMLButtonElement>('.trait-btn');
      const codeTabs  = document.querySelectorAll<HTMLButtonElement>('.code-tab');
      let currentTrait = 'predictive';
      let currentTab   = 'define';
      let prevTabIndex = 0;

      function getActivePanel(): HTMLElement | null {
        if (currentTab === 'define') {
          return document.querySelector(`[data-trait-panel="${currentTrait}"]`);
        } else if (currentTab === 'train') {
          return document.getElementById('panel-train');
        } else {
          return document.querySelector(`[data-trait-infer-panel="${currentTrait}"]`);
        }
      }

      function showPanel(incoming: HTMLElement | null, direction: 1 | -1) {
        if (!incoming) return;
        // hide all
        document.querySelectorAll('.code-panel').forEach((p) => {
          p.classList.remove('active', 'entering-right', 'entering-left');
        });
        incoming.classList.add('active', direction > 0 ? 'entering-right' : 'entering-left');
        setTimeout(() => incoming.classList.remove('entering-right', 'entering-left'), 400);
      }

      function switchTrait(trait: string) {
        currentTrait = trait;
        traitBtns.forEach((b) => {
          const active = b.dataset.trait === trait;
          b.classList.toggle('active', active);
          b.setAttribute('aria-selected', String(active));
        });
        // determine direction based on trait order
        const order = ['predictive','anomaly','similarity','temporal','generative'];
        const newIdx = order.indexOf(trait);
        const oldIdx = order.indexOf(currentTrait);
        showPanel(getActivePanel(), newIdx >= oldIdx ? 1 : -1);
      }

      function switchTab(tab: string) {
        const order = ['define','train','infer'];
        const newIdx = order.indexOf(tab);
        const direction: 1 | -1 = newIdx >= prevTabIndex ? 1 : -1;
        prevTabIndex = newIdx;
        currentTab = tab;

        codeTabs.forEach((t) => {
          const active = t.dataset.tab === tab;
          t.classList.toggle('active', active);
          t.setAttribute('aria-selected', String(active));
        });
        showPanel(getActivePanel(), direction);
      }

      traitBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (btn.dataset.trait) switchTrait(btn.dataset.trait);
        });
      });

      codeTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          if (tab.dataset.tab) switchTab(tab.dataset.tab);
        });
      });

      // initialise
      showPanel(getActivePanel(), 1);

      // ── Copy button ──────────────────────────────────────
      const copyBtn   = document.getElementById('copyBtn');
      const installCmd = document.getElementById('installCmd');
      if (copyBtn && installCmd) {
        copyBtn.addEventListener('click', async () => {
          await navigator.clipboard.writeText('npm install @vncsleal/scheml');
          installCmd.classList.add('copied');
          setTimeout(() => installCmd.classList.remove('copied'), 2000);
        });
      }

      // ── Mobile menu ──────────────────────────────────────
      const menuBtn = document.getElementById('menuBtn');
      const header  = document.querySelector('.header');
      if (menuBtn && header) {
        menuBtn.addEventListener('click', () => header.classList.toggle('header--open'));
        document.querySelectorAll('.header__nav-link').forEach((link) => {
          link.addEventListener('click', () => header.classList.remove('header--open'));
        });
      }

      // ── Scroll reveal ─────────────────────────────────────
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });

      document.querySelectorAll(
        '.feature-card, .arch-card, .supported__col, .section-header, .cta'
      ).forEach((el) => revealObserver.observe(el));

      // ── Pipeline reveal ──────────────────────────────────
      const pipelineObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            pipelineObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      const pipeline = document.getElementById('pipelineSection');
      if (pipeline) pipelineObs.observe(pipeline);

      // ── Header scroll ─────────────────────────────────────
      const heroSection = document.getElementById('heroSection');
      const headerEl    = document.querySelector('.header') as HTMLElement | null;
      if (heroSection && headerEl) {
        const heroObs = new IntersectionObserver(
          ([entry]) => headerEl.classList.toggle('header--scrolled', !entry.isIntersecting),
          { threshold: 0 }
        );
        heroObs.observe(heroSection);
      }

      // ── Hero canvas dot grid ─────────────────────────────
      const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
      const hero   = document.getElementById('heroSection');
      if (canvas && hero) {
        const ctx = canvas.getContext('2d');
        if (ctx) {
          const GRID = 24;
          const RADIUS = 150;
          const REST_ALPHA = 0.055;
          const PEAK_ALPHA = 0.45;
          const AMBER: [number,number,number] = [241, 194, 27];
          let dots: {x:number;y:number;brightness:number}[] = [];
          let mouse = { x: -9999, y: -9999 };
          let animId: number;

          function buildDots() {
            canvas!.width  = hero!.offsetWidth;
            canvas!.height = hero!.offsetHeight;
            dots = [];
            for (let x = 0; x < canvas!.width; x += GRID) {
              for (let y = 0; y < canvas!.height; y += GRID) {
                dots.push({ x, y, brightness: 0 });
              }
            }
          }

          function draw() {
            ctx!.clearRect(0, 0, canvas!.width, canvas!.height);
            for (const dot of dots) {
              const dx = dot.x - mouse.x;
              const dy = dot.y - mouse.y;
              const dist = Math.sqrt(dx*dx + dy*dy);
              const target = dist < RADIUS ? (1 - dist / RADIUS) * PEAK_ALPHA : 0;
              dot.brightness += (target - dot.brightness) * 0.07;
              const alpha = REST_ALPHA + dot.brightness;
              if (alpha < 0.005) continue;
              const [r,g,b] = dot.brightness > 0.02 ? AMBER : [255,255,255];
              ctx!.beginPath();
              ctx!.arc(dot.x, dot.y, 1.5, 0, Math.PI * 2);
              ctx!.fillStyle = `rgba(${r},${g},${b},${Math.min(alpha, 1)})`;
              ctx!.fill();
            }
            animId = requestAnimationFrame(draw);
          }

          hero.addEventListener('mousemove', (e) => {
            const rect = hero.getBoundingClientRect();
            mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
          });
          hero.addEventListener('mouseleave', () => { mouse = { x: -9999, y: -9999 }; });

          const ro = new ResizeObserver(() => buildDots());
          ro.observe(hero);

          buildDots();
          draw();
        }
      }
    });
  </script>

  <!-- ════════ STYLES ════════ -->
  <style is:global>
    /* ── Tokens ── */
    :root {
      --gray-100: #161616;
      --gray-90:  #262626;
      --gray-80:  #393939;
      --gray-70:  #525252;
      --gray-60:  #6f6f6f;
      --gray-50:  #8d8d8d;
      --gray-30:  #c6c6c6;
      --gray-20:  #d4d4d4;
      --gray-10:  #f4f4f4;
      --amber-60: #d2a106;
      --amber-50: #f1c21b;
      --amber-40: #fddc69;
      --amber-20: #fcf4d6;
      --amber-90: #3d2e00;
      --green-50: #42be65;
      --green-40: #6fdc8c;
      --red-50:   #fa4d56;
      --bg:              var(--gray-100);
      --bg-elevated:     var(--gray-90);
      --bg-hover:        var(--gray-80);
      --border-subtle:   #2a2a2a;
      --border-strong:   var(--gray-80);
      --text-primary:    var(--gray-10);
      --text-secondary:  var(--gray-30);
      --text-placeholder:var(--gray-60);
      --text-interactive:var(--amber-50);
      --focus:           var(--amber-60);
      --accent:          var(--amber-50);
      --font-sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
      --sp-1:  4px;  --sp-2:  8px;  --sp-3:  12px; --sp-4:  16px;
      --sp-5:  24px; --sp-6:  32px; --sp-7:  40px; --sp-8:  48px;
      --sp-9:  64px; --sp-10: 80px; --sp-11: 96px; --sp-12: 128px;
      --max-width: 1120px;
      --header-height: 48px;
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.5;
      color: var(--text-primary);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--gray-70); }
    ::-webkit-scrollbar-thumb:hover { background: var(--gray-50); }

    /* ── Scroll progress ── */
    .scroll-progress {
      position: fixed;
      top: 0; left: 0;
      height: 1px;
      width: 0%;
      background: var(--amber-60);
      z-index: 200;
      transition: width 40ms linear;
      pointer-events: none;
    }

    /* ── Page ── */
    .page { min-height: 100vh; display: flex; flex-direction: column; }

    /* ── Logo mark ── */
    .logo-mark {
      font-family: var(--font-mono);
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .logo-mark--sm { font-size: 13px; color: var(--text-secondary); }
    .logo-bracket { color: var(--amber-50); font-weight: 400; }

    /* ── Header ── */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      height: var(--header-height);
      background: var(--bg);
      border-bottom: 1px solid var(--border-subtle);
      transition: background 200ms ease, border-color 200ms ease, backdrop-filter 200ms ease;
    }
    .header--scrolled {
      background: rgba(22,22,22,0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom-color: #333;
    }
    .header__inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
      height: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header__logo {
      display: flex;
      align-items: center;
      gap: var(--sp-2);
      text-decoration: none;
    }
    .header__logo:hover .logo-mark { opacity: 0.85; }
    .logo-inner.typing::after {
      content: '|';
      color: inherit;
      font-weight: 400;
      animation: cursor-blink 0.55s step-end infinite;
    }
    .header__nav { display: flex; align-items: center; gap: 0; }
    .header__nav a {
      display: inline-flex;
      align-items: center;
      padding: 0 var(--sp-4);
      height: var(--header-height);
      font-size: 14px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: background 120ms ease, color 120ms ease;
    }
    .header__nav a:hover { background: var(--bg-elevated); color: var(--text-primary); }
    .header__npm-badge { font-family: var(--font-mono); font-size: 12px !important; }
    .npm-version {
      background: var(--bg-elevated);
      padding: 2px 10px;
      border: 1px solid var(--border-subtle);
      font-size: 12px;
      color: var(--text-secondary);
    }
    .header__menu-btn {
      display: none;
      align-items: center;
      justify-content: center;
      width: 40px; height: 40px;
      background: none; border: none;
      color: var(--text-secondary);
      cursor: pointer;
      transition: color 120ms ease;
    }
    .header__menu-btn:hover { color: var(--text-primary); }
    .menu-icon--close { display: none; }
    .header--open .menu-icon--open { display: none; }
    .header--open .menu-icon--close { display: block; }

    /* ── Keyframes ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(36px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes drawRight {
      from { width: 0; }
      to   { width: 100%; }
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(241,194,27,0.35); }
      50%       { box-shadow: 0 0 0 8px rgba(241,194,27,0); }
    }
    @keyframes panelInRight {
      from { opacity: 0; transform: translateX(24px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes panelInLeft {
      from { opacity: 0; transform: translateX(-24px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* ── Hero ── */
    .hero {
      position: relative;
      overflow: hidden;
      padding: var(--sp-12) 0 var(--sp-10);
      border-bottom: 1px solid var(--border-subtle);
    }
    #heroCanvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }
    .hero__container {
      position: relative;
      z-index: 1;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
      display: block;
    }
    .hero__content { display: flex; flex-direction: column; }
    .hero__breadcrumb {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-placeholder);
      margin-bottom: var(--sp-5);
      display: flex;
      align-items: center;
      gap: var(--sp-2);
      animation: fadeUp 600ms cubic-bezier(0.22,1,0.36,1) both;
    }
    .breadcrumb-sep { opacity: 0.4; }
    .hero__title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.12;
      color: var(--text-primary);
      margin-bottom: var(--sp-5);
      animation: fadeUp 720ms cubic-bezier(0.22,1,0.36,1) 180ms both;
    }
    .hero__title strong { font-weight: 600; }
    .hero__lead {
      font-size: 16px;
      line-height: 1.65;
      color: var(--text-secondary);
      margin-bottom: var(--sp-6);
      max-width: 560px;
      animation: fadeUp 720ms cubic-bezier(0.22,1,0.36,1) 360ms both;
    }

    /* Trait pills */
    .trait-pills {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-2);
      margin-bottom: var(--sp-6);
    }
    .trait-pill {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 10px;
      background: var(--amber-90);
      color: var(--amber-40);
      border: 1px solid rgba(241,194,27,0.2);
      letter-spacing: 0.02em;
      animation: fadeIn 500ms cubic-bezier(0.16,1,0.3,1) both;
    }
    .trait-pill:nth-child(1) { animation-delay: 360ms; }
    .trait-pill:nth-child(2) { animation-delay: 420ms; }
    .trait-pill:nth-child(3) { animation-delay: 480ms; }
    .trait-pill:nth-child(4) { animation-delay: 540ms; }
    .trait-pill:nth-child(5) { animation-delay: 600ms; }

    .hero__actions {
      display: flex;
      gap: var(--sp-3);
      align-items: center;
      flex-wrap: wrap;
      animation: fadeUp 720ms cubic-bezier(0.22,1,0.36,1) 520ms both;
    }

    /* Hero right col: code card */
    .hero__code-preview {
      animation: fadeUp 500ms cubic-bezier(0.16,1,0.3,1) 560ms both;
    }
    .hero__code-card {
      border: 1px solid rgba(241,194,27,0.25);
      background: #0d1117;
      overflow: hidden;
    }
    .hero__code-card pre {
      margin: 0 !important;
      padding: var(--sp-5) var(--sp-5) !important;
      background: transparent !important;
      font-size: 12px !important;
      line-height: 1.65 !important;
      font-family: var(--font-mono) !important;
      white-space: pre-wrap !important;
      word-break: break-all !important;
    }

    /* ── Install cmd ── */
    .install-cmd {
      display: inline-flex;
      align-items: center;
      gap: var(--sp-2);
      height: 40px;
      padding: 0 var(--sp-3) 0 var(--sp-4);
      background: var(--bg-elevated);
      border: 1px solid var(--border-strong);
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text-secondary);
      cursor: default;
      transition: border-color 200ms ease;
    }
    .install-cmd:hover { border-color: var(--gray-60); }
    .install-cmd__prompt { color: var(--text-placeholder); }
    .install-cmd__text { color: var(--text-primary); }
    .install-cmd__copy {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      background: none;
      border: none;
      color: var(--text-placeholder);
      cursor: pointer;
      margin-left: var(--sp-1);
      transition: color 120ms ease, background 120ms ease;
      position: relative;
    }
    .install-cmd__copy:hover { background: var(--bg-hover); color: var(--text-primary); }
    .check-icon { display: none; }
    .install-cmd.copied .install-cmd__copy svg:not(.check-icon) { display: none; }
    .install-cmd.copied .check-icon { display: block; color: var(--green-50); }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: var(--sp-2);
      height: 40px;
      padding: 0 var(--sp-5);
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      border: 1px solid transparent;
      transition: background 200ms ease, border-color 200ms ease, color 200ms ease, transform 120ms ease;
    }
    .btn:active { transform: scale(0.98); }
    .btn--primary {
      background: var(--amber-50);
      color: var(--gray-100);
      border-color: var(--amber-50);
    }
    .btn--primary:hover { background: var(--amber-40); border-color: var(--amber-40); }
    .btn--secondary {
      background: transparent;
      color: var(--text-secondary);
      border-color: var(--border-strong);
    }
    .btn--secondary:hover { background: var(--bg-elevated); color: var(--text-primary); }
    .btn--ghost {
      background: transparent;
      color: var(--text-secondary);
      border-color: transparent;
    }
    .btn--ghost:hover { color: var(--text-primary); background: var(--bg-elevated); }

    /* ── Pipeline ── */
    .pipeline {
      padding: var(--sp-8) 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .pipeline__container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
    }
    .pipeline__step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--sp-2);
      padding: 0 var(--sp-6);
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0ms, transform 0ms;
    }
    #pipelineSection.revealed .pipeline__step {
      animation: fadeUp 560ms cubic-bezier(0.22,1,0.36,1) both;
    }
    #pipelineSection.revealed .pipeline__step:nth-child(1) { animation-delay: 0ms; }
    #pipelineSection.revealed .pipeline__step:nth-child(3) { animation-delay: 240ms; }
    #pipelineSection.revealed .pipeline__step:nth-child(5) { animation-delay: 480ms; }
    #pipelineSection.revealed .pipeline__step:nth-child(7) { animation-delay: 720ms; }
    .pipeline__connector {
      flex: 1;
      max-width: 80px;
      display: flex;
      align-items: center;
    }
    .pipeline__connector-line {
      display: block;
      height: 1px;
      background: var(--gray-70);
      width: 0;
    }
    #pipelineSection.revealed .pipeline__connector-line {
      animation: drawRight 600ms cubic-bezier(0.16,1,0.3,1) forwards;
    }
    #pipelineSection.revealed .pipeline__connector:nth-child(2) .pipeline__connector-line { animation-delay: 100ms; }
    #pipelineSection.revealed .pipeline__connector:nth-child(4) .pipeline__connector-line { animation-delay: 300ms; }
    #pipelineSection.revealed .pipeline__connector:nth-child(6) .pipeline__connector-line { animation-delay: 500ms; }
    .pipeline__icon {
      width: 48px; height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border-strong);
      color: var(--text-secondary);
      background: var(--bg-elevated);
    }
    .pipeline__icon--accent {
      border-color: var(--amber-60);
      color: var(--amber-50);
      background: rgba(241,194,27,0.06);
    }
    #pipelineSection.revealed .pipeline__icon--accent {
      animation: pulse 2200ms ease-in-out 1000ms infinite;
    }
    .pipeline__label {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-primary);
    }
    .pipeline__desc {
      font-size: 11px;
      font-family: var(--font-mono);
      color: var(--text-placeholder);
    }

    /* ── Code section ── */
    .code-section {
      padding: var(--sp-11) 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .code-section__container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
    }

    /* ── Section header ── */
    .section-header {
      margin-bottom: var(--sp-8);
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 620ms cubic-bezier(0.22,1,0.36,1), transform 620ms cubic-bezier(0.22,1,0.36,1);
    }
    .section-header.revealed { opacity: 1; transform: translateY(0); }
    .section-tag {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--amber-50);
      margin-bottom: var(--sp-3);
      border-left: 2px solid var(--amber-50);
      padding-left: var(--sp-2);
    }
    .section-header.revealed .section-tag::before {
      width: 24px;
    }
    .section-title {
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--text-primary);
      margin-bottom: var(--sp-3);
    }
    .section-desc {
      font-size: 15px;
      line-height: 1.65;
      color: var(--text-secondary);
      max-width: 600px;
    }

    /* ── Trait selector ── */
    .trait-selector {
      display: flex;
      border: 1px solid var(--border-subtle);
      margin-bottom: var(--sp-2);
      overflow-x: auto;
    }
    .trait-btn {
      padding: 0 var(--sp-5);
      height: 40px;
      background: var(--bg);
      border: none;
      border-right: 1px solid var(--border-subtle);
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-secondary);
      cursor: pointer;
      transition: background 250ms ease, color 250ms ease;
      white-space: nowrap;
    }
    .trait-btn:last-child { border-right: none; }
    .trait-btn:hover { background: var(--bg-elevated); color: var(--text-primary); }
    .trait-btn:active { transform: scale(0.98); }
    .trait-btn.active {
      background: var(--amber-90);
      color: var(--amber-40);
      font-weight: 600;
    }

    /* ── Code tabs ── */
    .code-tabs {
      border: 1px solid var(--border-subtle);
      background: var(--bg-elevated);
    }
    .code-tabs__bar {
      display: flex;
      border-bottom: 1px solid var(--border-subtle);
      background: var(--bg-elevated);
      overflow-x: auto;
    }
    .code-tab {
      display: flex;
      align-items: center;
      gap: var(--sp-3);
      padding: 0 var(--sp-5);
      height: 48px;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--text-secondary);
      font-family: var(--font-sans);
      font-size: 14px;
      cursor: pointer;
      transition: color 120ms ease, background 120ms ease, border-color 120ms ease;
      white-space: nowrap;
    }
    .code-tab:hover { background: var(--bg-hover); color: var(--text-primary); }
    .code-tab.active { color: var(--text-primary); border-bottom-color: var(--amber-60); }
    .code-tab__num {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-placeholder);
    }
    .code-tab.active .code-tab__num { color: var(--amber-50); }
    .code-tab__label { font-weight: 500; }
    .code-tab__file {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-placeholder);
    }
    .code-tabs__panels { display: grid; grid-template-columns: 1fr; }
    .code-panel {
      grid-column: 1;
      grid-row: 1;
      min-height: 320px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    .code-panel.active { opacity: 1; visibility: visible; pointer-events: auto; }
    .code-panel.entering-right { animation: panelInRight 350ms cubic-bezier(0.16,1,0.3,1) both; }
    .code-panel.entering-left  { animation: panelInLeft  350ms cubic-bezier(0.16,1,0.3,1) both; }
    .code-panel pre {
      margin: 0 !important;
      padding: var(--sp-5) var(--sp-6) !important;
      background: transparent !important;
      border-radius: 0 !important;
      font-size: 13px !important;
      line-height: 1.7 !important;
      font-family: var(--font-mono) !important;
      white-space: pre-wrap !important;
      word-break: break-all !important;
      overflow-x: hidden;
    }

    /* ── Features grid ── */
    .features {
      padding: var(--sp-11) 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .features__container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
    }
    .features__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-top: 1px solid var(--border-subtle);
      border-left: 1px solid var(--border-subtle);
    }
    .feature-card {
      padding: var(--sp-6);
      border-right: 1px solid var(--border-subtle);
      border-bottom: 1px solid var(--border-subtle);
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 560ms cubic-bezier(0.22,1,0.36,1), transform 560ms cubic-bezier(0.22,1,0.36,1), background 200ms ease, border-left-color 250ms ease;
    }
    .feature-card.revealed { opacity: 1; transform: translateY(0); }
    .feature-card:nth-child(2).revealed { transition-delay: 110ms; }
    .feature-card:nth-child(3).revealed { transition-delay: 220ms; }
    .feature-card:nth-child(4).revealed { transition-delay: 330ms; }
    .feature-card:nth-child(5).revealed { transition-delay: 0ms; }
    .feature-card:nth-child(6).revealed { transition-delay: 110ms; }
    .feature-card:nth-child(7).revealed { transition-delay: 220ms; }
    .feature-card:nth-child(8).revealed { transition-delay: 330ms; }
    .feature-card:hover { background: var(--bg-elevated); }
    .feature-card__icon {
      width: 40px; height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-secondary);
      margin-bottom: var(--sp-5);
    }
    .feature-card--amber .feature-card__icon {
      background: rgba(241,194,27,0.07);
      border: 1px solid rgba(241,194,27,0.18);
      color: var(--amber-50);
    }
    .feature-card__title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--sp-2);
    }
    .feature-card__desc {
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-secondary);
    }
    .feature-card__desc code {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--bg-hover);
      padding: 1px 5px;
      color: var(--text-primary);
    }

    /* ── Architecture ── */
    .how-it-works {
      padding: var(--sp-11) 0;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border-subtle);
    }
    .how-it-works__container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
    }
    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border-subtle);
      border: 1px solid var(--border-subtle);
    }
    .arch-card {
      position: relative;
      overflow: hidden;
      background: var(--bg);
      padding: var(--sp-6);
      display: flex;
      flex-direction: column;
      gap: var(--sp-4);
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 560ms cubic-bezier(0.22,1,0.36,1), transform 560ms cubic-bezier(0.22,1,0.36,1);
    }
    .arch-card.revealed { opacity: 1; transform: translateY(0); }
    .arch-card:nth-child(2).revealed { transition-delay: 200ms; }
    .arch-card:nth-child(3).revealed { transition-delay: 400ms; }
    .arch-card::before {
      content: attr(data-num);
      position: absolute;
      right: -12px; top: -20px;
      font-family: var(--font-mono);
      font-size: 112px;
      font-weight: 700;
      color: var(--amber-50);
      opacity: 0;
      pointer-events: none;
      line-height: 1;
      user-select: none;
      transition: opacity 600ms ease 200ms;
    }
    .arch-card.revealed::before { opacity: 0.04; }
    .arch-card__header { display: flex; align-items: center; gap: var(--sp-3); }
    .arch-card__num {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--amber-50);
      font-weight: 500;
    }
    .arch-card__title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
    }
    .arch-card__body {
      font-size: 14px;
      line-height: 1.65;
      color: var(--text-secondary);
      flex: 1;
    }
    .arch-card__body code {
      font-family: var(--font-mono);
      font-size: 12px;
      background: var(--bg-elevated);
      padding: 1px 6px;
      color: var(--text-primary);
    }
    .arch-card__tags { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
    .tag {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 2px 10px;
      background: var(--bg-elevated);
      color: var(--text-secondary);
      border: 1px solid var(--border-subtle);
    }

    /* ── Supported ── */
    .supported {
      padding: var(--sp-10) 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .supported__container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
    }
    .supported__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--sp-9);
    }
    .supported__col {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 560ms cubic-bezier(0.22,1,0.36,1), transform 560ms cubic-bezier(0.22,1,0.36,1);
    }
    .supported__col.revealed { opacity: 1; transform: translateY(0); }
    .supported__col:nth-child(2).revealed { transition-delay: 130ms; }
    .supported__col:nth-child(3).revealed { transition-delay: 260ms; }
    .supported__col:nth-child(4).revealed { transition-delay: 390ms; }
    .supported__heading {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-placeholder);
      margin-bottom: var(--sp-5);
      font-family: var(--font-mono);
    }
    .supported__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--sp-3);
    }
    .supported__list li {
      font-size: 14px;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      gap: var(--sp-3);
    }
    .supported__check {
      color: var(--green-50);
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 600;
    }

    /* ── CTA ── */
    .cta {
      padding: var(--sp-12) 0;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border-subtle);
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 620ms cubic-bezier(0.22,1,0.36,1), transform 620ms cubic-bezier(0.22,1,0.36,1);
    }
    .cta.revealed { opacity: 1; transform: translateY(0); }
    .cta__container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6); }
    .cta__inner { }
    .cta__rule {
      display: block;
      height: 1px;
      background: var(--amber-60);
      width: 0;
      margin-bottom: var(--sp-5);
    }
    .cta.revealed .cta__rule {
      animation: drawRight 500ms cubic-bezier(0.16,1,0.3,1) both;
      width: auto;
    }
    .cta__title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      margin-bottom: var(--sp-4);
      animation: none;
    }
    .cta.revealed .cta__title {
      animation: fadeUp 500ms cubic-bezier(0.16,1,0.3,1) 80ms both;
    }
    .cta__desc {
      font-size: 16px;
      color: var(--text-secondary);
      margin-bottom: var(--sp-7);
      line-height: 1.6;
    }
    .cta__actions { display: flex; gap: var(--sp-4); align-items: center; flex-wrap: wrap; }

    /* ── Footer ── */
    .footer { padding: var(--sp-5) 0; border-top: 1px solid var(--border-subtle); }
    .footer__container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--sp-6);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer__left { display: flex; align-items: center; gap: var(--sp-2); }
    .footer__right {
      display: flex;
      align-items: center;
      gap: var(--sp-3);
      font-size: 12px;
      font-family: var(--font-mono);
      color: var(--text-placeholder);
    }
    .footer__sep { opacity: 0.4; }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-delay: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
      .section-header, .feature-card, .arch-card, .supported__col, .cta, .pipeline__step {
        opacity: 1 !important;
        transform: none !important;
      }
    }

    /* ── Tablet ── */
    @media (max-width: 1023px) {
      .hero__container { grid-template-columns: 1fr; }
      .hero__code-preview { display: none; }
      .features__grid { grid-template-columns: repeat(2, 1fr); }
      .supported__grid { grid-template-columns: repeat(2, 1fr); gap: var(--sp-7); }
      .arch-grid { grid-template-columns: 1fr; }
      .pipeline__connector { display: none; }
      .pipeline__container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--sp-5);
        justify-items: center;
      }
      .code-section { padding: var(--sp-9) 0; }
      .features { padding: var(--sp-9) 0; }
      .how-it-works { padding: var(--sp-9) 0; }
      .cta { padding: var(--sp-9) 0; }
    }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .header { height: auto; min-height: var(--header-height); }
      .header__inner { padding: 0 var(--sp-4); flex-wrap: wrap; height: var(--header-height); }
      .header__menu-btn { display: flex; }
      .header__nav {
        display: none;
        flex-direction: column;
        width: 100%;
        border-top: 1px solid var(--border-subtle);
        background: var(--bg);
        order: 3;
      }
      .header--open .header__inner { height: auto; }
      .header--open .header__nav { display: flex; }
      .header__nav a { width: 100%; height: 48px; padding: 0 var(--sp-4); border-bottom: 1px solid var(--border-subtle); }
      .header__nav .header__npm-badge { justify-content: flex-start; border-bottom: none; }

      .hero { padding: var(--sp-8) 0 var(--sp-7); }
      .hero__container { padding: 0 var(--sp-4); }
      .hero__title { font-size: 2rem; margin-bottom: var(--sp-4); line-height: 1.2; }
      .hero__lead { font-size: 15px; margin-bottom: var(--sp-5); }
      .hero__actions { flex-direction: column; align-items: stretch; gap: var(--sp-3); }
      .install-cmd { width: 100%; justify-content: center; overflow: hidden; }
      .btn { width: 100%; justify-content: center; height: 44px; }
      .trait-pills { margin-bottom: var(--sp-5); }

      .pipeline { padding: var(--sp-6) 0; }
      .pipeline__container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--sp-5);
        justify-items: center;
        padding: 0 var(--sp-4);
      }
      .pipeline__icon { width: 40px; height: 40px; }
      .pipeline__icon svg { width: 20px; height: 20px; }
      .pipeline__label { font-size: 13px; }
      .pipeline__desc { font-size: 11px; }

      .code-section { padding: var(--sp-7) 0; }
      .code-section__container { padding: 0 var(--sp-4); }
      .section-header { margin-bottom: var(--sp-6); }
      .section-title { font-size: 1.35rem; }
      .section-desc { font-size: 14px; }
      .trait-selector { margin-bottom: 0; }
      .trait-btn { padding: 0 var(--sp-3); font-size: 11px; }
      .code-tab__file { display: none; }
      .code-tab { padding: 0 var(--sp-3); height: 44px; gap: var(--sp-2); flex: 1; justify-content: center; }
      .code-panel { min-height: 240px; }
      .code-panel pre { padding: var(--sp-4) !important; font-size: 12px !important; line-height: 1.6 !important; }

      .features { padding: var(--sp-7) 0; }
      .features__container { padding: 0 var(--sp-4); }
      .features__grid { grid-template-columns: 1fr; border-left: none; border-top: none; }
      .feature-card { padding: var(--sp-5) 0; border-right: none; border-left: 2px solid transparent; }
      .feature-card--amber .feature-card__icon { width: 36px; height: 36px; }

      .how-it-works { padding: var(--sp-7) 0; }
      .how-it-works__container { padding: 0 var(--sp-4); }
      .arch-card { padding: var(--sp-5); }
      .arch-card__title { font-size: 15px; }
      .arch-card::before { font-size: 80px; }

      .supported { padding: var(--sp-7) 0; }
      .supported__container { padding: 0 var(--sp-4); }
      .supported__grid { grid-template-columns: 1fr; gap: 0; }
      .supported__col { padding: var(--sp-5) 0; border-bottom: 1px solid var(--border-subtle); }
      .supported__col:last-child { border-bottom: none; }

      .cta { padding: var(--sp-8) 0; }
      .cta__container { padding: 0 var(--sp-4); }
      .cta__title { font-size: 2rem; }
      .cta__desc { font-size: 14px; margin-bottom: var(--sp-6); }
      .cta__actions { flex-direction: column; }
      .cta__actions .btn { width: 100%; justify-content: center; }

      .footer { padding: var(--sp-4) 0; }
      .footer__container { padding: 0 var(--sp-4); flex-direction: column; gap: var(--sp-3); text-align: center; }
      .footer__right { font-size: 11px; }
    }
  </style>
</BaseLayout>
