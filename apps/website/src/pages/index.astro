---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro:components';

const title = 'ScheML — Compiler-First ML for TypeScript';
const description = 'ScheML is to machine learning what Prisma is to databases. Define intelligence traits in TypeScript — compile once, run in-process.';

// ── Trait define snippets ─────────────────────────────────
const defineCodePredictive = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const churnRisk = defineTrait('User', {
  type: 'predictive',
  name: 'churnRisk',
  target: 'cancelledAt',
  features: ['logins', 'subscription', 'totalSpend', 'monthsActive'],
  output: {
    field: 'willChurn',
    taskType: 'binary_classification',
  },
  qualityGates: [
    { metric: 'f1', threshold: 0.85, comparison: 'gte' },
  ],
});

export default defineConfig({ traits: [churnRisk] });`;

const defineCodeAnomaly = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const orderFraud = defineTrait('Order', {
  type: 'anomaly',
  name: 'orderFraud',
  features: ['amount', 'itemCount', 'shippingCountry', 'accountAgeDays'],
  algorithm: { name: 'iforest' },
  qualityGates: [
    { metric: 'roc_auc', threshold: 0.90, comparison: 'gte' },
  ],
});

export default defineConfig({ traits: [orderFraud] });`;

const defineCodeSimilarity = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const productRecommend = defineTrait('Product', {
  type: 'similarity',
  name: 'productRecommend',
  features: ['category', 'price', 'brand', 'avgRating'],
  algorithm: { name: 'cosine' },
});

export default defineConfig({ traits: [productRecommend] });`;

const defineCodeTemporal = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const engagementTrend = defineTrait('SessionEvent', {
  type: 'temporal',
  name: 'engagementTrend',
  sequence: 'engagementScore',
  orderBy: 'createdAt',
  target: 'willChurn',
  output: { field: 'predictedChurn', taskType: 'binary_classification' },
});

export default defineConfig({ traits: [engagementTrend] });`;

const defineCodeGenerative = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const productDescription = defineTrait('Product', {
  type: 'generative',
  name: 'productDescription',
  contextFields: ['name', 'category', 'specs'],
  output: { field: 'description' },
  provider: { sdk: 'ai', model: 'openai:gpt-4o-mini' },
});

export default defineConfig({ traits: [productDescription] });`;

// ── Compile / Infer snippets ──────────────────────────────
const trainCode = `$ scheml train

◉ Loading schema...
✔ Schema loaded
◉ Loading trait definitions...
✔ Loaded 1 trait definition(s)
◉ Running preflight validation...
✔ Preflight validation passed
◉ Checking Python environment...
✔ Python environment OK
◉ Extracting training data...
◉ Training churnRisk (FLAML AutoML, 60s budget)...
✔ Best estimator: LGBMClassifier
◉ Writing artefacts...
✔ Artefacts written to ./.scheml

[OK] Training complete

Artefacts:
  churnRisk.metadata.json
  churnRisk.onnx`;

const inferCodePredictive = `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predict('churnRisk', user);
// → { prediction: "1", timestamp: "2026-04-02T..." }`;

const inferCodeAnomaly = `const result = await db.scheml.predict('orderFraud', order);
// → { score: 0.87, isAnomaly: true }`;

const inferCodeSimilarity = `const results = await db.scheml.findSimilar(
  'productRecommend',
  seedProduct,
  { limit: 10 }
);
// → Product[] ranked by cosine similarity`;

const inferCodeTemporal = `const result = await db.scheml.predict('engagementTrend', sessionWindow);
// → { prediction: "1", timestamp: "2026-04-02T..." }`;

const inferCodeGenerative = `const result = await db.scheml.generate(
  'productDescription',
  product
);
// → { description: "Lightweight merino blend..." }`;
---

<BaseLayout title={title} description={description}>
  <div class="page">

    <!-- ════════ SCROLL PROGRESS ════════ -->
    <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

    <!-- ════════ HEADER ════════ -->
    <header class="header" id="top" transition:name="site-header">
      <div class="header__inner">
        <a href="/" class="header__logo" aria-label="ScheML home">
          <span class="logo-mark">
            <span class="logo-bracket">[</span><span class="logo-inner"></span><span class="logo-bracket">]</span>
          </span>
        </a>
        <nav class="header__nav" aria-label="Main navigation">
          <a href="#features" class="header__nav-link">Features</a>
          <a href="#workflow" class="header__nav-link">How it works</a>
          <a href="/demo" class="header__nav-link">Demo</a>
          <a href="https://github.com/vncsleal/scheml" target="_blank" rel="noopener noreferrer" class="header__nav-link">
            GitHub
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" style="margin-left: 4px; opacity: 0.5;">
              <path d="M10 1h5v5l-1.7-1.7-4.6 4.6-1.4-1.4 4.6-4.6L10 1zM3 3h4v2H3v8h8V9h2v4a2 2 0 01-2 2H3a2 2 0 01-2-2V5a2 2 0 012-2z"/>
            </svg>
          </a>
          <a href="https://www.npmjs.com/package/@vncsleal/scheml" target="_blank" rel="noopener noreferrer" class="header__npm-badge header__nav-link">
            <span class="npm-version">v0.3.1</span>
          </a>
        </nav>
        <button class="header__menu-btn" aria-label="Toggle menu" id="menuBtn">
          <svg class="menu-icon menu-icon--open" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 5h14"/><path d="M3 10h14"/><path d="M3 15h14"/>
          </svg>
          <svg class="menu-icon menu-icon--close" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 4l12 12"/><path d="M16 4L4 16"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- ════════ HERO ════════ -->
    <section class="hero" id="heroSection">
      <canvas id="heroCanvas" aria-hidden="true"></canvas>
      <div class="hero__container">
        <div class="hero__content">
          <div class="hero__breadcrumb">
            <span>@vncsleal</span>
            <span class="breadcrumb-sep">/</span>
            <span>scheml</span>
          </div>

          <h1 class="hero__title">
            Machine learning<br/>
            <strong>that compiles.</strong>
          </h1>

          <p class="hero__lead">
            Define intelligence traits — predictive, anomaly, similarity, temporal, or generative — in TypeScript.
            ScheML compiles them to versioned build artefacts and runs each one in-process — no model registry, no microservices.
          </p>

          <div class="hero__actions">
            <div class="install-cmd" id="installCmd">
              <span class="install-cmd__prompt">$</span>
              <code class="install-cmd__text">npm install @vncsleal/scheml</code>
              <button class="install-cmd__copy" aria-label="Copy install command" id="copyBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2"/>
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                </svg>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="check-icon" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
              </button>
            </div>
            <a href="/demo" class="btn btn--secondary">Live demo</a>
            <a href="https://github.com/vncsleal/scheml" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
              View source
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
            </a>
          </div>
        </div><!-- /.hero__content -->
      </div><!-- /.hero__container -->
    </section>

    <!-- ════════ PIPELINE ════════ -->
    <section class="pipeline" id="pipelineSection">
      <div class="pipeline__container">
        <div class="pipeline__step">
          <div class="pipeline__icon">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="4" y="4" width="24" height="24" rx="2"/>
              <path d="M10 12h12M10 16h8M10 20h10"/>
            </svg>
          </div>
          <div class="pipeline__label">Define</div>
          <div class="pipeline__desc">TypeScript</div>
        </div>
        <div class="pipeline__connector" aria-hidden="true">
          <span class="pipeline__connector-line"></span>
        </div>
        <div class="pipeline__step">
          <div class="pipeline__icon pipeline__icon--accent">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M16 4v24M4 16l12-12 12 12"/>
              <rect x="6" y="20" width="20" height="8" rx="1"/>
            </svg>
          </div>
          <div class="pipeline__label">Compile</div>
          <div class="pipeline__desc">Build time</div>
        </div>
        <div class="pipeline__connector" aria-hidden="true">
          <span class="pipeline__connector-line"></span>
        </div>
        <div class="pipeline__step">
          <div class="pipeline__icon">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="16" cy="16" r="12"/>
              <path d="M16 10v6l4 4"/>
            </svg>
          </div>
          <div class="pipeline__label">Validate</div>
          <div class="pipeline__desc">Quality gates</div>
        </div>
        <div class="pipeline__connector" aria-hidden="true">
          <span class="pipeline__connector-line"></span>
        </div>
        <div class="pipeline__step">
          <div class="pipeline__icon">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 4l8 12H4l8-12z"/>
              <path d="M20 16l8 12H12l8-12z"/>
            </svg>
          </div>
          <div class="pipeline__label">Infer</div>
          <div class="pipeline__desc">In-process</div>
        </div>
      </div>
    </section>

    <!-- ════════ CODE TABS ════════ -->
    <section class="code-section" id="workflow">
      <div class="code-section__container">
        <div class="section-header">
          <p class="section-tag">Workflow</p>
          <h2 class="section-title">Three files. Zero infrastructure.</h2>
          <p class="section-desc">
            Define any intelligence trait in TypeScript, compile once, run in-process.
            Same feature resolvers at train time and inference time — the encoding cannot drift.
          </p>
        </div>

        <!-- Trait type selector -->
        <div class="trait-selector" id="traitSelector" role="tablist" aria-label="Trait type">
          <button class="trait-btn active" role="tab" aria-selected="true" data-trait="predictive">predictive</button>
          <button class="trait-btn" role="tab" aria-selected="false" data-trait="anomaly">anomaly</button>
          <button class="trait-btn" role="tab" aria-selected="false" data-trait="similarity">similarity</button>
          <button class="trait-btn" role="tab" aria-selected="false" data-trait="temporal">temporal</button>
          <button class="trait-btn" role="tab" aria-selected="false" data-trait="generative">generative</button>
        </div>

        <div class="code-tabs" id="codeTabs">
          <div class="code-tabs__bar" role="tablist">
            <button class="code-tab active" role="tab" aria-selected="true" data-tab="define">
              <span class="code-tab__num">01</span>
              <span class="code-tab__label">Define</span>
              <span class="code-tab__file">scheml.config.ts</span>
            </button>
            <button class="code-tab" role="tab" aria-selected="false" data-tab="train">
              <span class="code-tab__num">02</span>
              <span class="code-tab__label">Compile</span>
              <span class="code-tab__file">terminal</span>
            </button>
            <button class="code-tab" role="tab" aria-selected="false" data-tab="infer">
              <span class="code-tab__num">03</span>
              <span class="code-tab__label">Infer</span>
              <span class="code-tab__file">api/infer.ts</span>
            </button>
          </div>
          <div class="code-tabs__panels">
            <!-- Define panels (one per trait type) -->
            <div class="code-panel active" id="panel-define-predictive" role="tabpanel" data-trait-panel="predictive">
              <Code code={defineCodePredictive} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-define-anomaly" role="tabpanel" data-trait-panel="anomaly">
              <Code code={defineCodeAnomaly} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-define-similarity" role="tabpanel" data-trait-panel="similarity">
              <Code code={defineCodeSimilarity} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-define-temporal" role="tabpanel" data-trait-panel="temporal">
              <Code code={defineCodeTemporal} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-define-generative" role="tabpanel" data-trait-panel="generative">
              <Code code={defineCodeGenerative} lang="ts" theme="github-dark" />
            </div>
            <!-- Compile panel (shared) -->
            <div class="code-panel" id="panel-train" role="tabpanel">
              <Code code={trainCode} lang="bash" theme="github-dark" />
            </div>
            <!-- Infer panels (one per trait type) -->
            <div class="code-panel" id="panel-infer-predictive" role="tabpanel" data-trait-infer-panel="predictive">
              <Code code={inferCodePredictive} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-infer-anomaly" role="tabpanel" data-trait-infer-panel="anomaly">
              <Code code={inferCodeAnomaly} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-infer-similarity" role="tabpanel" data-trait-infer-panel="similarity">
              <Code code={inferCodeSimilarity} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-infer-temporal" role="tabpanel" data-trait-infer-panel="temporal">
              <Code code={inferCodeTemporal} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-infer-generative" role="tabpanel" data-trait-infer-panel="generative">
              <Code code={inferCodeGenerative} lang="ts" theme="github-dark" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════ FEATURES ════════ -->
    <section class="features" id="features">
      <div class="features__container">
        <div class="section-header">
          <p class="section-tag">Capabilities</p>
          <h2 class="section-title">Built for production correctness.</h2>
        </div>

        <div class="features__grid">
          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="6" width="28" height="20" rx="2"/>
                <path d="M9 14l3 3 5-6"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Compiler-first</h3>
            <p class="feature-card__desc">Trait definitions compile to versioned build artefacts. No model registry, no train/inference drift. Artefacts are deterministic across machines.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="10" cy="16" r="4"/>
                <circle cx="22" cy="8" r="4"/>
                <circle cx="22" cy="24" r="4"/>
                <path d="M14 14l4-4M14 18l4 4"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Five trait types</h3>
            <p class="feature-card__desc">Predictive, anomaly, similarity, temporal, generative — one <code>defineTrait()</code> API. Each compiles to the right artefact format for its inference strategy.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="10" width="8" height="12" rx="1"/>
                <rect x="12" y="6" width="8" height="20" rx="1"/>
                <rect x="22" y="13" width="8" height="9" rx="1"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Three adapters</h3>
            <p class="feature-card__desc">Prisma (model string), Drizzle (table object), Zod (schema object). Same trait definition — swap only the entity declaration.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="16" cy="16" r="13"/>
                <path d="M16 8v8l6 3"/>
              </svg>
            </div>
            <h3 class="feature-card__title">In-process inference</h3>
            <p class="feature-card__desc">ONNX Runtime, FAISS, and AI SDK calls run in-process. No serialization, no network hop. Predictive trait latency typically &lt;1 ms.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 4l12 7v10l-12 7L4 21V11l12-7z"/>
                <path d="M16 18V4M16 18l12-7M16 18L4 11"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Schema drift guard</h3>
            <p class="feature-card__desc">Every artefact carries a SHA-256 hash of the schema at compile time. <code>db.scheml.predict()</code> re-hashes on every call — <code>SchemaDriftError</code> before a single inference runs.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="8" cy="8" r="4"/>
                <circle cx="24" cy="8" r="4"/>
                <circle cx="16" cy="24" r="4"/>
                <path d="M12 8h8M10 12l4 8M22 12l-4 8"/>
              </svg>
            </div>
            <h3 class="feature-card__title">TraitGraph</h3>
            <p class="feature-card__desc">Chain traits into dependency graphs. Shared features are computed once and threaded through all dependent traits automatically.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 28V12l12-8 12 8v16"/>
                <path d="M12 28v-8h8v8"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Quality gates</h3>
            <p class="feature-card__desc">Define metric thresholds (<code>f1</code>, <code>accuracy</code>, <code>roc_auc</code>, <code>rmse</code>) in your trait config. <code>scheml train</code> fails-fast — no silent regressions.</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="20" height="20" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 20c4-8 20-8 24 0"/>
                <path d="M4 12c4-8 20-8 24 0"/>
                <circle cx="16" cy="26" r="3"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Feedback loop</h3>
            <p class="feature-card__desc"><code>db.scheml.record()</code> and <code>db.scheml.recordBatch()</code> push observed outcomes back. Re-run <code>scheml train</code> to close the loop without changing your schema.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════ HOW IT WORKS ════════ -->
    <section class="how-it-works">
      <div class="how-it-works__container">
        <div class="section-header">
          <p class="section-tag">Architecture</p>
          <h2 class="section-title">Traits as build artefacts.</h2>
          <p class="section-desc">
            ScheML treats intelligence traits the same way a compiler treats source code —
            as deterministic transformations from declaration to artefact.
          </p>
        </div>

        <div class="arch-grid">
          <div class="arch-card" data-num="01">
            <div class="arch-card__header">
              <span class="arch-card__num">01</span>
              <h3 class="arch-card__title">Declaration</h3>
            </div>
            <p class="arch-card__body">
              Use <code>defineTrait()</code> to declare an intelligence trait against a Prisma model, Drizzle table, or Zod schema.
              Specify feature fields, algorithm, and quality constraints. No data access — purely declarative.
            </p>
            <div class="arch-card__tags">
              <span class="tag">defineTrait()</span>
              <span class="tag">Prisma · Drizzle · Zod</span>
              <span class="tag">Type-safe</span>
            </div>
          </div>

          <div class="arch-card" data-num="02">
            <div class="arch-card__header">
              <span class="arch-card__num">02</span>
              <h3 class="arch-card__title">Compilation</h3>
            </div>
            <p class="arch-card__body">
              The CLI loads trait definitions, extracts training data via your adapter, and materialises a training dataset.
              A Python backend trains the model and exports a versioned artefact — ONNX, FAISS, embedded pickle, or JSON config — plus a schema hash.
            </p>
            <div class="arch-card__tags">
              <span class="tag">scheml train</span>
              <span class="tag">ONNX / FAISS / AI SDK</span>
              <span class="tag">Schema hash</span>
            </div>
          </div>

          <div class="arch-card" data-num="03">
            <div class="arch-card__header">
              <span class="arch-card__num">03</span>
              <h3 class="arch-card__title">Inference</h3>
            </div>
            <p class="arch-card__body">
              At runtime, <code>extendClient()</code> wraps your ORM client. The same feature resolvers that ran at train time
              run at inference time — encoding cannot drift. Schema hash is validated on every call.
            </p>
            <div class="arch-card__tags">
              <span class="tag">extendClient()</span>
              <span class="tag">In-process</span>
              <span class="tag">Deterministic</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════ SUPPORTED ════════ -->
    <section class="supported">
      <div class="supported__container">
        <div class="supported__grid">
          <div class="supported__col">
            <h3 class="supported__heading">Task types</h3>
