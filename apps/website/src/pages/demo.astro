  </div>
  <div id="__demo_data__" hidden aria-hidden="true"
    data-presets={JSON.stringify({
      predictivePresets: manifest.ui.predictivePresets,
      anomalyPresets: manifest.ui.anomalyPresets,
      similarityPresets: manifest.ui.similarityPresets,
      temporalPresets: manifest.ui.temporalPresets,
      generativeExamples: generativeContract.examples,
      generativePromptTemplate: 'Return the next retention motion for this account in one concise decision.',
      initialGenerativeKey,
      schemaHashes: {
        predictive: predictiveTrait.schemaHash.slice(0, 8),
        anomaly: anomalyTrait.schemaHash.slice(0, 8),
        similarity: similarityTrait.schemaHash.slice(0, 8),
        temporal: temporalTrait.schemaHash.slice(0, 8),
        generative: generativeContract.trait.schemaHash.slice(0, 8),
      },
    })}
  ></div>
  <script>
  document.addEventListener('astro:page-load', () => {
    const __raw = document.getElementById('__demo_data__');
    if (!__raw) return;
    const { predictivePresets, anomalyPresets, similarityPresets, temporalPresets, generativeExamples, generativePromptTemplate, initialGenerativeKey, schemaHashes } = JSON.parse(__raw.dataset.presets!);
    // ── Logo typewriter ──────────────────────────────────────────────────
    const logoInner = document.querySelector('.header__logo .logo-inner');
    if (logoInner) {
      const WORD = 'scheml'; const SPEED = 72; const DELAY = 300;
      logoInner.textContent = ''; logoInner.classList.remove('typing');
      let i = 0;
      setTimeout(() => {
        logoInner.classList.add('typing');
        const iv = setInterval(() => {
          logoInner.textContent = WORD.slice(0, ++i);
          if (i >= WORD.length) { clearInterval(iv); logoInner.classList.remove('typing'); }
        }, SPEED);
      }, DELAY);
    }

    // ── Helpers ─────────────────────────────────────────────────────────
    function flashPanel(el) {
      if (!el) return;
      el.classList.remove('result-updated'); void el.offsetWidth;
      el.classList.add('result-updated');
      el.addEventListener('animationend', () => el.classList.remove('result-updated'), { once: true });
    }
    function updateLatencyBar(barEl, fillEl, ms) {
      if (barEl) barEl.textContent = ms + ' ms';
      if (fillEl) fillEl.style.width = Math.min(100, Math.max(1, (ms / 800) * 100)) + '%';
    }

    // ── Trait section header metadata ──────────────────────────────────
    const TRAIT_META = {
      predictive: {
        tag: 'Live inference · predictive',
        title: 'Adjust inputs. Get a real prediction.',
        desc: 'Each submit hits <code>/api/demo/predict</code>, which calls <code>db.scheml.predict()</code> synchronously in the Node.js route. The latency shown is actual wall-clock ONNX inference time.',
      },
      anomaly: {
        tag: 'Live inference · anomaly',
        title: 'Detect anomalies in server metrics.',
        desc: 'Adjust the metric sliders to cross anomaly thresholds. The isolation forest model scores each sample in-process using L2-norm scoring against the trained <code>serverAnomaly</code> artefact — no HTTP round-trip, no serialisation overhead.',
      },
      similarity: {
        tag: 'Live inference · similarity',
        title: 'Retrieve the nearest neighbours.',
        desc: 'Set category and feature sliders to find the most similar products from the embedded product space. Cosine similarity runs in-process over the compiled <code>productSimilarity.embeddings.npy</code> index — no vector DB, no external service.',
      },
      temporal: {
        tag: 'Live inference · temporal',
        title: 'Predict churn from weekly engagement scores.',
        desc: 'Enter the last five weeks of engagement scores and the <code>extra_tree</code> model predicts whether the user will churn. Runs in-process against the compiled <code>engagementSequence.onnx</code> artefact — no subprocess, no network.',
      },
      generative: {
        tag: 'Live inference · generative',
        title: 'Browse the compiled prompt contract.',
        desc: 'The <code>retentionMessage</code> trait compiles into a prompt contract shipped with the bundle. The public page shows the contract only — runtime stays available to API consumers without depending on provider keys.',
      },
    };

    // ── Trait tab switching ──────────────────────────────────────────────
    const traitTabs    = document.querySelectorAll<HTMLElement>('.trait-tab');
    const inferenceTag   = document.getElementById('inferenceTag');
    const inferenceTitle = document.getElementById('inferenceTitle');
    const inferenceDesc  = document.getElementById('inferenceDesc');

    const TRAIT_DEFINE_CODE = {
      predictive: `import { defineTrait, defineConfig } from '@vncsleal/scheml';

export const userChurn = defineTrait('User', {
  type: 'predictive',
  name: 'userChurn',
  target: 'willChurn',
  features: ['lastActiveAt', 'monthlySpend', 'supportTickets'],
  output: { field: 'willChurn', taskType: 'binary_classification' },
  qualityGates: [
    { metric: 'f1',       threshold: 0.80, comparison: 'gte' },
    { metric: 'accuracy', threshold: 0.85, comparison: 'gte' },
  ],
});

export default defineConfig({
  adapter: 'prisma',
  schema: './prisma/schema.prisma',
  traits: [userChurn],
});`,
      anomaly: `import { defineTrait, defineConfig } from '@vncsleal/scheml';

export const serverAnomaly = defineTrait('MetricSnapshot', {
  type: 'anomaly',
  name: 'serverAnomaly',
  baseline: ['cpuUsage', 'memoryPressure', 'errorRate'],
  sensitivity: 'high',
  qualityGates: [
    { metric: 'roc_auc', threshold: 0.90, comparison: 'gte' },
  ],
});

export default defineConfig({
  adapter: 'prisma',
  schema: './prisma/schema.prisma',
  traits: [serverAnomaly],
});`,
      similarity: `import { defineTrait, defineConfig } from '@vncsleal/scheml';

export const productSimilarity = defineTrait('Product', {
  type: 'similarity',
  name: 'productSimilarity',
  on: ['categoryIndex', 'price', 'batteryHours', 'weightKg'],
});

export default defineConfig({
  adapter: 'prisma',
  schema: './prisma/schema.prisma',
  traits: [productSimilarity],
});`,
      temporal: `import { defineTrait, defineConfig } from '@vncsleal/scheml';

export const engagementSequence = defineTrait('SessionEvent', {
  type: 'temporal',
  name: 'engagementSequence',
  sequence: 'engagementScore',
  orderBy: 'createdAt',
  target: 'willChurn',
  output: { field: 'willChurn', taskType: 'binary_classification' },
});

export default defineConfig({
  adapter: 'prisma',
  schema: './prisma/schema.prisma',
  traits: [engagementSequence],
});`,
      generative: `import { defineTrait, defineConfig } from '@vncsleal/scheml';
import { openai } from '@ai-sdk/openai';
import { z } from 'zod';

export const retentionMessage = defineTrait('User', {
  type: 'generative',
  name: 'retentionMessage',
  context: ['planTier', 'willChurn', 'monthlySpend'],
  prompt: 'Return the next retention motion in one concise decision.',
  outputSchema: z.object({
    action: z.enum(['retain', 'escalate', 'celebrate']),
  }),
});

export default defineConfig({
  adapter: 'prisma',
  schema: './prisma/schema.prisma',
  generativeProvider: openai('gpt-4o-mini'),
  traits: [retentionMessage],
});`,
    };

    const TRAIT_COMPILE_CODE = {
      predictive: (h) => `$ scheml train\n\n◉ Loading Prisma schema...\n✔ Schema loaded (hash: ${h})\n◉ Training userChurn (gbm)...\n✔ Training complete (97 iterations)\n◉ Writing artefacts...\n✔ Artefacts written to ./.scheml\n\nArtefacts:\n  userChurn.metadata.json\n  userChurn.onnx`,
      anomaly:    (h) => `$ scheml train\n\n◉ Loading Prisma schema...\n✔ Schema loaded (hash: ${h})\n◉ Training serverAnomaly (isolation-forest)...\n✔ Anomaly baseline fitted (300 samples)\n◉ Writing artefacts...\n✔ Artefacts written to ./.scheml\n\nArtefacts:\n  serverAnomaly.metadata.json\n  (L2-norm scored in-process, no ONNX)`,
      similarity: (h) => `$ scheml train\n\n◉ Loading Prisma schema...\n✔ Schema loaded (hash: ${h})\n◉ Training productSimilarity (embeddings)...\n✔ PCA embeddings fitted (512 products \u2192 4 dims)\n◉ Writing artefacts...\n✔ Artefacts written to ./.scheml\n\nArtefacts:\n  productSimilarity.metadata.json\n  productSimilarity.embeddings.npy`,
      temporal:   (h) => `$ scheml train\n\n◉ Loading Prisma schema...\n✔ Schema loaded (hash: ${h})\n◉ Training engagementSequence (lstm)...\n✔ LSTM sequence model trained (window=5)\n◉ Writing artefacts...\n✔ Artefacts written to ./.scheml\n\nArtefacts:\n  engagementSequence.metadata.json\n  engagementSequence.onnx`,
      generative: (h) => `$ scheml compile\n\n◉ Loading Prisma schema...\n✔ Schema loaded (hash: ${h})\n◉ Compiling retentionMessage (generative)...\n✔ Prompt contract compiled — no model training\n◉ Writing artefacts...\n✔ Artefacts written to ./.scheml\n\n# Generative traits compile to a prompt contract.\n# Your AI provider is called at runtime, not now.\n\nArtefacts:\n  retentionMessage.metadata.json`,
    };

    const TRAIT_INFER_CODE = {
      predictive: `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predict('userChurn', user);

console.log(result.prediction);  // "1" or "0"
console.log(result.label);       // "Will churn" | "Will retain"
console.log(result.latencyMs);   // ~0.4 ms — ONNX in-process`,
      anomaly: `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predict('serverAnomaly', snapshot);

console.log(result.isAnomaly);   // true | false
console.log(result.score);       // 0.8743 (isolation score)
console.log(result.latencyMs);   // <2 ms — scored in-process`,
      similarity: `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predictSimilarity(
  'productSimilarity',
  query,
  { limit: 4 }
);

// result.matches → [{ entityId, score, product }, ...]
// Cosine similarity run against .npy index in-process`,
      temporal: `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

// Pass last 5 weekly engagement readings as a sequence window
const result = await db.scheml.predict('engagementSequence', window);

console.log(result.prediction);  // "0" | "1"
console.log(result.label);       // "Stable" | "Churn risk"
console.log(result.latencyMs);   // LSTM scored in-process`,
      generative: `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

// Calls your AI provider with the compiled contract
const result = await db.scheml.predictGenerative(
  'retentionMessage',
  user
);

console.log(result.result);  // "retain" | "escalate" | "celebrate"
// Provider: openai('gpt-4o-mini') — set in scheml.config.ts`,
    };

    const INFER_FILENAMES = {
      predictive: 'api/predict.ts', anomaly: 'api/detect.ts',
      similarity: 'api/similar.ts', temporal: 'api/trend.ts', generative: 'api/retain.ts',
    };

    function switchTrait(trait) {
      traitTabs.forEach((t) => {
        const active = t.dataset.trait === trait;
        t.classList.toggle('active', active);
        t.setAttribute('aria-selected', String(active));
      });
      document.querySelectorAll('.demo-pane').forEach((p) => {
        p.classList.toggle('active', p.id === 'pane-' + trait);
      });
      const meta = TRAIT_META[trait];
      if (meta) {
        if (inferenceTag)   inferenceTag.textContent = meta.tag;
        if (inferenceTitle) inferenceTitle.textContent = meta.title;
        if (inferenceDesc)  inferenceDesc.innerHTML = meta.desc;
      }
      // Update integration code panels to match the selected trait
      const hash = (schemaHashes && schemaHashes[trait]) || '--------';
      const defineEl = document.querySelector('#panel-define code');
      const trainEl  = document.querySelector('#panel-train code');
      const inferEl  = document.querySelector('#panel-infer code');
      if (defineEl) defineEl.textContent = TRAIT_DEFINE_CODE[trait] || '';
      if (trainEl)  trainEl.textContent  = (TRAIT_COMPILE_CODE[trait] || (() => ''))(hash);
      if (inferEl)  inferEl.textContent  = TRAIT_INFER_CODE[trait]   || '';
      const inferFileEl = document.querySelector('.code-tab[data-tab="infer"] .code-tab__file');
      if (inferFileEl) inferFileEl.textContent = INFER_FILENAMES[trait] || 'api/infer.ts';
    }

    traitTabs.forEach((tab) => {
      tab.addEventListener('click', () => switchTrait(tab.dataset.trait || 'predictive'));
    });

    const activeTab = document.querySelector<HTMLElement>('.trait-tab.active');
    if (activeTab && activeTab.dataset.trait) switchTrait(activeTab.dataset.trait);

    // ── Range inputs live-value sync ─────────────────────────────────────
    const setRangeValue = (input, valueEl) => {
      if (!input || !valueEl) return;
      const render = () => { valueEl.textContent = input.value; };
      input.addEventListener('input', render);
      render();
    };

    setRangeValue(document.getElementById('predictiveDays'), document.getElementById('predictiveDaysValue'));
    setRangeValue(document.getElementById('predictiveSpend'), document.getElementById('predictiveSpendValue'));
    setRangeValue(document.getElementById('predictiveTickets'), document.getElementById('predictiveTicketsValue'));
    setRangeValue(document.getElementById('anomalyCpu'), document.getElementById('anomalyCpuValue'));
    setRangeValue(document.getElementById('anomalyMemory'), document.getElementById('anomalyMemoryValue'));
    setRangeValue(document.getElementById('anomalyError'), document.getElementById('anomalyErrorValue'));
    setRangeValue(document.getElementById('similarityPrice'), document.getElementById('similarityPriceValue'));
    setRangeValue(document.getElementById('similarityBattery'), document.getElementById('similarityBatteryValue'));
    setRangeValue(document.getElementById('similarityWeight'), document.getElementById('similarityWeightValue'));
    document.querySelectorAll<HTMLInputElement>('.temporal-input').forEach((input) => {
      const valueEl = input.parentElement?.querySelector('.temporal-value');
      setRangeValue(input, valueEl);
    });

    const activatePreset = (selector, activeButton) => {
      document.querySelectorAll(selector).forEach((button) => button.classList.toggle('is-active', button === activeButton));
    };

    document.querySelectorAll<HTMLElement>('[data-predictive-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        activatePreset('[data-predictive-preset]', button);
        const preset = predictivePresets[button.dataset.predictivePreset!];
        (document.getElementById('predictiveDays') as HTMLInputElement).value = String(preset.daysSinceActive);
        (document.getElementById('predictiveSpend') as HTMLInputElement).value = String(preset.monthlySpend);
        (document.getElementById('predictiveTickets') as HTMLInputElement).value = String(preset.supportTickets);
        document.getElementById('predictiveDaysValue')!.textContent = String(preset.daysSinceActive);
        document.getElementById('predictiveSpendValue')!.textContent = String(preset.monthlySpend);
        document.getElementById('predictiveTicketsValue')!.textContent = String(preset.supportTickets);
      });
    });

    document.querySelectorAll<HTMLElement>('[data-anomaly-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        activatePreset('[data-anomaly-preset]', button);
        const preset = anomalyPresets[button.dataset.anomalyPreset!];
        (document.getElementById('anomalyCpu') as HTMLInputElement).value = String(preset.cpuUsage);
        (document.getElementById('anomalyMemory') as HTMLInputElement).value = String(preset.memoryPressure);
        (document.getElementById('anomalyError') as HTMLInputElement).value = String(preset.errorRate);
        document.getElementById('anomalyCpuValue')!.textContent = String(preset.cpuUsage);
        document.getElementById('anomalyMemoryValue')!.textContent = String(preset.memoryPressure);
        document.getElementById('anomalyErrorValue')!.textContent = String(preset.errorRate);
      });
    });

    document.querySelectorAll<HTMLElement>('[data-similarity-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        activatePreset('[data-similarity-preset]', button);
        const preset = similarityPresets[button.dataset.similarityPreset!];
        (document.getElementById('similarityCategory') as HTMLInputElement).value = String(preset.categoryIndex);
        (document.getElementById('similarityPrice') as HTMLInputElement).value = String(preset.price);
        (document.getElementById('similarityBattery') as HTMLInputElement).value = String(preset.batteryHours);
        (document.getElementById('similarityWeight') as HTMLInputElement).value = String(preset.weightKg);
        document.getElementById('similarityPriceValue')!.textContent = String(preset.price);
        document.getElementById('similarityBatteryValue')!.textContent = String(preset.batteryHours);
        document.getElementById('similarityWeightValue')!.textContent = String(preset.weightKg);
      });
    });

    document.querySelectorAll<HTMLElement>('[data-temporal-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        activatePreset('[data-temporal-preset]', button);
        const preset = temporalPresets[button.dataset.temporalPreset!];
        document.querySelectorAll<HTMLInputElement>('.temporal-input').forEach((input, index) => {
          input.value = String(preset.scores[index]);
          const valEl = input.parentElement?.querySelector('.temporal-value');
          if (valEl) valEl.textContent = String(preset.scores[index]);
        });
      });
    });

    const renderGenerativePreview = (key) => {
      const example = generativeExamples[key];
      document.getElementById('generativeLabel')!.textContent = example.label;
      const ctx = example.context;
      const likelyAction = ctx.willChurn ? 'escalate' : (Number(ctx.monthlySpend) >= 1000 ? 'celebrate' : 'retain');
      const preview = document.getElementById('generativeCallPreview');
      if (!preview) return;
      const choices = ['retain', 'escalate', 'celebrate'];
      const ctxRows = Object.entries(ctx)
        .map(([k, v]) => `<div class="gen-ctx-row"><span class="gen-ctx-key">${k}</span><span class="gen-ctx-val">${JSON.stringify(v)}</span></div>`)
        .join('');
      preview.innerHTML = `
        <div class="gen-section">
          <p class="contract-section__label">Context resolved from User</p>
          <div class="gen-ctx">${ctxRows}</div>
        </div>
        <div class="gen-section">
          <p class="contract-section__label">Prompt</p>
          <p class="gen-prompt-text">${((document.getElementById('generativePromptInput') as HTMLTextAreaElement | null)?.value ?? generativePromptTemplate).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>
        </div>
        <div class="gen-section">
          <p class="contract-section__label">Valid outputs (schema constraint)</p>
          <div class="choice-chips">
            ${choices.map((c) => `<span class="choice-chip${c === likelyAction ? ' choice-chip--expected' : ''}">${c}</span>`).join('')}
          </div>
        </div>`;
    };

    renderGenerativePreview(initialGenerativeKey);
    document.getElementById('generativePromptInput')?.addEventListener('input', () => {
      const activeBtn = document.querySelector<HTMLElement>('[data-generative-preset].is-active');
      const key = activeBtn?.dataset?.generativePreset ?? initialGenerativeKey;
      renderGenerativePreview(key);
    });
    document.querySelectorAll<HTMLElement>('[data-generative-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        activatePreset('[data-generative-preset]', button);
        renderGenerativePreview(button.dataset.generativePreset);
        // Reset live result when switching preset
        (document.getElementById('generativeLiveResult') as HTMLElement).hidden = true;
        document.getElementById('generativePill')!.textContent = 'contract only';
        document.getElementById('generativePill')!.className = 'status-pill status-pill--info';
        document.getElementById('generativeResultPanel')!.dataset.tone = '';
      });
    });

    document.getElementById('generativeForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = (event.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const status = document.getElementById('generativeStatus')!;
      button.disabled = true;
      button.textContent = 'Calling Groq...';
      status.textContent = '';
      try {
        // Get context from the active preset
        const activePresetBtn = document.querySelector<HTMLElement>('[data-generative-preset].is-active');
        const key = activePresetBtn?.dataset?.generativePreset ?? initialGenerativeKey;
        const ctx = generativeExamples[key]?.context ?? {};
        const prompt = ((document.getElementById('generativePromptInput') as HTMLTextAreaElement | null)?.value ?? '').trim();
        const response = await fetch('/api/demo/generative', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ ...ctx, prompt }),
        });
        const data = await response.json();
        if (!data.ok) throw new Error(data.error ?? 'Generative inference failed');
        const action = data.result.action;
        const choices = ['retain', 'escalate', 'celebrate'];
        document.getElementById('generativeLiveChoices')!.innerHTML = choices
          .map((c) => `<span class="choice-chip${c === action ? ' choice-chip--live' : ''}">${c}</span>`)
          .join('');
        document.getElementById('generativeLatency')!.textContent = String(data.result.latencyMs);
        (document.getElementById('generativeLiveResult') as HTMLElement).hidden = false;
        const pill = document.getElementById('generativePill')!;
        pill.textContent = action;
        const pillMod = action === 'escalate' ? 'danger' : action === 'celebrate' ? 'healthy' : 'info';
        pill.className = `status-pill status-pill--${pillMod}`;
        document.getElementById('generativeResultPanel')!.dataset.tone = action === 'escalate' ? 'danger' : action === 'celebrate' ? 'healthy' : '';
        flashPanel(document.getElementById('generativeResultPanel'));
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Request failed';
      } finally {
        button.disabled = false;
        button.textContent = 'Run live inference';
      }
    });

    document.getElementById('predictiveForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = (event.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const status = document.getElementById('predictiveStatus')!;
      button.disabled = true;
      button.textContent = 'Running...';
      status.textContent = '';
      try {
        const payload = {
          daysSinceActive: Number((document.getElementById('predictiveDays') as HTMLInputElement).value),
          monthlySpend: Number((document.getElementById('predictiveSpend') as HTMLInputElement).value),
          supportTickets: Number((document.getElementById('predictiveTickets') as HTMLInputElement).value),
        };
        const response = await fetch('/api/demo/predict', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.ok) throw new Error(data.error || 'Prediction failed');
        document.getElementById('predictiveLabel')!.textContent = data.prediction.label;
        document.getElementById('predictiveRaw')!.textContent = String(data.prediction.prediction);
        document.getElementById('predictiveLatency')!.textContent = `${data.prediction.latencyMs} ms`;
        updateLatencyBar(document.getElementById('latencyPrisml'), document.getElementById('latencyFill'), data.prediction.latencyMs);
        const pill = document.getElementById('predictivePill')!;
        const isChurnPred = String(data.prediction.prediction) === '1';
        pill.textContent = isChurnPred ? '1 — churn' : '0 — safe';
        pill.className = `status-pill ${isChurnPred ? 'status-pill--danger' : 'status-pill--healthy'}`;
        document.getElementById('predictiveResultPanel')!.dataset.tone = isChurnPred ? 'danger' : 'healthy';
        flashPanel(document.getElementById('predictiveResultPanel'));
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Request failed';
      } finally {
        button.disabled = false;
        button.textContent = 'Run prediction';
      }
    });

    document.getElementById('anomalyForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = (event.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const status = document.getElementById('anomalyStatus')!;
      button.disabled = true;
      button.textContent = 'Scoring...';
      status.textContent = '';
      try {
        const payload = {
          cpuUsage: Number((document.getElementById('anomalyCpu') as HTMLInputElement).value),
          memoryPressure: Number((document.getElementById('anomalyMemory') as HTMLInputElement).value),
          errorRate: Number((document.getElementById('anomalyError') as HTMLInputElement).value),
        };
        const response = await fetch('/api/demo/anomaly', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.ok) throw new Error(data.error || 'Anomaly request failed');
        document.getElementById('anomalyLabel')!.textContent = data.result.label;
        document.getElementById('anomalyScore')!.textContent = data.result.score.toFixed(4);
        document.getElementById('anomalyLatency')!.textContent = `${data.result.latencyMs} ms`;
        const pill = document.getElementById('anomalyPill')!;
        pill.textContent = data.result.isAnomaly ? 'anomaly' : 'normal';
        pill.className = `status-pill ${data.result.isAnomaly ? 'status-pill--danger' : 'status-pill--healthy'}`;
        document.getElementById('anomalyResultPanel')!.dataset.tone = data.result.isAnomaly ? 'danger' : 'healthy';
        flashPanel(document.getElementById('anomalyResultPanel'));
        updateLatencyBar(document.getElementById('anomalyLatencyBar'), document.getElementById('anomalyLatencyFill'), data.result.latencyMs);
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Request failed';
      } finally {
        button.disabled = false;
        button.textContent = 'Score anomaly';
      }
    });

    document.getElementById('similarityForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = (event.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const status = document.getElementById('similarityStatus')!;
      button.disabled = true;
      button.textContent = 'Searching...';
      status.textContent = '';
      try {
        const payload = {
          categoryIndex: Number((document.getElementById('similarityCategory') as HTMLInputElement).value),
          price: Number((document.getElementById('similarityPrice') as HTMLInputElement).value),
          batteryHours: Number((document.getElementById('similarityBattery') as HTMLInputElement).value),
          weightKg: Number((document.getElementById('similarityWeight') as HTMLInputElement).value),
          limit: 4,
        };
        const response = await fetch('/api/demo/similarity', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!data.ok) throw new Error(data.error || 'Similarity request failed');
        document.getElementById('similarityLabel')!.textContent = `${data.result.matches.length} nearest neighbours`;
        document.getElementById('similarityPill')!.textContent = `${data.result.matches.length} matches`;
        document.getElementById('similarityPill')!.className = 'status-pill status-pill--info';
        document.getElementById('similarityMatches')!.innerHTML = data.result.matches.map((match, i) => {
          const score = Number(match.score);
          const barPct = Math.round(score * 100);
          return `
          <div class="result-item">
            <div class="result-item__left">
              <span class="result-item__rank">${i + 1}</span>
              <div class="result-item__info">
                <span class="result-item__name">${match.product?.name ?? match.entityId}</span>
                <span class="result-item__cat">${match.product?.categoryLabel ?? ''}</span>
              </div>
            </div>
            <div class="result-item__score-block">
              <span class="result-item__score">${score.toFixed(4)}</span>
              <div class="result-item__bar"><div class="result-item__bar-fill" style="width:${barPct}%"></div></div>
            </div>
          </div>`;
        }).join('');
        updateLatencyBar(document.getElementById('simLatencyBar'), document.getElementById('simLatencyFill'), data.result.latencyMs);
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Request failed';
      } finally {
        button.disabled = false;
        button.textContent = 'Find neighbors';
      }
    });

    document.getElementById('temporalForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = (event.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const status = document.getElementById('temporalStatus')!;
      button.disabled = true;
      button.textContent = 'Running...';
      status.textContent = '';
      try {
        const scores = [...document.querySelectorAll<HTMLInputElement>('.temporal-input')].map((input) => Number(input.value));
        const response = await fetch('/api/demo/temporal', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ scores }),
        });
        const data = await response.json();
        if (!data.ok) throw new Error(data.error || 'Temporal request failed');
        document.getElementById('temporalLabel')!.textContent = data.result.label;
        document.getElementById('temporalPrediction')!.textContent = String(data.result.prediction);
        document.getElementById('temporalLatency')!.textContent = `${data.result.latencyMs} ms`;
        const isChurnSeq = String(data.result.prediction) === '1';
        document.getElementById('temporalPill')!.textContent = isChurnSeq ? '1 — churn' : '0 — stable';
        document.getElementById('temporalPill')!.className = `status-pill ${isChurnSeq ? 'status-pill--danger' : 'status-pill--healthy'}`;
        document.getElementById('temporalResultPanel')!.dataset.tone = isChurnSeq ? 'danger' : 'healthy';
        flashPanel(document.getElementById('temporalResultPanel'));
        updateLatencyBar(document.getElementById('seqLatencyBar'), document.getElementById('seqLatencyFill'), data.result.latencyMs);
        document.getElementById('temporalDerived')!.innerHTML = Object.entries(data.result.derivedFeatures).map(([key, value]) => {
          const num = Number(value);
          // clamp 0-1 range for the track; treat values > 1 as already 0..100 scale
          const pct = num <= 1 ? Math.round(num * 100) : Math.min(100, Math.round(num));
          return `
          <div class="derived-chip">
            <span class="derived-chip__key">${key.replace(/__/g, ' ')}</span>
            <div class="derived-chip__track"><div class="derived-chip__fill" style="width:${pct}%"></div></div>
            <strong class="derived-chip__val">${num.toFixed(3)}</strong>
          </div>`;
        }).join('');
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Request failed';
      } finally {
        button.disabled = false;
        button.textContent = 'Run temporal inference';
      }
    });

    // ── SCHEMA DRIFT TOGGLE ────────────────────────────────────────────
    const driftToggle      = document.getElementById('driftToggle');
    const driftToggleLabel = document.getElementById('driftToggleLabel');
    const driftOutputCode  = document.getElementById('driftOutputCode');
    const driftResultTitle = document.getElementById('driftResultTitle');
    const driftResultPill  = document.getElementById('driftResultPill');
    const driftExplanation = document.getElementById('driftExplanation');
    const schemaDiff       = document.getElementById('schemaDiff');
    const driftOutput      = document.getElementById('driftOutput');
    let driftActive = false;

    const normalCode = `// Schema hash matches — inference proceeds normally.

const result = await db.scheml.predict('userChurn', user);
// result.prediction → "0"
// result.timestamp  → "2026-03-08T12:00:00.000Z"`;

    const errorCode = `// extendClient validates the schema hash on predict().

const result = await db.scheml.predict('userChurn', user); // schema now hashes to 7d2e9f1a

// ✖ Throws before any inference:
// SchemaDriftError: Trait 'userChurn' was trained on schema
// hash a3f8c1b2 but the current schema hash is 7d2e9f1a.
// Run \`scheml train\` to rebuild the artifact.`;

    if (driftOutputCode) driftOutputCode.textContent = normalCode;

    driftToggle && driftToggle.addEventListener('click', () => {
      driftActive = !driftActive;
      driftToggle.setAttribute('aria-pressed', String(driftActive));
      driftToggle.classList.toggle('is-active', driftActive);
      if (driftToggleLabel) driftToggleLabel.textContent = driftActive ? 'Schema has changed' : 'Schema matches artifact';
      if (schemaDiff) schemaDiff.setAttribute('aria-hidden', String(!driftActive));
      if (driftResultTitle) driftResultTitle.textContent = driftActive ? 'SchemaDriftError thrown' : 'Prediction runs normally';
      if (driftResultPill) {
        driftResultPill.textContent = driftActive ? 'Error' : 'OK';
        driftResultPill.className = 'status-pill ' + (driftActive ? 'status-pill--danger' : 'status-pill--healthy');
      }
      if (driftOutputCode) driftOutputCode.textContent = driftActive ? errorCode : normalCode;
      if (driftOutput) {
        if (driftActive) driftOutput.setAttribute('data-tone', 'danger');
        else driftOutput.removeAttribute('data-tone');
      }
      if (driftExplanation) {
        driftExplanation.innerHTML = driftActive
          ? '<p>The new field <code>subscriptionTier</code> changed the schema hash to <code>7d2e9f1a</code>. ScheML catches the mismatch before running any inference and throws <code>SchemaDriftError</code>. You are forced to retrain — no silent model incorrectness.</p>'
          : '<p>The session holds <code>a3f8c1b2</code> — the hash of the schema at compile time. When calling <code>db.scheml.predict()</code>, ScheML re-hashes the current schema and compares. A match means the feature resolvers are still valid against the live data shape.</p>';
      }
    });

    // ── CODE TABS ──────────────────────────────────────────────────────
    const tabs   = document.querySelectorAll('.code-tab');
    const panels = document.querySelectorAll('.code-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        tabs.forEach((t) => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach((p) => p.classList.remove('active'));
        tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
        document.getElementById('panel-' + (target === 'predict' ? 'infer' : target))?.classList.add('active');
      });
    });

    // ── COPY INSTALL COMMAND ───────────────────────────────────────────
    const copyBtn    = document.getElementById('copyBtn');
    const installCmd = document.getElementById('installCmd');
    copyBtn && copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText('npm install @vncsleal/scheml');
      installCmd?.classList.add('copied');
      setTimeout(() => installCmd?.classList.remove('copied'), 2000);
    });

    // ── MOBILE MENU ────────────────────────────────────────────────────
    const menuBtn = document.getElementById('menuBtn');
    const header  = document.querySelector('.header');
    menuBtn && menuBtn.addEventListener('click', () => header?.classList.toggle('header--open'));
    document.querySelectorAll('.header__nav-link').forEach((link) => {
      link.addEventListener('click', () => header?.classList.remove('header--open'));
    });

    // ── HEADER SCROLL ──────────────────────────────────────────────────
    const heroSection = document.querySelector('.hero');
    const headerEl = document.querySelector('.header');
    if (heroSection && headerEl) {
      new IntersectionObserver(
        ([entry]) => headerEl.classList.toggle('header--scrolled', !entry.isIntersecting),
        { threshold: 0 }
      ).observe(heroSection);
    }

    // ── SCROLL REVEAL ──────────────────────────────────────────────────
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('revealed'); revealObs.unobserve(e.target); }
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -32px 0px' });

    document.querySelectorAll('.drift-section .section-header, .drift-grid .panel, .drift-code-panel, .code-section .section-header').forEach((el) => {
      el.classList.add('reveal-pending');
      revealObs.observe(el);
    });

  });
  </script>

  <style is:global>
    /* Tokens (same as homepage) */
    :root {
      --gray-100: #161616; --gray-90: #262626; --gray-80: #393939;
      --gray-70: #525252;  --gray-60: #6f6f6f; --gray-50: #8d8d8d;
      --gray-30: #c6c6c6;  --gray-20: #d4d4d4; --gray-10: #f4f4f4;
      --amber-60: #d2a106; --amber-50: #f1c21b; --amber-40: #fddc69;
      --green-50: #42be65; --red-50: #fa4d56;
      --bg:               var(--gray-100);
      --bg-elevated:      var(--gray-90);
      --bg-hover:         var(--gray-80);
      --border-subtle:    #2a2a2a;
      --border-strong:    var(--gray-80);
      --text-primary:     var(--gray-10);
      --text-secondary:   var(--gray-30);
      --text-placeholder: var(--gray-60);
      --text-interactive: var(--amber-50);
      --font-sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
      --sp-1:4px; --sp-2:8px; --sp-3:12px; --sp-4:16px; --sp-5:24px;
      --sp-6:32px; --sp-7:40px; --sp-8:48px; --sp-9:64px;
      --sp-10:80px; --sp-11:96px; --sp-12:128px;
      --max-width: 1120px;
      --header-height: 48px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      font-family: var(--font-sans); font-size: 14px; line-height: 1.5;
      color: var(--text-primary); background: var(--bg);
      -webkit-font-smoothing: antialiased;
    }
    .page { min-height: 100vh; display: flex; flex-direction: column; }

    /* Logo mark */
    .logo-mark {
      font-family: var(--font-mono);
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .logo-mark--sm { font-size: 13px; color: var(--text-secondary); }
    .logo-bracket { color: var(--amber-50); font-weight: 400; }

    /* Trait tabs (hero) */
    .trait-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 28px;
    }
    .trait-tab {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 5px 14px;
      background: none;
      color: var(--text-placeholder);
      border: 1px solid var(--border-subtle);
      cursor: pointer;
      transition: color 120ms, border-color 120ms, background 120ms;
      letter-spacing: 0.04em;
    }
    .trait-tab:hover { color: var(--text-primary); border-color: var(--gray-70); }
    .trait-tab.active {
      background: rgba(61,46,0,0.7);
      color: var(--amber-40);
      border-color: rgba(241,194,27,0.2);
    }

    /* Demo panes */
    .demo-pane { display: none; }
    .demo-pane.active { display: block; }

    /* Text / textarea / select inputs */
    .text-input {
      width: 100%;
      background: var(--bg-elevated);
      border: 1px solid var(--border-strong);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 13px;
      padding: 8px 12px;
      outline: none;
      transition: border-color 120ms;
      appearance: none;
    }
    .text-input:focus { border-color: var(--amber-60); }
    textarea.text-input { resize: vertical; min-height: 88px; }
    .select-input {
      width: 100%;
      background: var(--bg-elevated);
      border: 1px solid var(--border-strong);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 13px;
      padding: 8px 12px;
      outline: none;
      appearance: none;
      cursor: pointer;
    }
    .select-input:focus { border-color: var(--amber-60); }

    /* Temporal event selectors */
    .field__seq-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 8px; display: block; }
    .seq-events { display: flex; flex-direction: column; gap: 8px; }
    .seq-step { display: flex; align-items: center; gap: 10px; }
    .seq-step-num {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-placeholder);
      min-width: 16px;
      text-align: center;
    }

    /* Probability bars (temporal / generative) */
    .prob-bars { display: flex; flex-direction: column; gap: 5px; padding: var(--sp-4) var(--sp-4) var(--sp-3); border-top: 1px solid var(--border-subtle); }
    .prob-bar { }
    .prob-bar__header { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px; }
    .prob-bar__label { color: var(--text-secondary); }
    .prob-bar__pct { font-family: var(--font-mono); color: var(--amber-40); }
    .prob-bar__track {
      height: 3px;
      background: var(--bg-elevated);
      overflow: hidden;
    }
    .prob-bar__fill {
      height: 100%;
      background: var(--gray-70);
      transition: width 350ms ease;
    }
    .prob-bar__fill--top { background: var(--amber-50); }

    /* Similarity result list */
    .result-list { display: flex; flex-direction: column; gap: 6px; padding: var(--sp-4) var(--sp-4) var(--sp-3); margin: 0; border-top: 1px solid var(--border-subtle); }
    .result-item {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      background: var(--bg-elevated);
      border: 1px solid var(--border-subtle);
      font-size: 13px;
      transition: border-color 120ms;
    }
    .result-item:hover { border-color: var(--border-strong); }
    .result-item__left { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .result-item__rank {
      flex-shrink: 0;
      width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono); font-size: 10px;
      color: var(--text-placeholder);
      background: var(--bg); border: 1px solid var(--border-subtle);
    }
    .result-item__info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .result-item__name {
      color: var(--text-primary);
      font-size: 13px; font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .result-item__cat {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-placeholder);
    }
    .result-item__score-block { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
    .result-item__score {
      font-family: var(--font-mono);
      font-size: 12px; font-weight: 600;
      color: var(--amber-40);
    }
    .result-item__bar {
      width: 60px; height: 3px;
      background: var(--border-subtle);
      overflow: hidden;
    }
    .result-item__bar-fill {
      height: 100%;
      background: var(--amber-40);
      opacity: 0.7;
    }

    /* Derived feature chips (temporal result) */
    .derived-chip {
      display: grid;
      grid-template-columns: 1fr auto auto;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      background: var(--bg-elevated); border: 1px solid var(--border-subtle);
      font-size: 12px;
    }
    .derived-chip__key {
      color: var(--text-secondary); font-family: var(--font-mono); font-size: 11px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .derived-chip__track {
      width: 56px; height: 3px;
      background: var(--border-subtle); overflow: hidden;
    }
    .derived-chip__fill {
      height: 100%; background: var(--amber-40); opacity: 0.6;
    }
    .derived-chip__val { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--amber-40); text-align: right; }

    /* Generative contract components */
    .context-chip {
      font-family: var(--font-mono); font-size: 11px;
      padding: 2px 8px;
      background: var(--bg); border: 1px solid var(--border-strong);
      color: var(--amber-40);
    }
    .contract-prompt {
      font-family: var(--font-mono); font-size: 12px; line-height: 1.6;
      padding: var(--sp-3) var(--sp-4);
      background: var(--bg); border: 1px solid var(--border-subtle);
      color: var(--text-secondary);
      white-space: pre-wrap; word-break: break-word; margin: 0;
    }
    .contract-prompt-edit {
      width: 100%; box-sizing: border-box;
      font-family: var(--font-mono); font-size: 12px; line-height: 1.6;
      padding: var(--sp-3) var(--sp-4);
      background: var(--bg); border: 1px solid var(--border-subtle);
      color: var(--text-secondary);
      resize: vertical; white-space: pre-wrap; word-break: break-word; margin: 0;
      transition: border-color 120ms ease;
    }
    .contract-prompt-edit:focus {
      outline: none; border-color: var(--amber-60);
    }
    .contract-section__label {
      font-size: 10px; font-family: var(--font-mono); letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--text-placeholder); margin-bottom: var(--sp-2);
    }
    .gen-preview { display: flex; flex-direction: column; }
    .gen-section {
      padding: var(--sp-4) var(--sp-6);
      border-bottom: 1px solid var(--border-subtle);
    }
    .gen-ctx { display: flex; flex-direction: column; gap: 6px; }
    .gen-ctx-row { display: flex; justify-content: space-between; align-items: baseline; gap: var(--sp-6); }
    .gen-ctx-key { font-family: var(--font-mono); font-size: 12px; color: var(--text-placeholder); flex-shrink: 0; }
    .gen-ctx-val { font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); text-align: right; }
    .gen-prompt-text {
      font-family: var(--font-mono); font-size: 12px; line-height: 1.6;
      color: var(--text-secondary); margin: 0; white-space: pre-wrap;
    }
    .choice-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .choice-chip {
      font-family: var(--font-mono); font-size: 12px;
      padding: 4px 12px;
      background: var(--bg-elevated); border: 1px solid var(--border-subtle);
      color: var(--text-placeholder);
    }
    .choice-chip--expected {
      background: rgba(241, 194, 27, 0.10);
      border-color: rgba(241, 194, 27, 0.3);
      color: var(--amber-40);
    }
    .choice-chip--live {
      background: rgba(66, 190, 101, 0.12);
      border-color: rgba(66, 190, 101, 0.4);
      color: var(--green-50);
      font-weight: 600;
    }
    .gen-run-bar {
      display: flex; flex-direction: column; align-items: stretch; gap: var(--sp-3);
      padding: var(--sp-4) var(--sp-6);
    }
    .gen-run-bar .btn { width: 100%; justify-content: center; }
    .gen-result {
      padding: var(--sp-4) var(--sp-6) var(--sp-5);
      border-top: 1px solid var(--border-subtle);
    }
    .gen-meta { font-size: 12px; color: var(--text-placeholder); margin-top: var(--sp-3); }

    /* Hero trait pills (kept for reference) */
    .hero-trait-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
    }
    .trait-pill {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 10px;
      background: var(--bg-elevated);
      color: var(--text-placeholder);
      border: 1px solid var(--border-subtle);
      letter-spacing: 0.02em;
    }
    .trait-pill--active {
      background: rgba(61,46,0,0.7);
      color: var(--amber-40);
      border-color: rgba(241,194,27,0.2);
    }

        /* Header */
    .header {
      position: sticky; top: 0; z-index: 100;
      height: var(--header-height); background: var(--bg);
      border-bottom: 1px solid var(--border-subtle);
      transition: background 200ms ease, border-color 200ms ease, backdrop-filter 200ms ease;
    }
    .header--scrolled {
      background: rgba(22, 22, 22, 0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom-color: #333;
    }
    .header__inner {
      max-width: var(--max-width); margin: 0 auto;
      padding: 0 var(--sp-6); height: 100%;
      display: flex; justify-content: space-between; align-items: center;
    }
    .header__logo {
      display: flex; align-items: center; gap: var(--sp-2);
      text-decoration: none;
    }
    .logo-inner.typing::after {
      content: '|';
      color: inherit;
      font-weight: 400;
      animation: cursor-blink 0.55s step-end infinite;
    }
    .header__nav { display: flex; align-items: center; }
    .header__nav a {
      display: inline-flex; align-items: center;
      padding: 0 var(--sp-4); height: var(--header-height);
      font-size: 14px; color: var(--text-secondary);
      text-decoration: none; transition: background 120ms ease, color 120ms ease;
    }
    .header__nav a:hover { background: var(--bg-elevated); color: var(--text-primary); }
    .header__menu-btn {
      display: none; align-items: center; justify-content: center;
      width: 40px; height: 40px; background: none; border: none;
      color: var(--text-secondary); cursor: pointer;
    }
    .menu-icon--close { display: none; }
    .header--open .menu-icon--open { display: none; }
    .header--open .menu-icon--close { display: block; }

    /* Hero */
    .hero { padding: var(--sp-12) 0 var(--sp-10); border-bottom: 1px solid var(--border-subtle); }
    .hero__container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6); }
    .hero__breadcrumb {
      font-family: var(--font-mono); font-size: 13px;
      color: var(--text-placeholder); margin-bottom: var(--sp-6);
    }
    .breadcrumb-sep { margin: 0 var(--sp-1); color: var(--gray-70); }
    .hero__title {
      font-size: clamp(2.5rem, 5vw, 3.75rem); font-weight: 300;
      line-height: 1.15; letter-spacing: -0.02em;
      color: var(--text-primary); margin-bottom: var(--sp-6); max-width: 720px;
    }
    .hero__lead {
      font-size: 16px; line-height: 1.65; color: var(--text-secondary);
      max-width: 620px; margin-bottom: var(--sp-7); font-weight: 400;
    }
    .hero__lead code {
      font-family: var(--font-mono); font-size: 14px;
      background: var(--bg-elevated); padding: 1px 6px; color: var(--text-primary);
    }
    .hero-meta { display: flex; flex-wrap: wrap; gap: var(--sp-3); }
    .meta-pill {
      display: flex; align-items: center; gap: var(--sp-2);
      height: 32px; padding: 0 var(--sp-3);
      background: var(--bg-elevated); border: 1px solid var(--border-subtle);
    }
    .meta-pill__label { font-family: var(--font-mono); font-size: 12px; color: var(--text-placeholder); }
    .meta-pill__value { font-family: var(--font-mono); font-size: 12px; color: var(--amber-50); }

    /* Sections */
    .section { padding: var(--sp-11) 0; border-bottom: 1px solid var(--border-subtle); }
    .section__container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6); }
    .section-header { margin-bottom: var(--sp-9); }
    .drift-section .section-header { margin-bottom: var(--sp-5); }
    .section-tag {
      font-family: var(--font-mono); font-size: 12px; font-weight: 500;
      color: var(--amber-50); text-transform: uppercase; letter-spacing: 0.05em;
      margin-bottom: var(--sp-3);
    }
    .section-title {
      font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 300;
      line-height: 1.25; letter-spacing: -0.01em;
      color: var(--text-primary); margin-bottom: var(--sp-4);
    }
    .section-desc {
      font-size: 16px; line-height: 1.6;
      color: var(--text-secondary); max-width: 540px;
    }
    .section-desc code {
      font-family: var(--font-mono); font-size: 13px;
      background: var(--bg-elevated); padding: 1px 6px; color: var(--text-primary);
    }
    .eyebrow {
      font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--text-placeholder); margin-bottom: var(--sp-1);
    }

    /* Panel */
    .panel { border: 1px solid var(--border-subtle); background: var(--bg); }
    .panel__header {
      display: flex; justify-content: space-between; align-items: flex-start;
      padding: var(--sp-5) var(--sp-6);
      border-bottom: 1px solid var(--border-subtle);
    }
    .panel__header h3 { font-size: 16px; font-weight: 600; color: var(--text-primary); margin: 0; }

    /* Pills */
    .status-pill {
      display: inline-flex; align-items: center;
      height: 24px; padding: 0 var(--sp-3);
      font-family: var(--font-mono); font-size: 12px; font-weight: 500; white-space: nowrap;
    }
    .status-pill--healthy { background: rgba(66, 190, 101, 0.12); color: var(--green-50); }
    .status-pill--danger  { background: rgba(250, 77, 86, 0.12);  color: var(--red-50); }
    .status-pill--info    { background: rgba(241, 194, 27, 0.10);  color: var(--amber-40); }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; gap: var(--sp-2);
      height: 48px; padding: 0 var(--sp-5);
      font-family: var(--font-sans); font-size: 14px; font-weight: 500;
      text-decoration: none; cursor: pointer; border: none; white-space: nowrap;
      transition: background 120ms ease, color 120ms ease;
    }
    .btn--primary {
      background: var(--amber-60); color: var(--gray-100);
      width: 100%; justify-content: center; margin-top: var(--sp-5);
    }
    .btn--primary:hover { background: #b28600; }
    .btn--primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn--secondary {
      background: var(--bg-elevated); color: var(--text-primary);
      border: 1px solid var(--border-subtle);
    }
    .btn--secondary:hover { background: var(--bg-hover); }

    /* Inference */
    .inference-section { background: var(--bg-elevated); }
    .inference-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); }
    .preset-bar {
      display: flex; flex-wrap: wrap; gap: var(--sp-2);
      padding: var(--sp-4) var(--sp-6);
      border-bottom: 1px solid var(--border-subtle);
    }
    .preset-btn {
      height: auto; padding: var(--sp-1) var(--sp-3);
      white-space: normal; text-align: left; line-height: 1.4;
      background: none; border: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);
      cursor: pointer; transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .preset-btn:hover, .preset-btn.is-active {
      background: var(--bg-elevated); color: var(--text-primary); border-color: var(--amber-60);
    }
    #generativePresets { flex-direction: column; gap: var(--sp-2); }
    #generativePresets .preset-btn { width: 100%; padding: var(--sp-2) var(--sp-3); }
    .inference-form { padding: var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-6); }
    .field { display: flex; flex-direction: column; gap: var(--sp-2); }
    .field__header { display: flex; justify-content: space-between; align-items: center; }
    .field__header label { font-size: 14px; color: var(--text-secondary); }
    .field__val {
      font-family: var(--font-mono); font-size: 14px; font-weight: 600;
      color: var(--amber-50); min-width: 36px; text-align: right;
    }
    input[type="range"] {
      -webkit-appearance: none; width: 100%; height: 2px;
      background: var(--border-strong); outline: none; cursor: pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; width: 16px; height: 16px;
      background: var(--amber-50); border-radius: 50%;
      cursor: pointer; transition: background 120ms ease;
    }
    input[type="range"]::-webkit-slider-thumb:hover { background: var(--amber-60); }
    input[type="range"]::-moz-range-thumb {
      width: 16px; height: 16px; background: var(--amber-50);
      border-radius: 50%; border: none; cursor: pointer;
    }
    .field__range-labels {
      display: flex; justify-content: space-between;
      font-family: var(--font-mono); font-size: 11px; color: var(--text-placeholder);
    }
    .result-stack { display: flex; flex-direction: column; gap: var(--sp-5); }
    .result-panel[data-tone="danger"]  { border-color: rgba(250, 77, 86, 0.3); }
    .result-panel[data-tone="healthy"] { border-color: rgba(66, 190, 101, 0.25); }
    .output-stats {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--border-subtle);
      border-top: 1px solid var(--border-subtle);
    }
    .output-stats > div {
      background: var(--bg); padding: var(--sp-4) var(--sp-5);
      display: flex; flex-direction: column; gap: var(--sp-1);
    }
    .output-stats dt { font-size: 12px; color: var(--text-placeholder); }
    .output-stats dd { font-family: var(--font-mono); font-size: 14px; color: var(--text-primary); font-weight: 500; }
    .output-stats dd.mono { font-size: 12px; }
    .result-status {
      padding: var(--sp-3) var(--sp-5);
      font-family: var(--font-mono); font-size: 12px; color: var(--red-50); min-height: 32px;
    }
    .latency-panel { background: var(--bg) !important; border-top: none; }
    .latency-bars { padding: var(--sp-5) var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-5); }
    .latency-bar { display: flex; flex-direction: column; gap: var(--sp-2); }
    .latency-bar__label { display: flex; justify-content: space-between; font-size: 13px; color: var(--text-secondary); }
    .latency-bar__ms { font-family: var(--font-mono); font-size: 13px; color: var(--text-primary); }
    .latency-bar__track { height: 4px; background: var(--border-strong); }
    .latency-bar__fill { height: 100%; background: var(--gray-70); transition: width 400ms ease; }
    .latency-bar__fill--accent { background: var(--amber-50); }
    .latency-note { padding: 0 var(--sp-6) var(--sp-5); font-size: 13px; color: var(--text-placeholder); }

    .artifact-ls {
      margin: 0 var(--sp-6) var(--sp-6);
      background: var(--gray-100); border: 1px solid var(--border-subtle);
      padding: var(--sp-4) var(--sp-5); font-family: var(--font-mono); font-size: 12px;
      overflow-x: hidden; white-space: pre-wrap; word-break: break-all;
    }
    .artifact-ls__prompt { color: var(--text-placeholder); margin-bottom: var(--sp-2); }
    .prompt { color: var(--green-50); }
    .artifact-ls__line { color: var(--text-secondary); line-height: 2; }
    .ls-perm { color: var(--text-placeholder); }
    .ls-size { color: var(--amber-50); margin: 0 var(--sp-4); }
    .ls-name { color: var(--text-primary); }
    .artifact-ls__hint { margin-top: var(--sp-2); color: var(--gray-60); }
    .drift-ls { margin: var(--sp-5) 0 0; }

    /* Drift */
    .drift-section { background: var(--bg-elevated); }
    .drift-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); margin-bottom: var(--sp-5); }
    .drift-desc {
      padding: var(--sp-5) var(--sp-6); font-size: 14px; line-height: 1.6;
      color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);
    }
    .drift-desc code {
      font-family: var(--font-mono); font-size: 12px;
      background: var(--bg-elevated); padding: 1px 6px; color: var(--text-primary);
    }
    .drift-toggle-row { padding: var(--sp-5) var(--sp-6); border-bottom: 1px solid var(--border-subtle); }
    .drift-toggle {
      display: inline-flex; align-items: center; gap: var(--sp-3);
      background: none; border: none; cursor: pointer; padding: 0;
    }
    .drift-toggle__track {
      position: relative; width: 44px; height: 24px;
      background: var(--bg-hover); border: 1px solid var(--border-strong);
      border-radius: 12px; transition: background 200ms ease, border-color 200ms ease;
    }
    .drift-toggle.is-active .drift-toggle__track {
      background: rgba(250, 77, 86, 0.2); border-color: var(--red-50);
    }
    .drift-toggle__thumb {
      position: absolute; top: 3px; left: 3px;
      width: 16px; height: 16px; border-radius: 50%;
      background: var(--gray-50); transition: transform 200ms ease, background 200ms ease;
    }
    .drift-toggle.is-active .drift-toggle__thumb {
      transform: translateX(20px); background: var(--red-50);
    }
    .drift-toggle__label {
      font-size: 14px; color: var(--text-secondary);
      transition: color 200ms ease;
    }
