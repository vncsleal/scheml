---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getDemoManifest,
  getDemoTraitSummary,
  getGenerativeDemoContract,
  runPredictiveDemo,
} from '../lib/demo/runtime';

export const prerender = false;

const manifest = getDemoManifest();
const predictiveTrait = getDemoTraitSummary('userChurn');
const anomalyTrait = getDemoTraitSummary('serverAnomaly');
const similarityTrait = getDemoTraitSummary('productSimilarity');
const temporalTrait = getDemoTraitSummary('engagementSequence');
const generativeContract = getGenerativeDemoContract();

const initialPredictiveInputs = manifest.ui.predictivePresets.atRisk;
const initialPredictiveResult = await runPredictiveDemo(initialPredictiveInputs);
const generativeEntries = Object.entries(generativeContract.examples);
const initialGenerativeKey = generativeEntries[0]?.[0] ?? 'growth';
const initialGenerative = generativeEntries[0]?.[1] ?? { label: '', context: {}, expectedShape: 'choice' };

const title = 'ScheML — Live Demo';
const description = 'Run a real ONNX model in-process. Adjust features, see the prediction and latency — five trait types, one API, each runs in-process with no serialisation, no network hop.';
---

<BaseLayout title={title} description={description}>
  <div class="page">

    <header class="header" id="top" transition:name="site-header">
      <div class="header__inner">
        <a href="/" class="header__logo" aria-label="ScheML home">
          <span class="logo-mark">
            <span class="logo-bracket">[</span><span class="logo-inner"></span><span class="logo-bracket">]</span>
          </span>
        </a>
        <nav class="header__nav" aria-label="Main navigation">
          <a href="/" class="header__nav-link">Home</a>
          <a href="#inference" class="header__nav-link">Inference</a>
          <a href="#drift" class="header__nav-link">Drift guard</a>
          <a href="#integrate" class="header__nav-link">Integration</a>
          <a href="https://github.com/vncsleal/scheml" target="_blank" rel="noopener noreferrer" class="header__nav-link">
            GitHub
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" style="margin-left: 4px; opacity: 0.5;">
              <path d="M10 1h5v5l-1.7-1.7-4.6 4.6-1.4-1.4 4.6-4.6L10 1zM3 3h4v2H3v8h8V9h2v4a2 2 0 01-2 2H3a2 2 0 01-2-2V5a2 2 0 012-2z"/>
            </svg>
          </a>
        </nav>
        <button class="header__menu-btn" aria-label="Toggle menu" id="menuBtn">
          <svg class="menu-icon menu-icon--open" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 5h14"/>
            <path d="M3 10h14"/>
            <path d="M3 15h14"/>
          </svg>
          <svg class="menu-icon menu-icon--close" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 4l12 12"/>
            <path d="M16 4L4 16"/>
          </svg>
        </button>
      </div>
    </header>

    <section class="hero">
      <div class="hero__container">
        <div class="hero__breadcrumb anim-fade-up">
          <span>scheml</span>
          <span class="breadcrumb-sep">/</span>
          <span>demo</span>
        </div>
        <h1 class="hero__title anim-fade-up anim-delay-1">
          Intelligence that<br/>ships with your code.
        </h1>
        <p class="hero__lead anim-fade-up anim-delay-2">
          Five trait types. One API. Each runs in-process — no serialisation, no network hop.
          Select a trait type to run an interactive demo.
        </p>
        <div class="trait-tabs anim-fade-up anim-delay-3" id="traitTabs" role="tablist" aria-label="Trait type demo">
          <button class="trait-tab active" role="tab" aria-selected="true" data-trait="predictive">predictive</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="anomaly">anomaly</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="similarity">similarity</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="temporal">temporal</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="generative">generative</button>
        </div>
      </div>
    </section>

    <section class="section inference-section" id="inference">
      <div class="section__container">

        <div class="section-header">
          <p class="section-tag" id="inferenceTag">Live inference · predictive</p>
          <h2 class="section-title" id="inferenceTitle">Adjust inputs. Get a real prediction.</h2>
          <p class="section-desc" id="inferenceDesc">
            Each submit hits <code>/api/demo/predict</code>, which calls <code>db.scheml.predict()</code>
            synchronously in the Node.js route. The latency shown is actual wall-clock ONNX inference time.
          </p>
        </div>

        <!-- ── PREDICTIVE PANE ── -->
        <div class="demo-pane active" id="pane-predictive">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Feature inputs</p>
                  <h3>Churn risk model</h3>
                </div>
              </div>
              <div class="preset-bar" id="predictivePresets">
                {Object.entries(manifest.ui.predictivePresets).map(([key, preset]) => (
                  <button type="button" class:list={["preset-btn", key === 'atRisk' && 'is-active']} data-predictive-preset={key}>{preset.label}</button>
                ))}
              </div>
              <form id="predictiveForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="predictiveDays">Days since last active</label>
                    <span class="field__val" id="predictiveDaysValue">{initialPredictiveInputs.daysSinceActive}</span>
                  </div>
                  <input id="predictiveDays" name="daysSinceActive" type="range" min="0" max="120" step="1" value={initialPredictiveInputs.daysSinceActive} />
                  <div class="field__range-labels"><span>0d</span><span>120d</span></div>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="predictiveSpend">Monthly spend ($)</label>
                    <span class="field__val" id="predictiveSpendValue">{initialPredictiveInputs.monthlySpend}</span>
                  </div>
                  <input id="predictiveSpend" name="monthlySpend" type="range" min="0" max="1500" step="10" value={initialPredictiveInputs.monthlySpend} />
                  <div class="field__range-labels"><span>$0</span><span>$1,500</span></div>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="predictiveTickets">Open support tickets</label>
                    <span class="field__val" id="predictiveTicketsValue">{initialPredictiveInputs.supportTickets}</span>
                  </div>
                  <input id="predictiveTickets" name="supportTickets" type="range" min="0" max="15" step="1" value={initialPredictiveInputs.supportTickets} />
                  <div class="field__range-labels"><span>0</span><span>15</span></div>
                </div>
                <button class="btn btn--primary" type="submit">Run prediction</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel result-panel" id="predictiveResultPanel"
                data-tone={String(initialPredictiveResult.prediction) === '1' ? 'danger' : 'healthy'}>
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Prediction output</p>
                    <h3 id="predictiveLabel">{initialPredictiveResult.label}</h3>
                  </div>
                  <span class:list={["status-pill", String(initialPredictiveResult.prediction) === '1' ? 'status-pill--danger' : 'status-pill--healthy']} id="predictivePill">
                    {String(initialPredictiveResult.prediction) === '1' ? '1 — positive' : '0 — negative'}
                  </span>
                </div>
                <dl class="output-stats">
                  <div><dt>Raw output</dt><dd id="predictiveRaw">{String(initialPredictiveResult.prediction)}</dd></div>
                  <div><dt>Inference latency</dt><dd id="predictiveLatency">{initialPredictiveResult.latencyMs} ms</dd></div>
                  <div><dt>Schema hash</dt><dd class="mono">{predictiveTrait.schemaHash.slice(0, 8)}</dd></div>
                  <div><dt>Artefact</dt><dd class="mono">{predictiveTrait.artifactFile}</dd></div>
                </dl>
                <p id="predictiveStatus" class="result-status" aria-live="polite"></p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Latency comparison</p>
                    <h3>Why in-process matters</h3>
                  </div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label">
                      <span>ScheML in-process</span>
                      <strong id="latencyPrisml" class="latency-bar__ms">{initialPredictiveResult.latencyMs} ms</strong>
                    </div>
                    <div class="latency-bar__track">
                      <div class="latency-bar__fill latency-bar__fill--accent" id="latencyFill"
                        style={`width: ${Math.min(100, Math.max(1, (initialPredictiveResult.latencyMs / 800) * 100))}%`}></div>
                    </div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── ANOMALY PANE ── -->
        <div class="demo-pane" id="pane-anomaly">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Feature inputs</p>
                  <h3>Server metrics model</h3>
                </div>
              </div>
              <div class="preset-bar" id="anomalyPresets">
                {Object.entries(manifest.ui.anomalyPresets).map(([key, preset]) => (
                  <button type="button" class:list={["preset-btn", key === 'healthy' && 'is-active']} data-anomaly-preset={key}>{preset.label}</button>
                ))}
              </div>
              <form id="anomalyForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="anomalyCpu">CPU usage (%)</label>
                    <span class="field__val" id="anomalyCpuValue">{manifest.ui.anomalyPresets.healthy.cpuUsage}</span>
                  </div>
                  <input id="anomalyCpu" name="cpuUsage" type="range" min="0" max="100" step="1" value={manifest.ui.anomalyPresets.healthy.cpuUsage} />
                  <div class="field__range-labels"><span>0%</span><span>100%</span></div>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="anomalyMemory">Memory pressure (%)</label>
                    <span class="field__val" id="anomalyMemoryValue">{manifest.ui.anomalyPresets.healthy.memoryPressure}</span>
                  </div>
                  <input id="anomalyMemory" name="memoryPressure" type="range" min="0" max="100" step="1" value={manifest.ui.anomalyPresets.healthy.memoryPressure} />
                  <div class="field__range-labels"><span>0%</span><span>100%</span></div>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="anomalyError">Error rate (%)</label>
                    <span class="field__val" id="anomalyErrorValue">{manifest.ui.anomalyPresets.healthy.errorRate}</span>
                  </div>
                  <input id="anomalyError" name="errorRate" type="range" min="0" max="10" step="0.1" value={manifest.ui.anomalyPresets.healthy.errorRate} />
                  <div class="field__range-labels"><span>0%</span><span>10%</span></div>
                </div>
                <button class="btn btn--primary" type="submit">Run inference</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel result-panel" id="anomalyResultPanel" data-tone="healthy">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Anomaly output</p>
                    <h3 id="anomalyLabel">—</h3>
                  </div>
                  <span class="status-pill status-pill--healthy" id="anomalyPill">—</span>
                </div>
                <dl class="output-stats">
                  <div><dt>Anomaly score</dt><dd id="anomalyScore" class="mono">—</dd></div>
                  <div><dt>Inference latency</dt><dd id="anomalyLatency">—</dd></div>
                  <div><dt>Schema hash</dt><dd class="mono">{anomalyTrait.schemaHash.slice(0, 8)}</dd></div>
                  <div><dt>Artefact</dt><dd class="mono">{anomalyTrait.artifactFile ?? 'metadata-only'}</dd></div>
                </dl>
                <p id="anomalyStatus" class="result-status" aria-live="polite">Hit "Run inference" to see the result.</p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div><p class="eyebrow">Latency comparison</p><h3>Why in-process matters</h3></div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="anomalyLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="anomalyLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── SIMILARITY PANE ── -->
        <div class="demo-pane" id="pane-similarity">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Query</p>
                  <h3>Product similarity model</h3>
                </div>
              </div>
              <div class="preset-bar" id="similarityPresets">
                {Object.entries(manifest.ui.similarityPresets).map(([key, preset]) => (
                  <button type="button" class:list={["preset-btn", key === 'laptop' && 'is-active']} data-similarity-preset={key}>{preset.label}</button>
                ))}
              </div>
              <form id="similarityForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="similarityCategory">Category</label>
                  </div>
                  <select id="similarityCategory" name="categoryIndex" class="select-input">
                    {manifest.ui.categories.map((category) => <option value={category.value}>{category.label}</option>)}
                  </select>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="similarityPrice">Price ($)</label>
                    <span class="field__val" id="similarityPriceValue">{manifest.ui.similarityPresets.laptop.price}</span>
                  </div>
                  <input id="similarityPrice" name="price" type="range" min="0" max="2500" step="25" value={manifest.ui.similarityPresets.laptop.price} />
                  <div class="field__range-labels"><span>$0</span><span>$2,500</span></div>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="similarityBattery">Battery life (h)</label>
                    <span class="field__val" id="similarityBatteryValue">{manifest.ui.similarityPresets.laptop.batteryHours}</span>
                  </div>
                  <input id="similarityBattery" name="batteryHours" type="range" min="0" max="40" step="1" value={manifest.ui.similarityPresets.laptop.batteryHours} />
                  <div class="field__range-labels"><span>0 h</span><span>40 h</span></div>
                </div>
                <div class="field">
                  <div class="field__header">
                    <label for="similarityWeight">Weight (kg)</label>
                    <span class="field__val" id="similarityWeightValue">{manifest.ui.similarityPresets.laptop.weightKg}</span>
                  </div>
                  <input id="similarityWeight" name="weightKg" type="range" min="0" max="8" step="0.1" value={manifest.ui.similarityPresets.laptop.weightKg} />
                  <div class="field__range-labels"><span>0 kg</span><span>8 kg</span></div>
                </div>
                <button class="btn btn--primary" type="submit">Find similar</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel" id="similarityResultPanel">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Nearest neighbours</p>
                    <h3 id="similarityLabel">—</h3>
                  </div>
                  <span class="status-pill status-pill--healthy" id="similarityPill">—</span>
                </div>
                <div id="similarityMatches" class="result-list"></div>
                <p id="similarityStatus" class="result-status" aria-live="polite">Hit "Find similar" to retrieve nearest neighbours.</p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div><p class="eyebrow">Latency comparison</p><h3>Why in-process matters</h3></div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="simLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="simLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── TEMPORAL PANE ── -->
        <div class="demo-pane" id="pane-temporal">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Sequence input</p>
                  <h3>User engagement model</h3>
                </div>
              </div>
              <div class="preset-bar" id="temporalPresets">
                {Object.entries(manifest.ui.temporalPresets).map(([key, preset]) => (
                  <button type="button" class:list={["preset-btn", key === 'stable' && 'is-active']} data-temporal-preset={key}>{preset.label}</button>
                ))}
              </div>
              <form id="temporalForm" class="inference-form">
                <div class="field">
                  <label class="field__seq-label">Weekly engagement scores (last {manifest.ui.temporalPresets.stable.scores.length} weeks)</label>
                  <div class="seq-events">
                    {manifest.ui.temporalPresets.stable.scores.map((score, index) => (
                      <div class="seq-step">
                        <span class="seq-step-num">W{index + 1}</span>
                        <div style="flex:1">
                          <input class="temporal-input" name={`score-${index}`} type="range" min="0" max="100" step="1" value={score} />
                          <span class="field__val temporal-value" style="float:right;font-size:12px">{score}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                <button class="btn btn--primary" type="submit">Predict engagement trend</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel result-panel" id="temporalResultPanel" data-tone="healthy">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Temporal prediction</p>
                    <h3 id="temporalLabel">—</h3>
                  </div>
                  <span class="status-pill status-pill--healthy" id="temporalPill">—</span>
                </div>
                <div class="prob-bars" id="temporalDerived"></div>
                <dl class="output-stats" style="margin-top:16px">
                  <div><dt>Prediction</dt><dd id="temporalPrediction" class="mono">—</dd></div>
                  <div><dt>Latency</dt><dd id="temporalLatency">—</dd></div>
                  <div><dt>Schema hash</dt><dd class="mono">{temporalTrait.schemaHash.slice(0, 8)}</dd></div>
                  <div><dt>Artefact</dt><dd class="mono">{temporalTrait.artifactFile}</dd></div>
                </dl>
                <p id="temporalStatus" class="result-status" aria-live="polite">Hit "Predict engagement trend" to see the result.</p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div><p class="eyebrow">Latency comparison</p><h3>Why in-process matters</h3></div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="seqLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="seqLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── GENERATIVE PANE ── -->
        <div class="demo-pane" id="pane-generative">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Compiled contract</p>
                  <h3>retentionMessage</h3>
                </div>
                <span class="status-pill status-pill--info">generative</span>
              </div>
              <div class="preset-bar" id="generativePresets">
                {generativeEntries.map(([key, example]) => (
                  <button type="button" class:list={["preset-btn", key === initialGenerativeKey && 'is-active']} data-generative-preset={key}>{example.label}</button>
                ))}
              </div>
              <div class="inference-form" style="padding: var(--sp-5) var(--sp-6);">
                <p style="font-size:13px;color:var(--text-secondary);line-height:1.65;margin:0 0 var(--sp-5)">
                  A generative trait compiles to a prompt contract — no ONNX, no embeddings.
                  At runtime, ScheML resolves the entity's context fields, builds the prompt, and calls your AI provider.
                </p>
                <p class="eyebrow" style="margin-bottom:var(--sp-2)">Context fields</p>
                <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:var(--sp-5)">
                  <span class="context-chip">planTier</span>
                  <span class="context-chip">willChurn</span>
                  <span class="context-chip">monthlySpend</span>
                </div>
                <p class="eyebrow" style="margin-bottom:var(--sp-2)">Compiled prompt</p>
                <textarea id="generativePromptInput" class="contract-prompt-edit" rows="3" maxlength="500" spellcheck="false">Return the next retention motion for this account in one concise decision.</textarea>
                <dl class="output-stats" style="margin-top:var(--sp-4)">
                  <div><dt>Output shape</dt><dd>{generativeContract.trait.outputSchemaShape}</dd></div>
                  <div><dt>Valid outputs</dt><dd>{generativeContract.trait.choiceOptions?.join(' · ')}</dd></div>
                  <div><dt>Schema hash</dt><dd class="mono">{generativeContract.trait.schemaHash.slice(0, 8)}</dd></div>
                </dl>
              </div>
            </div>

            <div class="result-stack">
              <div class="panel result-panel" id="generativeResultPanel" data-tone="">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Call preview</p>
                    <h3 id="generativeLabel">{initialGenerative.label}</h3>
                  </div>
                  <span class="status-pill status-pill--info" id="generativePill">ready</span>
                </div>
                <div class="gen-preview" id="generativeCallPreview"></div>
                <form class="gen-run-bar" id="generativeForm">
                  <button class="btn btn--primary" type="submit">Run live inference</button>
                  <p id="generativeStatus" class="result-status" aria-live="polite"></p>
                </form>
                <div class="gen-result" id="generativeLiveResult" hidden>
                  <p class="contract-section__label" style="margin-bottom:var(--sp-3)">Model returned</p>
                  <div class="choice-chips" id="generativeLiveChoices"></div>
                  <p class="gen-meta">Latency: <span id="generativeLatency" class="mono">—</span>&thinsp;ms &ensp;&middot;&ensp; <code>llama-3.1-8b-instant</code> &ensp;&middot;&ensp; Groq</p>
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>

    <!-- SCHEMA DRIFT -->
    <section class="section drift-section" id="drift">
      <div class="section__container">

        <div class="section-header">
          <p class="section-tag">Schema drift guard</p>
          <h2 class="section-title">The model knows what schema it was trained on.</h2>
          <p class="section-desc">
            Every artefact carries a SHA-256 hash of the Prisma schema at compile time. If the schema changes
            and you call <code>db.scheml.predict()</code>, ScheML throws a typed
            <code>SchemaDriftError</code> before a single inference runs. No silent incorrectness.
          </p>
          <div class="artifact-ls drift-ls">
            <p class="artifact-ls__prompt"><span class="prompt">$</span> ls -lh .scheml/</p>
            <p class="artifact-ls__line"><span class="ls-perm">-rw-r--r--</span><span class="ls-size">52K</span><span class="ls-name">userChurn.onnx</span></p>
            <p class="artifact-ls__line"><span class="ls-perm">-rw-r--r--</span><span class="ls-size"> 4K</span><span class="ls-name">userChurn.metadata.json</span></p>
            <p class="artifact-ls__hint"># both files are bound to schema hash {predictiveTrait.schemaHash.slice(0, 8)}</p>
          </div>
        </div>

        <div class="drift-grid">
          <div class="panel">
            <div class="panel__header">
              <div>
                <p class="eyebrow">Simulate schema change</p>
                <h3>Toggle a schema migration</h3>
              </div>
            </div>
            <p class="drift-desc">
              This artefact was compiled against schema hash <code>{predictiveTrait.schemaHash.slice(0, 8)}</code>.
              Simulate adding a field to the <code>User</code> model and watch the session refuse to proceed.
            </p>
            <div class="drift-toggle-row">
              <button class="drift-toggle" type="button" id="driftToggle" aria-pressed="false">
                <span class="drift-toggle__track">
                  <span class="drift-toggle__thumb"></span>
                </span>
                <span class="drift-toggle__label" id="driftToggleLabel">Schema matches artefact</span>
              </button>
            </div>
            <div class="schema-diff" id="schemaDiff" aria-hidden="true">
              <div class="schema-diff__header">
                <span>prisma/schema.prisma</span>
                <span class="schema-diff__badge">modified</span>
              </div>
              <pre class="schema-diff__code"><code> model User &#123;
   id            String   @id @default(cuid())
   email         String   @unique
   createdAt     DateTime @default(now())
   lastActiveAt  DateTime
   monthlySpend  Float
   supportTickets Int
   willChurn     Boolean?
<span class="diff-add">+  subscriptionTier String  // new field</span>
 &#125;</code></pre>
            </div>
          </div>

          <div class="panel">
            <div class="panel__header">
              <div>
                <p class="eyebrow">Session response</p>
                <h3 id="driftResultTitle">Prediction runs normally</h3>
              </div>
              <span class="status-pill status-pill--healthy" id="driftResultPill">OK</span>
            </div>
            <pre class="drift-output" id="driftOutput"><code id="driftOutputCode">// Schema hash matches — inference proceeds normally.

const result = await db.scheml.predict('userChurn', user);
// result.prediction → "0"
// result.timestamp  → "2026-04-07T12:00:00.000Z"</code></pre>
            <div class="drift-explanation" id="driftExplanation">
              <p>
                The session holds <code>{predictiveTrait.schemaHash.slice(0, 8)}</code> — the hash of the schema at compile time.
                When calling <code>db.scheml.predict()</code>, ScheML re-hashes the current schema and compares.
                A match means the feature resolvers are still valid against the live data shape.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- INTEGRATION -->
    <section class="section code-section" id="integrate">
      <div class="code-section__container">

        <div class="section-header">
          <p class="section-tag">Integration</p>
          <h2 class="section-title">Three files. Zero infrastructure.</h2>
          <p class="section-desc">
            Define a trait in TypeScript, compile once at build time, run in-process at runtime.
            The same feature resolvers run during training and inference — the behaviour cannot drift.
          </p>
        </div>

        <div class="code-tabs" id="codeTabs">
          <div class="code-tabs__bar" role="tablist">
