  qualityGates: [
    { metric: 'f1', threshold: 0.80, comparison: 'gte' },
    { metric: 'accuracy', threshold: 0.85, comparison: 'gte' },
  ],
});

export default defineConfig({
  traits: [userChurn],
});`}</code></pre>
            </div>
            <div class="code-panel" id="panel-train" role="tabpanel">
              <pre class="code-block"><code>{`$ scheml train

◉ Loading Prisma schema...
✔ Schema loaded (hash: ${predictiveTrait.schemaHash.slice(0, 8)})
◉ Loading trait definitions...
✔ Loaded 1 trait definition(s)
◉ Validating traits...
✔ Traits validated
◉ Extracting training data via Prisma...
◉ Training userChurn (gbm)...
✔ Training complete
◉ Writing artefacts...
✔ Artefacts written to ./.scheml

[OK] Training complete

Artefacts:
  userChurn.metadata.json
  userChurn.onnx`}</code></pre>
            </div>
            <div class="code-panel" id="panel-infer" role="tabpanel">
              <pre class="code-block"><code>{`import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predict('userChurn', user);

console.log(result.prediction);  // "1" or "0"
console.log(result.timestamp);   // "2026-04-07T12:00:00.000Z"
