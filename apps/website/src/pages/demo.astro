                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="genLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="genLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
