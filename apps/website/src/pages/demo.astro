            <div class="code-panel active" id="panel-define" role="tabpanel">
              <pre class="code-block"><code>{`import { defineTrait, defineConfig } from '@vncsleal/scheml';

const userChurn = defineTrait('User', {
  type: 'predictive',
  name: 'userChurn',
  target: 'willChurn',
  features: ['lastActiveAt', 'monthlySpend', 'supportTickets'],
  output: {
