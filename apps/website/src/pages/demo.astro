---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro:components';
import { getDemoModelInfo, predictDemoChurn } from '../lib/demoPrediction';

export const prerender = false;

const title = 'PrisML — Live Demo';
const description = 'Run a real ONNX model in-process. Adjust features, see the prediction and latency, then simulate a schema drift error — the thing that makes PrisML different.';

const demoInfo = await getDemoModelInfo();
const initialInputs = { daysSinceActive: 34, monthlySpend: 192, supportTickets: 7 };
const initialPrediction = await predictDemoChurn(initialInputs, 'demo-default');

const defineCode = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const userChurn = defineTrait('User', {
  type: 'predictive',
  name: 'userChurn',
  target: 'willChurn',
  features: ['lastActiveAt', 'monthlySpend', 'supportTickets'],
  output: {
    field: 'willChurn',
    taskType: 'binary_classification',
  },
  algorithm: { name: 'gbm' },
  qualityGates: [
    { metric: 'f1', threshold: 0.80, comparison: 'gte' },
    { metric: 'accuracy', threshold: 0.85, comparison: 'gte' },
  ],
});

export default defineConfig({
  traits: [userChurn],
});`;

const trainCode = `$ scheml train

◉ Loading Prisma schema...
✔ Schema loaded (hash: a3f8c1b2)
◉ Loading trait definitions...
✔ Loaded 1 trait definition(s)
◉ Validating traits...
✔ Traits validated
◉ Extracting training data via Prisma...
◉ Training userChurn (gbm)...
✔ Training complete
◉ Writing artifacts...
✔ Artifacts written to ./.scheml

[OK] Training complete

Artifacts:
  userChurn.metadata.json
  userChurn.onnx`;

const predictCode = `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predict('userChurn', user);

console.log(result.prediction);  // "1" or "0"
console.log(result.timestamp);   // "2026-03-08T12:00:00.000Z"
// Inference ran in ~0.4ms — in the same V8 process.`;

const driftCode = `// After adding a new field to schema.prisma:
// model User {
//   ...
//   subscriptionTier String   // ← new field
// }

// extendClient validates the schema hash on every predict() call.
const result = await db.scheml.predict('userChurn', user); // schema now hashes to 7d2e9f1a

// ✖ Throws:
// SchemaDriftError: Trait 'userChurn' was trained on schema
// hash a3f8c1b2 but the current schema hash is 7d2e9f1a.
// Run \`scheml train\` to rebuild the artifact.`;

const initialIsChurn = String(initialPrediction.prediction) === '1';
---

<BaseLayout title={title} description={description}>
  <div class="page">

    <!-- HEADER -->
    <header class="header" id="top" transition:name="site-header">
      <div class="header__inner">
        <a href="/" class="header__logo" aria-label="PrisML home">
          <svg width="24" height="24" viewBox="-1.5 -1.5 8 8" fill="none" aria-hidden="true" shape-rendering="crispEdges">
            <rect x="-1.5" y="-1.5" width="8" height="8" rx="1.4" fill="#161616"/>
            <rect x="0" y="0" width="5" height="1" fill="#f1c21b"/>
            <rect x="0" y="1" width="1" height="4" fill="#f1c21b"/>
            <rect x="2" y="1" width="1" height="2" fill="#f1c21b"/>
            <rect x="4" y="2" width="1" height="3" fill="#f1c21b"/>
            <rect x="1" y="2" width="1" height="1" fill="#f1c21b"/>
            <rect x="2" y="4" width="2" height="1" fill="#f1c21b"/>
          </svg>
          <span>PrisML</span>
        </a>
        <nav class="header__nav" aria-label="Main navigation">
          <a href="/" class="header__nav-link">Home</a>
          <a href="#inference" class="header__nav-link">Inference</a>
          <a href="#drift" class="header__nav-link">Drift guard</a>
          <a href="#integrate" class="header__nav-link">Integration</a>
          <a href="https://github.com/vncsleal/prisml" target="_blank" rel="noopener noreferrer" class="header__nav-link">
            GitHub
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" style="margin-left: 4px; opacity: 0.5;">
              <path d="M10 1h5v5l-1.7-1.7-4.6 4.6-1.4-1.4 4.6-4.6L10 1zM3 3h4v2H3v8h8V9h2v4a2 2 0 01-2 2H3a2 2 0 01-2-2V5a2 2 0 012-2z"/>
            </svg>
          </a>
        </nav>
        <button class="header__menu-btn" aria-label="Toggle menu" id="menuBtn">
          <svg class="menu-icon menu-icon--open" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 5h14"/>
            <path d="M3 10h14"/>
            <path d="M3 15h14"/>
          </svg>
          <svg class="menu-icon menu-icon--close" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 4l12 12"/>
            <path d="M16 4L4 16"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- HERO -->
    <section class="hero">
      <div class="hero__container">
        <div class="hero__breadcrumb">
          <span>prisml</span>
          <span class="breadcrumb-sep">/</span>
          <span>demo</span>
        </div>
        <h1 class="hero__title anim-fade-up">
          Predictions that<br/>ship with your code.
        </h1>
        <p class="hero__lead anim-fade-up anim-delay-1">
          A real ONNX model running in-process. Adjust the inputs, see the latency, then break the schema.
        </p>
        <div class="hero-meta anim-fade-up anim-delay-2">
          <div class="meta-pill">
            <span class="meta-pill__label">artifact</span>
            <code class="meta-pill__value">userChurn.onnx</code>
          </div>
          <div class="meta-pill">
            <span class="meta-pill__label">algorithm</span>
            <code class="meta-pill__value">{demoInfo.algorithm}</code>
          </div>
          <div class="meta-pill">
            <span class="meta-pill__label">task</span>
            <code class="meta-pill__value">{demoInfo.taskType}</code>
          </div>
          <div class="meta-pill">
            <span class="meta-pill__label">compiled</span>
            <code class="meta-pill__value">{new Date(demoInfo.compiledAt).toLocaleDateString()}</code>
          </div>
        </div>
      </div>
    </section>

    <!-- LIVE INFERENCE -->
    <section class="section inference-section" id="inference">
      <div class="section__container">

        <div class="section-header">
          <p class="section-tag">Live inference</p>
          <h2 class="section-title">Adjust inputs. Get a real prediction.</h2>
          <p class="section-desc">
            Each submit hits <code>/api/demo/predict</code>, which calls <code>session.predict()</code>
            synchronously in the Node.js route. The latency shown is actual wall-clock ONNX inference time.
          </p>
        </div>

        <div class="inference-grid">

          <!-- Inputs -->
          <div class="panel">
            <div class="panel__header">
              <div>
                <p class="eyebrow">Feature inputs</p>
                <h3>Churn risk model</h3>
              </div>
            </div>

            <div class="preset-bar">
              <button type="button" class="preset-btn" data-preset="healthy">Healthy user</button>
              <button type="button" class="preset-btn is-active" data-preset="at-risk">At-risk user</button>
              <button type="button" class="preset-btn" data-preset="churning">Likely churning</button>
            </div>

            <form id="inferenceForm" class="inference-form">
              <div class="field">
                <div class="field__header">
                  <label for="daysSinceActive">Days since last active</label>
                  <span class="field__val" id="daysVal">{initialInputs.daysSinceActive}</span>
                </div>
                <input id="daysSinceActive" name="daysSinceActive" type="range"
                  min="0" max="90" step="1" value={initialInputs.daysSinceActive} />
                <div class="field__range-labels"><span>0d</span><span>90d</span></div>
              </div>

              <div class="field">
                <div class="field__header">
                  <label for="monthlySpend">Monthly spend ($)</label>
                  <span class="field__val" id="spendVal">{initialInputs.monthlySpend}</span>
                </div>
                <input id="monthlySpend" name="monthlySpend" type="range"
                  min="0" max="1000" step="10" value={initialInputs.monthlySpend} />
                <div class="field__range-labels"><span>$0</span><span>$1,000</span></div>
              </div>

              <div class="field">
                <div class="field__header">
                  <label for="supportTickets">Open support tickets</label>
                  <span class="field__val" id="ticketsVal">{initialInputs.supportTickets}</span>
                </div>
                <input id="supportTickets" name="supportTickets" type="range"
                  min="0" max="15" step="1" value={initialInputs.supportTickets} />
                <div class="field__range-labels"><span>0</span><span>15</span></div>
              </div>

              <button class="btn btn--primary" type="submit">Run prediction</button>
            </form>
          </div>

          <!-- Result -->
          <div class="result-stack">
            <div class="panel result-panel" id="resultPanel"
              data-tone={initialIsChurn ? 'danger' : 'healthy'}>
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Prediction output</p>
                  <h3 id="resultLabel">{initialIsChurn ? 'Will churn' : 'Will retain'}</h3>
                </div>
                <span class:list={["status-pill", initialIsChurn ? "status-pill--danger" : "status-pill--healthy"]}
                  id="resultPill">
                  {initialIsChurn ? '1 — positive' : '0 — negative'}
                </span>
              </div>

              <dl class="output-stats">
                <div>
                  <dt>Raw output</dt>
                  <dd id="resultRaw">{initialPrediction.prediction}</dd>
                </div>
                <div>
                  <dt>Inference latency</dt>
                  <dd id="resultLatency">{initialPrediction.latencyMs} ms</dd>
                </div>
                <div>
                  <dt>Schema hash</dt>
                  <dd id="resultHash" class="mono">a3f8c1b2</dd>
                </div>
                <div>
                  <dt>Artifact</dt>
                  <dd class="mono">userChurn.onnx</dd>
                </div>
              </dl>

              <p id="resultStatus" class="result-status" aria-live="polite"></p>
            </div>

            <div class="panel latency-panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Latency comparison</p>
                  <h3>Why in-process matters</h3>
                </div>
              </div>
              <div class="latency-bars">
                <div class="latency-bar">
                  <div class="latency-bar__label">
                    <span>PrisML in-process</span>
                    <strong id="latencyPrisml" class="latency-bar__ms">{initialPrediction.latencyMs} ms</strong>
                  </div>
                  <div class="latency-bar__track">
                    <div class="latency-bar__fill latency-bar__fill--accent" id="latencyFill"
                      style={`width: ${Math.min(100, Math.max(1, (initialPrediction.latencyMs / 800) * 100))}%`}></div>
                  </div>
                </div>
                <div class="latency-bar">
                  <div class="latency-bar__label">
                    <span>HTTP microservice</span>
                    <strong class="latency-bar__ms">~120 ms</strong>
                  </div>
                  <div class="latency-bar__track">
                    <div class="latency-bar__fill" style="width: 15%"></div>
                  </div>
                </div>
                <div class="latency-bar">
                  <div class="latency-bar__label">
                    <span>External inference API</span>
                    <strong class="latency-bar__ms">~400 ms</strong>
                  </div>
                  <div class="latency-bar__track">
                    <div class="latency-bar__fill" style="width: 50%"></div>
                  </div>
                </div>
                <div class="latency-bar">
                  <div class="latency-bar__label">
                    <span>Python subprocess</span>
                    <strong class="latency-bar__ms">~800 ms</strong>
                  </div>
                  <div class="latency-bar__track">
                    <div class="latency-bar__fill" style="width: 100%"></div>
                  </div>
                </div>
              </div>
              <p class="latency-note">Scale: 0 – 800 ms (Python subprocess = 100%). PrisML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- SCHEMA DRIFT -->
    <section class="section drift-section" id="drift">
      <div class="section__container">

        <div class="section-header">
          <p class="section-tag">Schema drift guard</p>
          <h2 class="section-title">The model knows what schema it was trained on.</h2>
          <p class="section-desc">
            Every artifact carries a SHA-256 hash of the Prisma schema at compile time. If the schema changes
            and you try to initialise predictions, <code>PredictionSession</code> throws a typed
            <code>SchemaDriftError</code> before a single inference runs. No silent incorrectness.
          </p>
          <div class="artifact-ls drift-ls">
            <p class="artifact-ls__prompt"><span class="prompt">$</span> ls -lh .scheml/</p>
            <p class="artifact-ls__line"><span class="ls-perm">-rw-r--r--</span><span class="ls-size">52K</span><span class="ls-name">userChurn.onnx</span></p>
            <p class="artifact-ls__line"><span class="ls-perm">-rw-r--r--</span><span class="ls-size"> 4K</span><span class="ls-name">userChurn.metadata.json</span></p>
            <p class="artifact-ls__hint"># both files are bound to schema hash a3f8c1b2</p>
          </div>
        </div>

        <div class="drift-grid">
          <div class="panel">
            <div class="panel__header">
              <div>
                <p class="eyebrow">Simulate schema change</p>
                <h3>Toggle a schema migration</h3>
              </div>
            </div>
            <p class="drift-desc">
              This artifact was compiled against schema hash <code>a3f8c1b2</code>.
              Simulate adding a field to the <code>User</code> model and watch the session refuse to proceed.
            </p>
            <div class="drift-toggle-row">
              <button class="drift-toggle" type="button" id="driftToggle" aria-pressed="false">
                <span class="drift-toggle__track">
                  <span class="drift-toggle__thumb"></span>
                </span>
                <span class="drift-toggle__label" id="driftToggleLabel">Schema matches artifact</span>
              </button>
            </div>
            <div class="schema-diff" id="schemaDiff" aria-hidden="true">
              <div class="schema-diff__header">
                <span>prisma/schema.prisma</span>
                <span class="schema-diff__badge">modified</span>
              </div>
              <pre class="schema-diff__code"><code> model User &#123;
   id            String   @id @default(cuid())
   email         String   @unique
   createdAt     DateTime @default(now())
   lastActiveAt  DateTime
   monthlySpend  Float
   supportTickets Int
   willChurn     Boolean?
<span class="diff-add">+  subscriptionTier String  // new field</span>
 &#125;</code></pre>
            </div>
          </div>

          <div class="panel">
            <div class="panel__header">
              <div>
                <p class="eyebrow">Session response</p>
                <h3 id="driftResultTitle">Prediction runs normally</h3>
              </div>
              <span class="status-pill status-pill--healthy" id="driftResultPill">OK</span>
            </div>
            <pre class="drift-output" id="driftOutput"><code id="driftOutputCode">// Schema hash matches — inference proceeds normally.

const result = await db.scheml.predict('userChurn', user);
// result.prediction → "0"
// result.timestamp  → "2026-03-08T12:00:00.000Z"</code></pre>
            <div class="drift-explanation" id="driftExplanation">
              <p>
                The session holds <code>a3f8c1b2</code> — the hash of the schema at compile time.
                When calling <code>db.scheml.predict()</code>, ScheML re-hashes the current schema and compares.
                A match means the feature definitions are still valid against the live data shape.
              </p>
            </div>
          </div>
        </div>

        <div class="panel drift-code-panel">
          <div class="panel__header">
            <div>
              <p class="eyebrow">What the error looks like</p>
              <h3>SchemaDriftError in practice</h3>
            </div>
          </div>
          <Code code={driftCode} lang="ts" theme="github-dark" />
        </div>

      </div>
    </section>

    <!-- INTEGRATION -->
    <section class="section code-section" id="integrate">
      <div class="code-section__container">

        <div class="section-header">
          <p class="section-tag">Integration</p>
          <h2 class="section-title">Three files. Zero infrastructure.</h2>
          <p class="section-desc">
            Define a model in TypeScript, compile once at build time, predict in-process at runtime.
            The same feature resolvers run during training and inference — the behaviour cannot drift.
          </p>
        </div>

        <div class="code-tabs" id="codeTabs">
          <div class="code-tabs__bar" role="tablist">
            <button class="code-tab active" role="tab" aria-selected="true" data-tab="define">
              <span class="code-tab__num">01</span>
              <span class="code-tab__label">Define</span>
              <span class="code-tab__file">models/churn.ts</span>
            </button>
            <button class="code-tab" role="tab" aria-selected="false" data-tab="train">
              <span class="code-tab__num">02</span>
              <span class="code-tab__label">Compile</span>
              <span class="code-tab__file">terminal</span>
            </button>
            <button class="code-tab" role="tab" aria-selected="false" data-tab="predict">
              <span class="code-tab__num">03</span>
              <span class="code-tab__label">Predict</span>
              <span class="code-tab__file">api/predict.ts</span>
            </button>
          </div>
          <div class="code-tabs__panels">
            <div class="code-panel active" id="panel-define" role="tabpanel">
              <Code code={defineCode} lang="ts" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-train" role="tabpanel">
              <Code code={trainCode} lang="bash" theme="github-dark" />
            </div>
            <div class="code-panel" id="panel-predict" role="tabpanel">
              <Code code={predictCode} lang="ts" theme="github-dark" />
            </div>
          </div>
        </div>

        <div class="cta-strip">
          <div class="install-cmd" id="installCmd">
            <span class="install-cmd__prompt">$</span>
            <code class="install-cmd__text">npm install @vncsleal/scheml</code>
            <button class="install-cmd__copy" aria-label="Copy install command" id="copyBtn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"/>
                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
              </svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="check-icon" aria-hidden="true">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </button>
          </div>
          <a href="https://github.com/vncsleal/prisml" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
            View source on GitHub
          </a>
        </div>

      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer" transition:name="site-footer">
      <div class="footer__container">
        <div class="footer__left">
          <svg width="20" height="20" viewBox="-1.5 -1.5 8 8" fill="none" aria-hidden="true" shape-rendering="crispEdges">
            <rect x="-1.5" y="-1.5" width="8" height="8" rx="1.4" fill="#161616"/>
            <rect x="0" y="0" width="5" height="1" fill="#f1c21b"/>
            <rect x="0" y="1" width="1" height="4" fill="#f1c21b"/>
            <rect x="2" y="1" width="1" height="2" fill="#f1c21b"/>
            <rect x="4" y="2" width="1" height="3" fill="#f1c21b"/>
            <rect x="1" y="2" width="1" height="1" fill="#f1c21b"/>
            <rect x="2" y="4" width="2" height="1" fill="#f1c21b"/>
          </svg>
          <span class="footer__name">PrisML</span>
          <span class="footer__sep">·</span>
          <span>MIT License</span>
        </div>
        <div class="footer__right">
          <span>v0.1.2</span>
          <span class="footer__sep">·</span>
          <a href="https://github.com/vncsleal/prisml" target="_blank" rel="noopener noreferrer">github.com/vncsleal/prisml</a>
        </div>
      </div>
    </footer>

  </div>

  <script>
    document.addEventListener('astro:page-load', () => {

      // Range sliders
      const daysInput = document.getElementById('daysSinceActive') as HTMLInputElement | null;
      const spendInput = document.getElementById('monthlySpend') as HTMLInputElement | null;
      const ticketsInput = document.getElementById('supportTickets') as HTMLInputElement | null;
      const daysVal = document.getElementById('daysVal');
      const spendVal = document.getElementById('spendVal');
      const ticketsVal = document.getElementById('ticketsVal');

      daysInput?.addEventListener('input', () => { if (daysVal) daysVal.textContent = daysInput.value; });
      spendInput?.addEventListener('input', () => { if (spendVal) spendVal.textContent = spendInput.value; });
      ticketsInput?.addEventListener('input', () => { if (ticketsVal) ticketsVal.textContent = ticketsInput.value; });

      // Presets
      const presets: Record<string, { days: number; spend: number; tickets: number }> = {
        healthy:  { days: 3,  spend: 750, tickets: 0  },
        'at-risk':{ days: 34, spend: 192, tickets: 7  },
        churning: { days: 70, spend: 45,  tickets: 12 },
      };

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = (btn as HTMLElement).dataset.preset ?? '';
          const p = presets[key];
          if (!p) return;
          if (daysInput)    { daysInput.value    = String(p.days);    if (daysVal)    daysVal.textContent    = String(p.days); }
          if (spendInput)   { spendInput.value   = String(p.spend);   if (spendVal)   spendVal.textContent   = String(p.spend); }
          if (ticketsInput) { ticketsInput.value = String(p.tickets); if (ticketsVal) ticketsVal.textContent = String(p.tickets); }
          document.querySelectorAll('.preset-btn').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
      });

      // Inference form
      const form = document.getElementById('inferenceForm');
      const resultPanel = document.getElementById('resultPanel');
      const resultLabel = document.getElementById('resultLabel');
      const resultPill  = document.getElementById('resultPill');
      const resultRaw   = document.getElementById('resultRaw');
      const resultLatency = document.getElementById('resultLatency');
      const resultStatus  = document.getElementById('resultStatus');
      const latencyPrisml = document.getElementById('latencyPrisml');
      const latencyFill   = document.getElementById('latencyFill');
      const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) { submitBtn.textContent = 'Running...'; submitBtn.disabled = true; }
        if (resultStatus) resultStatus.textContent = '';

        try {
          const payload = {
            daysSinceActive: Number(daysInput?.value ?? 0),
            monthlySpend:    Number(spendInput?.value  ?? 0),
            supportTickets:  Number(ticketsInput?.value ?? 0),
          };

          const res  = await fetch('/api/demo/predict', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) throw new Error(data.error ?? 'Prediction failed');

          const isChurn  = String(data.prediction.prediction) === '1';
          const latencyMs = data.prediction.latencyMs ?? 0;

          if (resultPanel)  resultPanel.dataset.tone = isChurn ? 'danger' : 'healthy';
          if (resultLabel)  resultLabel.textContent  = isChurn ? 'Will churn' : 'Will retain';
          if (resultPill) {
            resultPill.textContent = isChurn ? '1 — positive' : '0 — negative';
            resultPill.className   = `status-pill ${isChurn ? 'status-pill--danger' : 'status-pill--healthy'}`;
          }
          if (resultRaw)     resultRaw.textContent     = String(data.prediction.prediction);
          if (resultLatency) resultLatency.textContent = `${latencyMs} ms`;
          if (latencyPrisml) latencyPrisml.textContent = `${latencyMs} ms`;
          if (latencyFill)   latencyFill.style.width   = `${Math.min(100, Math.max(1, (latencyMs / 800) * 100))}%`;

          // Flash the result panel to signal a fresh result
          if (resultPanel) {
            resultPanel.classList.remove('result-updated');
            void resultPanel.offsetWidth; // force reflow so animation retriggers
            resultPanel.classList.add('result-updated');
            resultPanel.addEventListener('animationend', () => {
              resultPanel.classList.remove('result-updated');
            }, { once: true });
          }

        } catch (err) {
          if (resultStatus) resultStatus.textContent = err instanceof Error ? err.message : 'Request failed';
        } finally {
          if (submitBtn) { submitBtn.textContent = 'Run prediction'; submitBtn.disabled = false; }
        }
      });

      // Schema drift toggle
      const driftToggle      = document.getElementById('driftToggle');
      const driftToggleLabel = document.getElementById('driftToggleLabel');
      const driftOutput      = document.getElementById('driftOutput');
      const driftOutputCode  = document.getElementById('driftOutputCode');
      const driftResultTitle = document.getElementById('driftResultTitle');
      const driftResultPill  = document.getElementById('driftResultPill');
      const driftExplanation = document.getElementById('driftExplanation');
      const schemaDiff       = document.getElementById('schemaDiff');
      let driftActive = false;

      const normalCode = `// Schema hash matches — inference proceeds normally.

const result = await db.scheml.predict('userChurn', user);
// result.prediction → "0"
// result.timestamp  → "2026-03-08T12:00:00.000Z"`;

      const errorCode = `// extendClient validates the schema hash on predict().

const result = await db.scheml.predict('userChurn', user); // schema now hashes to 7d2e9f1a

// ✖ Throws before any inference:
// SchemaDriftError: Trait 'userChurn' was trained on schema
// hash a3f8c1b2 but the current schema hash is 7d2e9f1a.
// Run \`scheml train\` to rebuild the artifact.`;

      driftToggle?.addEventListener('click', () => {
        driftActive = !driftActive;
        driftToggle.setAttribute('aria-pressed', String(driftActive));
        driftToggle.classList.toggle('is-active', driftActive);

        if (driftToggleLabel) driftToggleLabel.textContent = driftActive ? 'Schema has changed' : 'Schema matches artifact';
        if (schemaDiff) schemaDiff.setAttribute('aria-hidden', String(!driftActive));
        if (driftResultTitle) driftResultTitle.textContent = driftActive ? 'SchemaDriftError thrown' : 'Prediction runs normally';
        if (driftResultPill) {
          driftResultPill.textContent = driftActive ? 'Error' : 'OK';
          driftResultPill.className   = `status-pill ${driftActive ? 'status-pill--danger' : 'status-pill--healthy'}`;
        }
        if (driftOutputCode) driftOutputCode.textContent = driftActive ? errorCode : normalCode;
        if (driftOutput) {
          if (driftActive) driftOutput.setAttribute('data-tone', 'danger');
          else driftOutput.removeAttribute('data-tone');
        }
        if (driftExplanation) {
          driftExplanation.innerHTML = driftActive
            ? `<p>The new field <code>subscriptionTier</code> changed the schema hash to <code>7d2e9f1a</code>.
PrisML catches the mismatch in <code>session.load()</code> and throws <code>SchemaDriftError</code>
before running a single inference. You are forced to retrain — no silent model incorrectness.</p>`
            : `<p>The session holds <code>a3f8c1b2</code> — the hash of the schema at compile time.
When calling <code>session.load()</code>, PrisML re-hashes the current schema file and compares.
A match means the feature resolvers are still valid against the live data shape.</p>`;
        }
      });

      // Code tabs
      const tabs   = document.querySelectorAll('.code-tab');
      const panels = document.querySelectorAll('.code-panel');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');
          tabs.forEach((t)  => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
          panels.forEach((p) => p.classList.remove('active'));
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
          document.getElementById(`panel-${target}`)?.classList.add('active');
        });
      });

      // Copy install command
      const copyBtn    = document.getElementById('copyBtn');
      const installCmd = document.getElementById('installCmd');
      copyBtn?.addEventListener('click', async () => {
        await navigator.clipboard.writeText('npm install @vncsleal/scheml');
        installCmd?.classList.add('copied');
        setTimeout(() => installCmd?.classList.remove('copied'), 2000);
      });

      // Mobile menu
      const menuBtn = document.getElementById('menuBtn');
      const header  = document.querySelector('.header');
      menuBtn?.addEventListener('click', () => header?.classList.toggle('header--open'));
      document.querySelectorAll('.header__nav-link').forEach((link) => {
        link.addEventListener('click', () => header?.classList.remove('header--open'));
      });

      // Header scroll — observe hero exit
      const heroSection = document.querySelector('.hero');
      const headerEl = document.querySelector('.header') as HTMLElement | null;
      if (heroSection && headerEl) {
        const heroObs = new IntersectionObserver(
          ([entry]) => headerEl.classList.toggle('header--scrolled', !entry.isIntersecting),
          { threshold: 0, rootMargin: '0px 0px 0px 0px' }
        );
        heroObs.observe(heroSection);
      }

      // Scroll reveal for below-fold sections
      const revealObs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed');
            revealObs.unobserve(e.target);
          }
        });
      }, { threshold: 0.06, rootMargin: '0px 0px -32px 0px' });

      document.querySelectorAll('.drift-section .section-header, .drift-grid .panel, .drift-code-panel, .code-section .section-header').forEach((el) => {
        el.classList.add('reveal-pending');
        revealObs.observe(el);
      });
    });
  </script>

