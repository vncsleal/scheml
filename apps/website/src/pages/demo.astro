---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro:components';
import { getDemoModelInfo, predictDemoChurn } from '../lib/demoPrediction';

export const prerender = false;

const title = 'ScheML — Live Demo';
const description = 'Run a real ONNX model in-process. Adjust features, see the prediction and latency, then simulate a schema drift error — the thing that makes ScheML different.';

const demoInfo = await getDemoModelInfo();
const initialInputs = { daysSinceActive: 34, monthlySpend: 192, supportTickets: 7 };
const initialPrediction = await predictDemoChurn(initialInputs, 'demo-default');

const defineCode = `import { defineTrait, defineConfig } from '@vncsleal/scheml';

const userChurn = defineTrait('User', {
  type: 'predictive',
  name: 'userChurn',
  target: 'willChurn',
  features: ['lastActiveAt', 'monthlySpend', 'supportTickets'],
  output: {
    field: 'willChurn',
    taskType: 'binary_classification',
  },
  algorithm: { name: 'gbm' },
  qualityGates: [
    { metric: 'f1', threshold: 0.80, comparison: 'gte' },
    { metric: 'accuracy', threshold: 0.85, comparison: 'gte' },
  ],
});

export default defineConfig({
  traits: [userChurn],
});`;

const trainCode = `$ scheml train

◉ Loading Prisma schema...
✔ Schema loaded (hash: a3f8c1b2)
◉ Loading trait definitions...
✔ Loaded 1 trait definition(s)
◉ Validating traits...
✔ Traits validated
◉ Extracting training data via Prisma...
◉ Training userChurn (gbm)...
✔ Training complete
◉ Writing artefacts...
✔ Artefacts written to ./.scheml

[OK] Training complete

Artefacts:
  userChurn.metadata.json
  userChurn.onnx`;

const predictCode = `import { extendClient } from '@vncsleal/scheml';
import { PrismaClient } from '@prisma/client';
import config from './scheml.config';

const db = extendClient(new PrismaClient(), config);

const result = await db.scheml.predict('userChurn', user);

console.log(result.prediction);  // "1" or "0"
console.log(result.timestamp);   // "2026-03-08T12:00:00.000Z"
// Inference ran in ~0.4ms — in the same V8 process.`;

const driftCode = `// After adding a new field to schema.prisma:
// model User {
//   ...
//   subscriptionTier String   // ← new field
// }

// extendClient validates the schema hash on every predict() call.
const result = await db.scheml.predict('userChurn', user); // schema now hashes to 7d2e9f1a

// ✖ Throws:
// SchemaDriftError: Trait 'userChurn' was trained on schema
// hash a3f8c1b2 but the current schema hash is 7d2e9f1a.
// Run \`scheml train\` to rebuild the artifact.`;

const initialIsChurn = String(initialPrediction.prediction) === '1';
---

<BaseLayout title={title} description={description}>
  <div class="page">

    <!-- HEADER -->
    <header class="header" id="top" transition:name="site-header">
      <div class="header__inner">
        <a href="/" class="header__logo" aria-label="ScheML home">
          <span class="logo-mark">
            <span class="logo-bracket">[</span><span class="logo-inner"></span><span class="logo-bracket">]</span>
          </span>
        </a>
        <nav class="header__nav" aria-label="Main navigation">
          <a href="/" class="header__nav-link">Home</a>
          <a href="#inference" class="header__nav-link">Inference</a>
          <a href="#drift" class="header__nav-link">Drift guard</a>
          <a href="#integrate" class="header__nav-link">Integration</a>
          <a href="https://github.com/vncsleal/scheml" target="_blank" rel="noopener noreferrer" class="header__nav-link">
            GitHub
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" style="margin-left: 4px; opacity: 0.5;">
              <path d="M10 1h5v5l-1.7-1.7-4.6 4.6-1.4-1.4 4.6-4.6L10 1zM3 3h4v2H3v8h8V9h2v4a2 2 0 01-2 2H3a2 2 0 01-2-2V5a2 2 0 012-2z"/>
            </svg>
          </a>
        </nav>
        <button class="header__menu-btn" aria-label="Toggle menu" id="menuBtn">
          <svg class="menu-icon menu-icon--open" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 5h14"/>
            <path d="M3 10h14"/>
            <path d="M3 15h14"/>
          </svg>
          <svg class="menu-icon menu-icon--close" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 4l12 12"/>
            <path d="M16 4L4 16"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- HERO -->
    <section class="hero">
      <div class="hero__container">
        <div class="hero__breadcrumb anim-fade-up">
          <span>scheml</span>
          <span class="breadcrumb-sep">/</span>
          <span>demo</span>
        </div>
        <h1 class="hero__title anim-fade-up anim-delay-1">
          Intelligence that<br/>ships with your code.
        </h1>
        <p class="hero__lead anim-fade-up anim-delay-2">
          Five trait types. One API. Each runs in-process — no serialisation, no network hop.
          Select a trait type to run an interactive demo.
        </p>
        <div class="trait-tabs anim-fade-up anim-delay-3" id="traitTabs" role="tablist" aria-label="Trait type demo">
          <button class="trait-tab active" role="tab" aria-selected="true" data-trait="predictive">predictive</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="anomaly">anomaly</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="similarity">similarity</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="sequential">sequential</button>
          <button class="trait-tab" role="tab" aria-selected="false" data-trait="generative">generative</button>
        </div>
      </div>
    </section>

    <!-- LIVE INFERENCE -->
    <section class="section inference-section" id="inference">
      <div class="section__container">

        <div class="section-header">
          <p class="section-tag" id="inferenceTag">Live inference · predictive</p>
          <h2 class="section-title" id="inferenceTitle">Adjust inputs. Get a real prediction.</h2>
          <p class="section-desc" id="inferenceDesc">
            Each submit hits <code>/api/demo/predict</code>, which calls <code>db.scheml.predict()</code>
            synchronously in the Node.js route. The latency shown is actual wall-clock ONNX inference time.
          </p>
        </div>

        <!-- ── PREDICTIVE PANE ── -->
        <div class="demo-pane active" id="pane-predictive">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Feature inputs</p>
                  <h3>Churn risk model</h3>
                </div>
              </div>

              <div class="preset-bar">
                <button type="button" class="preset-btn" data-preset="healthy">Healthy user</button>
                <button type="button" class="preset-btn is-active" data-preset="at-risk">At-risk user</button>
                <button type="button" class="preset-btn" data-preset="churning">Likely churning</button>
              </div>

              <form id="inferenceForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="daysSinceActive">Days since last active</label>
                    <span class="field__val" id="daysVal">{initialInputs.daysSinceActive}</span>
                  </div>
                  <input id="daysSinceActive" name="daysSinceActive" type="range"
                    min="0" max="90" step="1" value={initialInputs.daysSinceActive} />
                  <div class="field__range-labels"><span>0d</span><span>90d</span></div>
                </div>

                <div class="field">
                  <div class="field__header">
                    <label for="monthlySpend">Monthly spend ($)</label>
                    <span class="field__val" id="spendVal">{initialInputs.monthlySpend}</span>
                  </div>
                  <input id="monthlySpend" name="monthlySpend" type="range"
                    min="0" max="1000" step="10" value={initialInputs.monthlySpend} />
                  <div class="field__range-labels"><span>$0</span><span>$1,000</span></div>
                </div>

                <div class="field">
                  <div class="field__header">
                    <label for="supportTickets">Open support tickets</label>
                    <span class="field__val" id="ticketsVal">{initialInputs.supportTickets}</span>
                  </div>
                  <input id="supportTickets" name="supportTickets" type="range"
                    min="0" max="15" step="1" value={initialInputs.supportTickets} />
                  <div class="field__range-labels"><span>0</span><span>15</span></div>
                </div>

                <button class="btn btn--primary" type="submit">Run prediction</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel result-panel" id="resultPanel"
                data-tone={initialIsChurn ? 'danger' : 'healthy'}>
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Prediction output</p>
                    <h3 id="resultLabel">{initialIsChurn ? 'Will churn' : 'Will retain'}</h3>
                  </div>
                  <span class:list={["status-pill", initialIsChurn ? "status-pill--danger" : "status-pill--healthy"]}
                    id="resultPill">
                    {initialIsChurn ? '1 — positive' : '0 — negative'}
                  </span>
                </div>

                <dl class="output-stats">
                  <div>
                    <dt>Raw output</dt>
                    <dd id="resultRaw">{initialPrediction.prediction}</dd>
                  </div>
                  <div>
                    <dt>Inference latency</dt>
                    <dd id="resultLatency">{initialPrediction.latencyMs} ms</dd>
                  </div>
                  <div>
                    <dt>Schema hash</dt>
                    <dd id="resultHash" class="mono">a3f8c1b2</dd>
                  </div>
                  <div>
                    <dt>Artefact</dt>
                    <dd class="mono">userChurn.onnx</dd>
                  </div>
                </dl>

                <p id="resultStatus" class="result-status" aria-live="polite"></p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Latency comparison</p>
                    <h3>Why in-process matters</h3>
                  </div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label">
                      <span>ScheML in-process</span>
                      <strong id="latencyPrisml" class="latency-bar__ms">{initialPrediction.latencyMs} ms</strong>
                    </div>
                    <div class="latency-bar__track">
                      <div class="latency-bar__fill latency-bar__fill--accent" id="latencyFill"
                        style={`width: ${Math.min(100, Math.max(1, (initialPrediction.latencyMs / 800) * 100))}%`}></div>
                    </div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── ANOMALY PANE ── -->
        <div class="demo-pane" id="pane-anomaly">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Feature inputs</p>
                  <h3>Server metrics model</h3>
                </div>
              </div>

              <div class="preset-bar">
                <button type="button" class="preset-btn anom-preset is-active" data-anom-preset="healthy">Healthy cluster</button>
                <button type="button" class="preset-btn anom-preset" data-anom-preset="spike">Memory spike</button>
                <button type="button" class="preset-btn anom-preset" data-anom-preset="critical">Critical state</button>
              </div>

              <form id="anomalyForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="cpuUsage">CPU usage (%)</label>
                    <span class="field__val" id="cpuVal">45</span>
                  </div>
                  <input id="cpuUsage" name="cpuUsage" type="range" min="0" max="100" step="1" value="45" />
                  <div class="field__range-labels"><span>0%</span><span>100%</span></div>
                </div>

                <div class="field">
                  <div class="field__header">
                    <label for="memPressure">Memory pressure (%)</label>
                    <span class="field__val" id="memVal">62</span>
                  </div>
                  <input id="memPressure" name="memPressure" type="range" min="0" max="100" step="1" value="62" />
                  <div class="field__range-labels"><span>0%</span><span>100%</span></div>
                </div>

                <div class="field">
                  <div class="field__header">
                    <label for="errorRate">Error rate (%)</label>
                    <span class="field__val" id="errVal">0.8</span>
                  </div>
                  <input id="errorRate" name="errorRate" type="range" min="0" max="10" step="0.1" value="0.8" />
                  <div class="field__range-labels"><span>0%</span><span>10%</span></div>
                </div>

                <button class="btn btn--primary" type="submit">Run inference</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel result-panel" id="anomalyResultPanel" data-tone="healthy">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Anomaly output</p>
                    <h3 id="anomalyResultLabel">—</h3>
                  </div>
                  <span class="status-pill status-pill--healthy" id="anomalyResultPill">—</span>
                </div>

                <dl class="output-stats">
                  <div><dt>Anomaly score</dt><dd id="anomalyScore" class="mono">—</dd></div>
                  <div><dt>Inference latency</dt><dd id="anomalyLatency">—</dd></div>
                  <div><dt>Algorithm</dt><dd class="mono">isolation_forest</dd></div>
                  <div><dt>Artefact</dt><dd class="mono">serverMetrics.onnx</dd></div>
                </dl>
                <p id="anomalyStatus" class="result-status" aria-live="polite">Hit "Run inference" to see the result.</p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div><p class="eyebrow">Latency comparison</p><h3>Why in-process matters</h3></div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="anomalyLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="anomalyLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── SIMILARITY PANE ── -->
        <div class="demo-pane" id="pane-similarity">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Query</p>
                  <h3>Product similarity model</h3>
                </div>
              </div>

              <div class="preset-bar">
                <button type="button" class="preset-btn sim-preset is-active" data-sim-preset="laptop">Lightweight laptop</button>
                <button type="button" class="preset-btn sim-preset" data-sim-preset="audio">Noise cancelling</button>
                <button type="button" class="preset-btn sim-preset" data-sim-preset="keyboard">Mechanical keyboard</button>
              </div>

              <form id="simForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="simQuery">Search query</label>
                  </div>
                  <input id="simQuery" name="simQuery" type="text"
                    placeholder="Describe what you're looking for..."
                    value="lightweight laptop for travel" class="text-input" />
                </div>

                <div class="field">
                  <div class="field__header">
                    <label for="simK">Top-K results</label>
                    <span class="field__val" id="simKVal">5</span>
                  </div>
                  <input id="simK" name="simK" type="range" min="1" max="8" step="1" value="5" />
                  <div class="field__range-labels"><span>1</span><span>8</span></div>
                </div>

                <button class="btn btn--primary" type="submit">Find similar</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel" id="simResultPanel">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Nearest neighbours</p>
                    <h3 id="simResultTitle">—</h3>
                  </div>
                  <span class="status-pill status-pill--healthy" id="simLatencyPill">—</span>
                </div>
                <div id="simResultList" class="result-list"></div>
                <p id="simStatus" class="result-status" aria-live="polite">Hit "Find similar" to retrieve nearest neighbours.</p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div><p class="eyebrow">Latency comparison</p><h3>Why in-process matters</h3></div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="simLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="simLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── SEQUENTIAL PANE ── -->
        <div class="demo-pane" id="pane-sequential">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Sequence input</p>
                  <h3>User session model</h3>
                </div>
              </div>

              <div class="preset-bar">
                <button type="button" class="preset-btn seq-preset is-active" data-seq-preset="browse">Browsing session</button>
                <button type="button" class="preset-btn seq-preset" data-seq-preset="intent">Purchase intent</button>
                <button type="button" class="preset-btn seq-preset" data-seq-preset="abandon">Abandonment risk</button>
              </div>

              <form id="seqForm" class="inference-form">
                <div class="field">
                  <label class="field__seq-label">Recent event sequence</label>
                  <div class="seq-events">
                    <div class="seq-step">
                      <span class="seq-step-num">1</span>
                      <select id="seqEv1" name="seqEv1" class="select-input">
                        <option value="view_product" selected>View Product</option>
                        <option value="search">Search</option>
                        <option value="add_cart">Add to Cart</option>
                        <option value="remove_cart">Remove from Cart</option>
                        <option value="apply_coupon">Apply Coupon</option>
                        <option value="checkout">Checkout</option>
                        <option value="review_page">Review Page</option>
                      </select>
                    </div>
                    <div class="seq-step">
                      <span class="seq-step-num">2</span>
                      <select id="seqEv2" name="seqEv2" class="select-input">
                        <option value="view_product" selected>View Product</option>
                        <option value="search">Search</option>
                        <option value="add_cart">Add to Cart</option>
                        <option value="remove_cart">Remove from Cart</option>
                        <option value="apply_coupon">Apply Coupon</option>
                        <option value="checkout">Checkout</option>
                        <option value="review_page">Review Page</option>
                      </select>
                    </div>
                    <div class="seq-step">
                      <span class="seq-step-num">3</span>
                      <select id="seqEv3" name="seqEv3" class="select-input">
                        <option value="view_product">View Product</option>
                        <option value="search">Search</option>
                        <option value="add_cart" selected>Add to Cart</option>
                        <option value="remove_cart">Remove from Cart</option>
                        <option value="apply_coupon">Apply Coupon</option>
                        <option value="checkout">Checkout</option>
                        <option value="review_page">Review Page</option>
                      </select>
                    </div>
                  </div>
                </div>

                <button class="btn btn--primary" type="submit">Predict next action</button>
              </form>
            </div>

            <div class="result-stack">
              <div class="panel" id="seqResultPanel">
                <div class="panel__header">
                  <div>
                    <p class="eyebrow">Predicted next action</p>
                    <h3 id="seqResultTitle">—</h3>
                  </div>
                  <span class="status-pill status-pill--healthy" id="seqLatencyPill">—</span>
                </div>
                <div class="prob-bars" id="seqProbBars"></div>
                <dl class="output-stats" style="margin-top: 16px;">
                  <div><dt>Algorithm</dt><dd class="mono">lstm</dd></div>
                  <div><dt>Artefact</dt><dd class="mono">userSession.onnx</dd></div>
                </dl>
                <p id="seqStatus" class="result-status" aria-live="polite">Hit "Predict next action" to see the result.</p>
              </div>

              <div class="panel latency-panel">
                <div class="panel__header">
                  <div><p class="eyebrow">Latency comparison</p><h3>Why in-process matters</h3></div>
                </div>
                <div class="latency-bars">
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>ScheML in-process</span><strong id="seqLatencyBar" class="latency-bar__ms">—</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill latency-bar__fill--accent" id="seqLatencyFill" style="width: 0%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>HTTP microservice</span><strong class="latency-bar__ms">~120 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 15%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>External inference API</span><strong class="latency-bar__ms">~400 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 50%"></div></div>
                  </div>
                  <div class="latency-bar">
                    <div class="latency-bar__label"><span>Python subprocess</span><strong class="latency-bar__ms">~800 ms</strong></div>
                    <div class="latency-bar__track"><div class="latency-bar__fill" style="width: 100%"></div></div>
                  </div>
                </div>
                <p class="latency-note">Scale: 0 – 800 ms. ScheML runs ONNX Runtime in-process — no serialisation, no network hop.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- ── GENERATIVE PANE ── -->
        <div class="demo-pane" id="pane-generative">
          <div class="inference-grid">

            <div class="panel">
              <div class="panel__header">
                <div>
                  <p class="eyebrow">Input text</p>
