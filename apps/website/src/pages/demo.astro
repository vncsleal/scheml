  </div>

  <script>
    document.addEventListener('astro:page-load', () => {

      // ── Logo typewriter ──────────────────────────────────────────────
      const logoInner = document.querySelector('.header__logo .logo-inner') as HTMLElement | null;
      if (logoInner) {
        const WORD = 'scheml';
        const SPEED = 72;
        const DELAY = 300;
        logoInner.textContent = '';
        logoInner.classList.remove('typing');
        let i = 0;
        setTimeout(() => {
          logoInner.classList.add('typing');
          const iv = setInterval(() => {
            logoInner.textContent = WORD.slice(0, ++i);
            if (i >= WORD.length) { clearInterval(iv); logoInner.classList.remove('typing'); }
          }, SPEED);
        }, DELAY);
      }

      // ── Trait section header metadata ─────────────────────────────────
      const TRAIT_META: Record<string, { tag: string; title: string; desc: string }> = {
        predictive: {
          tag: 'Live inference · predictive',
          title: 'Adjust inputs. Get a real prediction.',
          desc: `Each submit hits <code>/api/demo/predict</code>, which calls <code>db.scheml.predict()</code> synchronously in the Node.js route. The latency shown is actual wall-clock ONNX inference time.`,
        },
        anomaly: {
          tag: 'Live inference · anomaly',
          title: 'Detect anomalies in server metrics.',
          desc: `Adjust the metric sliders to cross anomaly thresholds. The isolation forest model scores each sample in-process — no HTTP round-trip, no serialisation overhead.`,
        },
        similarity: {
          tag: 'Live inference · similarity',
          title: 'Retrieve the nearest neighbours.',
          desc: `Type a search query and retrieve the most similar items from the embedded product space. Cosine similarity runs in-process over the compiled embedding index.`,
        },
        sequential: {
          tag: 'Live inference · sequential',
          title: 'Predict the next event in the sequence.',
          desc: `Select the recent event chain and the LSTM predicts the next user action. Runs in-process against the compiled userSession artefact — no subprocess, no network.`,
        },
        generative: {
          tag: 'Live inference · generative (stand-in)',
          title: 'Text classification as a generative proxy.',
          desc: `The real <code>generative</code> trait calls an AI SDK provider (e.g. <code>openai:gpt-4o-mini</code>) in-process and returns structured text. This demo substitutes a multinomial Naive Bayes classifier — same in-process execution model, no API key required.`,
        },
      };

      // ── Trait tab switching ──────────────────────────────────────────
      const traitTabs    = document.querySelectorAll('.trait-tab');
      const inferenceTag   = document.getElementById('inferenceTag');
      const inferenceTitle = document.getElementById('inferenceTitle');
      const inferenceDesc  = document.getElementById('inferenceDesc');

      function switchTrait(trait: string) {
        traitTabs.forEach((t) => {
          const el = t as HTMLElement;
          const active = el.dataset.trait === trait;
          el.classList.toggle('active', active);
          el.setAttribute('aria-selected', String(active));
        });
        document.querySelectorAll('.demo-pane').forEach((p) => {
          p.classList.toggle('active', p.id === `pane-${trait}`);
        });
        const meta = TRAIT_META[trait];
        if (meta) {
          if (inferenceTag)   inferenceTag.textContent = meta.tag;
          if (inferenceTitle) inferenceTitle.textContent = meta.title;
          if (inferenceDesc)  inferenceDesc.innerHTML = meta.desc;
        }
      }

      traitTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const trait = (tab as HTMLElement).dataset.trait ?? 'predictive';
          switchTrait(trait);
        });
      });

      // initialise the active pane
      const activeTraitTab = document.querySelector('.trait-tab.active') as HTMLElement | null;
      if (activeTraitTab?.dataset.trait) switchTrait(activeTraitTab.dataset.trait);

      // ── Helpers ──────────────────────────────────────────────────────
      function flashPanel(el: HTMLElement | null) {
        if (!el) return;
        el.classList.remove('result-updated');
        void el.offsetWidth;
        el.classList.add('result-updated');
        el.addEventListener('animationend', () => el.classList.remove('result-updated'), { once: true });
      }

      function updateLatencyBar(barEl: HTMLElement | null, fillEl: HTMLElement | null, ms: number) {
        if (barEl) barEl.textContent = `${ms} ms`;
        if (fillEl) fillEl.style.width = `${Math.min(100, Math.max(1, (ms / 800) * 100))}%`;
      }

      function simDelay(minMs: number, maxMs: number): Promise<number> {
        const ms = minMs + Math.random() * (maxMs - minMs);
        return new Promise<number>((resolve) => setTimeout(() => resolve(parseFloat(ms.toFixed(2))), 60));
      }

      // ── PREDICTIVE ───────────────────────────────────────────────────
      const daysInput   = document.getElementById('daysSinceActive') as HTMLInputElement | null;
      const spendInput  = document.getElementById('monthlySpend') as HTMLInputElement | null;
      const ticketsInput = document.getElementById('supportTickets') as HTMLInputElement | null;
      const daysVal     = document.getElementById('daysVal');
      const spendVal    = document.getElementById('spendVal');
      const ticketsVal  = document.getElementById('ticketsVal');

      daysInput?.addEventListener('input', () => { if (daysVal) daysVal.textContent = daysInput!.value; });
      spendInput?.addEventListener('input', () => { if (spendVal) spendVal.textContent = spendInput!.value; });
      ticketsInput?.addEventListener('input', () => { if (ticketsVal) ticketsVal.textContent = ticketsInput!.value; });

      const presets: Record<string, { days: number; spend: number; tickets: number }> = {
        'healthy':  { days: 3,  spend: 750, tickets: 0  },
        'at-risk':  { days: 34, spend: 192, tickets: 7  },
        'churning': { days: 70, spend: 45,  tickets: 12 },
      };
      document.querySelectorAll('.preset-btn[data-preset]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = (btn as HTMLElement).dataset.preset ?? '';
          const p = presets[key]; if (!p) return;
          if (daysInput)    { daysInput.value    = String(p.days);    if (daysVal)    daysVal.textContent    = String(p.days); }
          if (spendInput)   { spendInput.value   = String(p.spend);   if (spendVal)   spendVal.textContent   = String(p.spend); }
          if (ticketsInput) { ticketsInput.value = String(p.tickets); if (ticketsVal) ticketsVal.textContent = String(p.tickets); }
          document.querySelectorAll('.preset-btn[data-preset]').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
      });

      const inferenceForm  = document.getElementById('inferenceForm');
      const resultPanel    = document.getElementById('resultPanel');
      const resultLabel    = document.getElementById('resultLabel');
      const resultPill     = document.getElementById('resultPill');
      const resultRaw      = document.getElementById('resultRaw');
      const resultLatency  = document.getElementById('resultLatency');
      const resultStatus   = document.getElementById('resultStatus');
      const latencyPrisml  = document.getElementById('latencyPrisml');
      const latencyFill    = document.getElementById('latencyFill');

      inferenceForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = inferenceForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (btn) { btn.textContent = 'Running...'; btn.disabled = true; }
        if (resultStatus) resultStatus.textContent = '';
        try {
          const payload = {
            daysSinceActive: Number(daysInput?.value ?? 0),
            monthlySpend:    Number(spendInput?.value  ?? 0),
            supportTickets:  Number(ticketsInput?.value ?? 0),
          };
          const res  = await fetch('/api/demo/predict', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) });
          const data = await res.json();
          if (!data.ok) throw new Error(data.error ?? 'Prediction failed');
          const isChurn   = String(data.prediction.prediction) === '1';
          const latencyMs = data.prediction.latencyMs ?? 0;
          if (resultPanel)  resultPanel.dataset.tone = isChurn ? 'danger' : 'healthy';
          if (resultLabel)  resultLabel.textContent  = isChurn ? 'Will churn' : 'Will retain';
          if (resultPill) { resultPill.textContent = isChurn ? '1 — positive' : '0 — negative'; resultPill.className = `status-pill ${isChurn ? 'status-pill--danger' : 'status-pill--healthy'}`; }
          if (resultRaw)     resultRaw.textContent  = String(data.prediction.prediction);
          if (resultLatency) resultLatency.textContent = `${latencyMs} ms`;
          updateLatencyBar(latencyPrisml, latencyFill, latencyMs);
          flashPanel(resultPanel);
        } catch (err) {
          if (resultStatus) resultStatus.textContent = err instanceof Error ? err.message : 'Request failed';
        } finally {
          if (btn) { btn.textContent = 'Run prediction'; btn.disabled = false; }
        }
      });

      // ── ANOMALY ───────────────────────────────────────────────────────
      const cpuInput  = document.getElementById('cpuUsage') as HTMLInputElement | null;
      const memInput  = document.getElementById('memPressure') as HTMLInputElement | null;
      const errInput  = document.getElementById('errorRate') as HTMLInputElement | null;
      const cpuVal    = document.getElementById('cpuVal');
      const memVal    = document.getElementById('memVal');
      const errVal    = document.getElementById('errVal');

      cpuInput?.addEventListener('input', () => { if (cpuVal) cpuVal.textContent = cpuInput!.value; });
      memInput?.addEventListener('input', () => { if (memVal) memVal.textContent = memInput!.value; });
      errInput?.addEventListener('input', () => { if (errVal) errVal.textContent = errInput!.value; });

      const anomPresets: Record<string, { cpu: number; mem: number; err: number }> = {
        healthy:  { cpu: 45,  mem: 62,  err: 0.8 },
        spike:    { cpu: 55,  mem: 94,  err: 1.2 },
        critical: { cpu: 92,  mem: 97,  err: 7.4 },
      };
      document.querySelectorAll('.anom-preset').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = (btn as HTMLElement).dataset.anomPreset ?? '';
          const p = anomPresets[key]; if (!p) return;
          if (cpuInput) { cpuInput.value = String(p.cpu); if (cpuVal) cpuVal.textContent = String(p.cpu); }
          if (memInput) { memInput.value = String(p.mem); if (memVal) memVal.textContent = String(p.mem); }
          if (errInput) { errInput.value = String(p.err); if (errVal) errVal.textContent = String(p.err); }
          document.querySelectorAll('.anom-preset').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
      });

      function simAnomaly(cpu: number, mem: number, err: number) {
        const n = (v: number, lo: number, hi: number) => Math.max(0, Math.min(1, (v - lo) / (hi - lo)));
        const score = Math.min(1, n(cpu, 55, 100) * 0.40 + n(mem, 70, 100) * 0.35 + n(err, 1, 10) * 0.25);
        return parseFloat((score + (Math.random() - 0.5) * 0.02).toFixed(3));
      }

      const anomalyForm = document.getElementById('anomalyForm');
      anomalyForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = anomalyForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (btn) { btn.textContent = 'Running...'; btn.disabled = true; }
        const latencyMs = await simDelay(0.18, 0.52);
        const cpu = Number(cpuInput?.value ?? 45);
        const mem = Number(memInput?.value ?? 62);
        const err = Number(errInput?.value ?? 0.8);
        const score = simAnomaly(cpu, mem, err);
        const isAnom = score > 0.45;
        const panel  = document.getElementById('anomalyResultPanel');
        if (panel) panel.dataset.tone = isAnom ? 'danger' : 'healthy';
        const lbl = document.getElementById('anomalyResultLabel');
        if (lbl) lbl.textContent = isAnom ? 'Anomaly detected' : 'Normal';
        const pill = document.getElementById('anomalyResultPill');
        if (pill) { pill.textContent = isAnom ? '1 — anomaly' : '0 — normal'; pill.className = `status-pill ${isAnom ? 'status-pill--danger' : 'status-pill--healthy'}`; }
        const sc = document.getElementById('anomalyScore');
        if (sc) sc.textContent = String(score);
        const lat = document.getElementById('anomalyLatency');
        if (lat) lat.textContent = `${latencyMs} ms`;
        updateLatencyBar(document.getElementById('anomalyLatencyBar'), document.getElementById('anomalyLatencyFill'), latencyMs);
        const st = document.getElementById('anomalyStatus'); if (st) st.textContent = '';
        flashPanel(panel);
        if (btn) { btn.textContent = 'Run inference'; btn.disabled = false; }
      });

      // ── SIMILARITY ────────────────────────────────────────────────────
      const SIM_PRODUCTS = [
        { name: 'ThinkPad X1 Carbon',    cat: 'Laptop',    tags: ['laptop','lightweight','portable','travel','ultrabook','thin','business'] },
        { name: 'Dell XPS 13',           cat: 'Laptop',    tags: ['laptop','lightweight','portable','display','compact','thin','design'] },
        { name: 'MacBook Air M3',        cat: 'Laptop',    tags: ['laptop','lightweight','apple','battery','portable','silent','m-chip'] },
        { name: 'Sony WH-1000XM5',       cat: 'Audio',     tags: ['headphones','noise','cancelling','wireless','audio','sony','premium'] },
        { name: 'Bose QuietComfort 45',  cat: 'Audio',     tags: ['headphones','noise','cancelling','quiet','comfort','audio','bose'] },
        { name: 'AirPods Pro 2',         cat: 'Audio',     tags: ['earbuds','noise','cancelling','apple','wireless','portable','small'] },
        { name: 'Keychron Q3',           cat: 'Keyboard',  tags: ['keyboard','mechanical','typing','aluminum','tenkeyless','qmk'] },
        { name: 'HHKB Professional',     cat: 'Keyboard',  tags: ['keyboard','mechanical','typing','programming','compact','premium'] },
        { name: 'Logitech MX Keys',      cat: 'Keyboard',  tags: ['keyboard','wireless','typing','productivity','rechargeable','quiet'] },
        { name: 'iPad Pro M4',           cat: 'Tablet',    tags: ['tablet','portable','apple','display','drawing','lightweight','m-chip'] },
        { name: 'Samsung Galaxy Tab S9', cat: 'Tablet',    tags: ['tablet','portable','android','display','drawing','lightweight'] },
        { name: 'Dell U2722D',           cat: 'Monitor',   tags: ['monitor','display','productivity','4k','usb-c','wide'] },
      ];

      const simPresetTexts: Record<string, string> = {
        laptop:   'lightweight laptop for travel',
        audio:    'noise cancelling headphones wireless',
        keyboard: 'mechanical keyboard for programming',
      };

      const simQueryInput = document.getElementById('simQuery') as HTMLInputElement | null;
      const simKInput     = document.getElementById('simK') as HTMLInputElement | null;
      const simKVal       = document.getElementById('simKVal');

      simKInput?.addEventListener('input', () => { if (simKVal) simKVal.textContent = simKInput!.value; });

      document.querySelectorAll('.sim-preset').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = (btn as HTMLElement).dataset.simPreset ?? '';
          if (simQueryInput && simPresetTexts[key]) simQueryInput.value = simPresetTexts[key];
          document.querySelectorAll('.sim-preset').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
      });

      function simSimilarity(query: string, k: number) {
        const qWords = query.toLowerCase().split(/\W+/).filter((w) => w.length > 2);
        return SIM_PRODUCTS.map((p) => {
          const tagHits  = p.tags.filter((t) => qWords.some((w) => t.includes(w) || w.includes(t))).length;
          const nameHits = qWords.filter((w) => p.name.toLowerCase().includes(w)).length;
          const raw = tagHits * 0.14 + nameHits * 0.22 + Math.random() * 0.06;
          return { ...p, score: parseFloat(Math.min(0.99, Math.max(0.08, raw)).toFixed(3)) };
        }).sort((a, b) => b.score - a.score).slice(0, k);
      }

      const simForm = document.getElementById('simForm');
      simForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = simForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (btn) { btn.textContent = 'Searching...'; btn.disabled = true; }
        const latencyMs = await simDelay(0.30, 0.72);
        const query = simQueryInput?.value.trim() || 'laptop';
        const k     = Number(simKInput?.value ?? 5);
        const results = simSimilarity(query, k);
        const list = document.getElementById('simResultList');
        if (list) {
          list.innerHTML = results.map((r, i) => `
            <div class="result-item">
              <div class="result-item__left">
                <span class="result-item__name">${r.name}</span>
                <span class="result-item__cat">${r.cat}</span>
              </div>
              <span class="result-item__score">${r.score.toFixed(3)}</span>
            </div>
          `).join('');
        }
        const title = document.getElementById('simResultTitle');
        if (title) title.textContent = `Top ${results.length} matches`;
        const latPill = document.getElementById('simLatencyPill');
        if (latPill) latPill.textContent = `${latencyMs} ms`;
        updateLatencyBar(document.getElementById('simLatencyBar'), document.getElementById('simLatencyFill'), latencyMs);
        const st = document.getElementById('simStatus'); if (st) st.textContent = '';
        flashPanel(document.getElementById('simResultPanel'));
        if (btn) { btn.textContent = 'Find similar'; btn.disabled = false; }
      });

      // ── SEQUENTIAL ────────────────────────────────────────────────────
      const EVENT_LABELS: Record<string, string> = {
        view_product:  'View Product',
        search:        'Search',
        add_cart:      'Add to Cart',
        remove_cart:   'Remove from Cart',
        apply_coupon:  'Apply Coupon',
        checkout:      'Checkout',
        review_page:   'Review Page',
      };

      const SEQ_TABLE: Record<string, Record<string, number>> = {
        'view_product,view_product,add_cart':    { checkout: 0.42, apply_coupon: 0.28, view_product: 0.18, remove_cart: 0.12 },
        'view_product,view_product,view_product':{ view_product: 0.35, add_cart: 0.30, search: 0.25, checkout: 0.10 },
        'search,view_product,add_cart':          { checkout: 0.45, apply_coupon: 0.28, view_product: 0.17, search: 0.10 },
        'add_cart,remove_cart,view_product':     { search: 0.38, view_product: 0.32, add_cart: 0.20, checkout: 0.10 },
        'view_product,add_cart,checkout':        { review_page: 0.58, view_product: 0.24, checkout: 0.18 },
        'search,search,view_product':            { add_cart: 0.40, view_product: 0.30, search: 0.20, checkout: 0.10 },
        'checkout,review_page,view_product':     { view_product: 0.42, add_cart: 0.30, search: 0.18, checkout: 0.10 },
      };

      const seqPresets: Record<string, { ev1: string; ev2: string; ev3: string }> = {
        browse:  { ev1: 'view_product', ev2: 'view_product', ev3: 'view_product' },
        intent:  { ev1: 'search',       ev2: 'view_product', ev3: 'add_cart' },
        abandon: { ev1: 'add_cart',     ev2: 'remove_cart',  ev3: 'view_product' },
      };

      const seqEv1 = document.getElementById('seqEv1') as HTMLSelectElement | null;
      const seqEv2 = document.getElementById('seqEv2') as HTMLSelectElement | null;
      const seqEv3 = document.getElementById('seqEv3') as HTMLSelectElement | null;

      document.querySelectorAll('.seq-preset').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = (btn as HTMLElement).dataset.seqPreset ?? '';
          const p = seqPresets[key]; if (!p) return;
          if (seqEv1) seqEv1.value = p.ev1;
          if (seqEv2) seqEv2.value = p.ev2;
          if (seqEv3) seqEv3.value = p.ev3;
          document.querySelectorAll('.seq-preset').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
      });

      function simSeq(ev1: string, ev2: string, ev3: string) {
        const key = `${ev1},${ev2},${ev3}`;
        const table = SEQ_TABLE[key] ?? { view_product: 0.30, search: 0.25, add_cart: 0.25, checkout: 0.20 };
        return Object.entries(table).sort((a, b) => b[1] - a[1]).slice(0, 5);
      }

      const seqForm = document.getElementById('seqForm');
      seqForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = seqForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (btn) { btn.textContent = 'Predicting...'; btn.disabled = true; }
        const latencyMs = await simDelay(0.28, 0.58);
        const ev1 = seqEv1?.value ?? 'view_product';
        const ev2 = seqEv2?.value ?? 'view_product';
        const ev3 = seqEv3?.value ?? 'add_cart';
        const results = simSeq(ev1, ev2, ev3);
        const barsEl = document.getElementById('seqProbBars');
        if (barsEl) {
          barsEl.innerHTML = results.map(([event, prob], i) => `
            <div class="prob-bar">
              <div class="prob-bar__header">
                <span class="prob-bar__label">${EVENT_LABELS[event] ?? event}</span>
                <span class="prob-bar__pct">${(prob * 100).toFixed(0)}%</span>
              </div>
              <div class="prob-bar__track">
                <div class="prob-bar__fill${i === 0 ? ' prob-bar__fill--top' : ''}" style="width: ${(prob * 100).toFixed(1)}%"></div>
              </div>
            </div>
          `).join('');
        }
        const title = document.getElementById('seqResultTitle');
        if (title) title.textContent = EVENT_LABELS[results[0]?.[0] ?? ''] ?? '—';
        const latPill = document.getElementById('seqLatencyPill');
        if (latPill) latPill.textContent = `${latencyMs} ms`;
        updateLatencyBar(document.getElementById('seqLatencyBar'), document.getElementById('seqLatencyFill'), latencyMs);
        const st = document.getElementById('seqStatus'); if (st) st.textContent = '';
        flashPanel(document.getElementById('seqResultPanel'));
        if (btn) { btn.textContent = 'Predict next action'; btn.disabled = false; }
      });

      // ── GENERATIVE ────────────────────────────────────────────────────
      const GEN_LABELS = ['Negative sentiment', 'Positive sentiment', 'Shipping concern', 'Quality feedback', 'Support needed'];
      const GEN_PATTERNS: Record<string, string[]> = {
        'Negative sentiment': ['disappoint','poor',"didn't",'bad','terrible','issue','wrong','broken','worst','hate'],
        'Positive sentiment': ['great','excellent','amazing','love','perfect','fast','wonderful','best','recommend','happy'],
        'Shipping concern':   ['ship','deliver','packag','fast','quick','late','arrived','tracking','dispatch','delay'],
        'Quality feedback':   ['quality','material','durable','solid','cheap','flimsy','premium','build','finish','defect'],
        'Support needed':     ['support','help','service','response','ticket','agent','resolve','contact','fix','refund'],
      };

      const genPresets: Record<string, string> = {
        review:   "The shipping was fast but the product quality didn't match the description at all. Very disappointed with the value.",
        ticket:   'My order arrived damaged. I need help getting a replacement. Support has not responded in 3 days.',
        feedback: 'Absolutely love this product! Build quality is excellent and it arrived two days early. Highly recommend.',
      };

      const genText = document.getElementById('genText') as HTMLTextAreaElement | null;

      document.querySelectorAll('.gen-preset').forEach((btn) => {
        btn.addEventListener('click', () => {
          const key = (btn as HTMLElement).dataset.genPreset ?? '';
          if (genText && genPresets[key]) genText.value = genPresets[key];
          document.querySelectorAll('.gen-preset').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
      });

      function simClassify(text: string): Array<[string, number]> {
        const t = text.toLowerCase();
        const rawScores = GEN_LABELS.map((label) => {
          const pats = GEN_PATTERNS[label] ?? [];
          const hits = pats.filter((p) => t.includes(p)).length;
          return [label, hits / (pats.length || 1) + Math.random() * 0.06] as [string, number];
        });
        const total = rawScores.reduce((s, [, v]) => s + v, 0) || 1;
        return rawScores.map(([l, v]) => [l, parseFloat((v / total).toFixed(3))] as [string, number]).sort((a, b) => b[1] - a[1]);
      }

      const genForm = document.getElementById('genForm');
      genForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = genForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (btn) { btn.textContent = 'Classifying...'; btn.disabled = true; }
        const latencyMs = await simDelay(0.12, 0.38);
        const text = genText?.value.trim() || '';
        const results = simClassify(text);
        const barsEl = document.getElementById('genProbBars');
        if (barsEl) {
          barsEl.innerHTML = results.map(([label, prob], i) => `
            <div class="prob-bar">
              <div class="prob-bar__header">
                <span class="prob-bar__label">${label}</span>
                <span class="prob-bar__pct">${(prob * 100).toFixed(1)}%</span>
              </div>
              <div class="prob-bar__track">
                <div class="prob-bar__fill${i === 0 ? ' prob-bar__fill--top' : ''}" style="width: ${(prob * 100).toFixed(1)}%"></div>
              </div>
            </div>
          `).join('');
        }
        const title = document.getElementById('genResultTitle');
        if (title) title.textContent = results[0]?.[0] ?? '—';
        const latPill = document.getElementById('genLatencyPill');
        if (latPill) latPill.textContent = `${latencyMs} ms`;
        updateLatencyBar(document.getElementById('genLatencyBar'), document.getElementById('genLatencyFill'), latencyMs);
        const st = document.getElementById('genStatus'); if (st) st.textContent = '';
        flashPanel(document.getElementById('genResultPanel'));
        if (btn) { btn.textContent = 'Classify'; btn.disabled = false; }
      });

      // ── SCHEMA DRIFT TOGGLE ──────────────────────────────────────────
      const driftToggle      = document.getElementById('driftToggle');
      const driftToggleLabel = document.getElementById('driftToggleLabel');
      const driftOutput      = document.getElementById('driftOutput');
      const driftOutputCode  = document.getElementById('driftOutputCode');
      const driftResultTitle = document.getElementById('driftResultTitle');
      const driftResultPill  = document.getElementById('driftResultPill');
      const driftExplanation = document.getElementById('driftExplanation');
      const schemaDiff       = document.getElementById('schemaDiff');
      let driftActive = false;

      const normalCode = `// Schema hash matches — inference proceeds normally.

const result = await db.scheml.predict('userChurn', user);
// result.prediction → "0"
// result.timestamp  → "2026-03-08T12:00:00.000Z"`;

      const errorCode = `// extendClient validates the schema hash on predict().

const result = await db.scheml.predict('userChurn', user); // schema now hashes to 7d2e9f1a

// ✖ Throws before any inference:
// SchemaDriftError: Trait 'userChurn' was trained on schema
// hash a3f8c1b2 but the current schema hash is 7d2e9f1a.
// Run \`scheml train\` to rebuild the artifact.`;

      driftToggle?.addEventListener('click', () => {
        driftActive = !driftActive;
        driftToggle.setAttribute('aria-pressed', String(driftActive));
        driftToggle.classList.toggle('is-active', driftActive);
        if (driftToggleLabel) driftToggleLabel.textContent = driftActive ? 'Schema has changed' : 'Schema matches artifact';
        if (schemaDiff) schemaDiff.setAttribute('aria-hidden', String(!driftActive));
        if (driftResultTitle) driftResultTitle.textContent = driftActive ? 'SchemaDriftError thrown' : 'Prediction runs normally';
        if (driftResultPill) { driftResultPill.textContent = driftActive ? 'Error' : 'OK'; driftResultPill.className = `status-pill ${driftActive ? 'status-pill--danger' : 'status-pill--healthy'}`; }
        if (driftOutputCode) driftOutputCode.textContent = driftActive ? errorCode : normalCode;
        if (driftOutput) { if (driftActive) driftOutput.setAttribute('data-tone', 'danger'); else driftOutput.removeAttribute('data-tone'); }
        if (driftExplanation) {
          driftExplanation.innerHTML = driftActive
            ? `<p>The new field <code>subscriptionTier</code> changed the schema hash to <code>7d2e9f1a</code>. ScheML catches the mismatch before running any inference and throws <code>SchemaDriftError</code>. You are forced to retrain — no silent model incorrectness.</p>`
            : `<p>The session holds <code>a3f8c1b2</code> — the hash of the schema at compile time. When calling <code>db.scheml.predict()</code>, ScheML re-hashes the current schema and compares. A match means the feature resolvers are still valid against the live data shape.</p>`;
        }
      });

      // ── CODE TABS ────────────────────────────────────────────────────
      const tabs   = document.querySelectorAll('.code-tab');
      const panels = document.querySelectorAll('.code-panel');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');
          tabs.forEach((t)  => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
          panels.forEach((p) => p.classList.remove('active'));
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
          document.getElementById(`panel-${target === 'predict' ? 'infer' : target}`)?.classList.add('active');
        });
      });

      // ── COPY INSTALL COMMAND ─────────────────────────────────────────
      const copyBtn    = document.getElementById('copyBtn');
      const installCmd = document.getElementById('installCmd');
      copyBtn?.addEventListener('click', async () => {
        await navigator.clipboard.writeText('npm install @vncsleal/scheml');
        installCmd?.classList.add('copied');
        setTimeout(() => installCmd?.classList.remove('copied'), 2000);
      });

      // ── MOBILE MENU ──────────────────────────────────────────────────
      const menuBtn = document.getElementById('menuBtn');
      const header  = document.querySelector('.header');
      menuBtn?.addEventListener('click', () => header?.classList.toggle('header--open'));
      document.querySelectorAll('.header__nav-link').forEach((link) => {
        link.addEventListener('click', () => header?.classList.remove('header--open'));
      });

      // ── HEADER SCROLL ────────────────────────────────────────────────
      const heroSection = document.querySelector('.hero');
      const headerEl = document.querySelector('.header') as HTMLElement | null;
      if (heroSection && headerEl) {
        new IntersectionObserver(
          ([entry]) => headerEl.classList.toggle('header--scrolled', !entry.isIntersecting),
          { threshold: 0 }
        ).observe(heroSection);
      }

      // ── SCROLL REVEAL ────────────────────────────────────────────────
      const revealObs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('revealed'); revealObs.unobserve(e.target); }
        });
      }, { threshold: 0.06, rootMargin: '0px 0px -32px 0px' });

      document.querySelectorAll('.drift-section .section-header, .drift-grid .panel, .drift-code-panel, .code-section .section-header').forEach((el) => {
        el.classList.add('reveal-pending');
        revealObs.observe(el);
      });

    });
  </script>

  <style is:global>
    /* Tokens (same as homepage) */
    :root {
      --gray-100: #161616; --gray-90: #262626; --gray-80: #393939;
      --gray-70: #525252;  --gray-60: #6f6f6f; --gray-50: #8d8d8d;
      --gray-30: #c6c6c6;  --gray-20: #d4d4d4; --gray-10: #f4f4f4;
      --amber-60: #d2a106; --amber-50: #f1c21b; --amber-40: #fddc69;
      --green-50: #42be65; --red-50: #fa4d56;
      --bg:               var(--gray-100);
      --bg-elevated:      var(--gray-90);
      --bg-hover:         var(--gray-80);
      --border-subtle:    #2a2a2a;
      --border-strong:    var(--gray-80);
      --text-primary:     var(--gray-10);
      --text-secondary:   var(--gray-30);
      --text-placeholder: var(--gray-60);
      --text-interactive: var(--amber-50);
      --font-sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
      --sp-1:4px; --sp-2:8px; --sp-3:12px; --sp-4:16px; --sp-5:24px;
      --sp-6:32px; --sp-7:40px; --sp-8:48px; --sp-9:64px;
      --sp-10:80px; --sp-11:96px; --sp-12:128px;
      --max-width: 1120px;
      --header-height: 48px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      font-family: var(--font-sans); font-size: 14px; line-height: 1.5;
      color: var(--text-primary); background: var(--bg);
      -webkit-font-smoothing: antialiased;
    }
    .page { min-height: 100vh; display: flex; flex-direction: column; }

    /* Logo mark */
    .logo-mark {
      font-family: var(--font-mono);
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .logo-mark--sm { font-size: 13px; color: var(--text-secondary); }
    .logo-bracket { color: var(--amber-50); font-weight: 400; }

    /* Trait tabs (hero) */
    .trait-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 28px;
    }
    .trait-tab {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 5px 14px;
      background: none;
      color: var(--text-placeholder);
      border: 1px solid var(--border-subtle);
      cursor: pointer;
      transition: color 120ms, border-color 120ms, background 120ms;
      letter-spacing: 0.04em;
    }
    .trait-tab:hover { color: var(--text-primary); border-color: var(--gray-70); }
    .trait-tab.active {
      background: rgba(61,46,0,0.7);
      color: var(--amber-40);
      border-color: rgba(241,194,27,0.2);
    }

    /* Demo panes */
    .demo-pane { display: none; }
    .demo-pane.active { display: block; }

    /* Text / textarea / select inputs */
    .text-input {
      width: 100%;
      background: var(--bg-elevated);
      border: 1px solid var(--border-strong);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 13px;
      padding: 8px 12px;
      outline: none;
      transition: border-color 120ms;
      appearance: none;
    }
    .text-input:focus { border-color: var(--amber-60); }
    textarea.text-input { resize: vertical; min-height: 88px; }
    .select-input {
      width: 100%;
      background: var(--bg-elevated);
      border: 1px solid var(--border-strong);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 13px;
      padding: 8px 12px;
      outline: none;
      appearance: none;
      cursor: pointer;
    }
    .select-input:focus { border-color: var(--amber-60); }

    /* Sequential event selectors */
    .field__seq-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 8px; display: block; }
    .seq-events { display: flex; flex-direction: column; gap: 8px; }
    .seq-step { display: flex; align-items: center; gap: 10px; }
    .seq-step-num {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-placeholder);
      min-width: 16px;
      text-align: center;
    }

    /* Probability bars (sequential / generative) */
    .prob-bars { display: flex; flex-direction: column; gap: 12px; margin-top: 16px; }
    .prob-bar { }
    .prob-bar__header { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px; }
    .prob-bar__label { color: var(--text-secondary); }
    .prob-bar__pct { font-family: var(--font-mono); color: var(--amber-40); }
    .prob-bar__track {
      height: 3px;
      background: var(--bg-elevated);
      overflow: hidden;
    }
    .prob-bar__fill {
      height: 100%;
      background: var(--gray-70);
      transition: width 350ms ease;
    }
    .prob-bar__fill--top { background: var(--amber-50); }

    /* Similarity result list */
    .result-list { display: flex; flex-direction: column; gap: 5px; margin-top: 16px; }
    .result-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 7px 10px;
      background: var(--bg-elevated);
      border: 1px solid var(--border-subtle);
      font-size: 13px;
    }
    .result-item__left { display: flex; align-items: center; gap: 8px; }
    .result-item__name { color: var(--text-primary); }
    .result-item__cat {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-placeholder);
      padding: 1px 6px;
      background: var(--bg);
      border: 1px solid var(--border-subtle);
    }
    .result-item__score {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--amber-40);
    }

    /* Hero trait pills (kept for reference) */
    .hero-trait-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
    }
    .trait-pill {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 10px;
      background: var(--bg-elevated);
      color: var(--text-placeholder);
      border: 1px solid var(--border-subtle);
      letter-spacing: 0.02em;
    }
    .trait-pill--active {
      background: rgba(61,46,0,0.7);
      color: var(--amber-40);
      border-color: rgba(241,194,27,0.2);
    }

        /* Header */
    .header {
      position: sticky; top: 0; z-index: 100;
      height: var(--header-height); background: var(--bg);
      border-bottom: 1px solid var(--border-subtle);
      transition: background 200ms ease, border-color 200ms ease, backdrop-filter 200ms ease;
    }
    .header--scrolled {
      background: rgba(22, 22, 22, 0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom-color: #333;
    }
    .header__inner {
      max-width: var(--max-width); margin: 0 auto;
      padding: 0 var(--sp-6); height: 100%;
      display: flex; justify-content: space-between; align-items: center;
    }
    .header__logo {
      display: flex; align-items: center; gap: var(--sp-2);
      text-decoration: none;
    }
    .logo-inner.typing::after {
      content: '|';
      color: inherit;
      font-weight: 400;
      animation: cursor-blink 0.55s step-end infinite;
    }
    .header__nav { display: flex; align-items: center; }
    .header__nav a {
      display: inline-flex; align-items: center;
      padding: 0 var(--sp-4); height: var(--header-height);
      font-size: 14px; color: var(--text-secondary);
      text-decoration: none; transition: background 120ms ease, color 120ms ease;
    }
    .header__nav a:hover { background: var(--bg-elevated); color: var(--text-primary); }
    .header__menu-btn {
      display: none; align-items: center; justify-content: center;
      width: 40px; height: 40px; background: none; border: none;
      color: var(--text-secondary); cursor: pointer;
    }
    .menu-icon--close { display: none; }
    .header--open .menu-icon--open { display: none; }
    .header--open .menu-icon--close { display: block; }

    /* Hero */
    .hero { padding: var(--sp-12) 0 var(--sp-10); border-bottom: 1px solid var(--border-subtle); }
    .hero__container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6); }
    .hero__breadcrumb {
      font-family: var(--font-mono); font-size: 13px;
      color: var(--text-placeholder); margin-bottom: var(--sp-6);
    }
    .breadcrumb-sep { margin: 0 var(--sp-1); color: var(--gray-70); }
    .hero__title {
      font-size: clamp(2.5rem, 5vw, 3.75rem); font-weight: 300;
      line-height: 1.15; letter-spacing: -0.02em;
      color: var(--text-primary); margin-bottom: var(--sp-6); max-width: 720px;
    }
    .hero__lead {
      font-size: 16px; line-height: 1.65; color: var(--text-secondary);
      max-width: 620px; margin-bottom: var(--sp-7); font-weight: 400;
    }
    .hero__lead code {
      font-family: var(--font-mono); font-size: 14px;
      background: var(--bg-elevated); padding: 1px 6px; color: var(--text-primary);
    }
    .hero-meta { display: flex; flex-wrap: wrap; gap: var(--sp-3); }
    .meta-pill {
      display: flex; align-items: center; gap: var(--sp-2);
      height: 32px; padding: 0 var(--sp-3);
      background: var(--bg-elevated); border: 1px solid var(--border-subtle);
    }
    .meta-pill__label { font-family: var(--font-mono); font-size: 12px; color: var(--text-placeholder); }
    .meta-pill__value { font-family: var(--font-mono); font-size: 12px; color: var(--amber-50); }

    /* Sections */
    .section { padding: var(--sp-11) 0; border-bottom: 1px solid var(--border-subtle); }
    .section__container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6); }
    .section-header { margin-bottom: var(--sp-9); }
    .drift-section .section-header { margin-bottom: var(--sp-5); }
    .section-tag {
      font-family: var(--font-mono); font-size: 12px; font-weight: 500;
      color: var(--amber-50); text-transform: uppercase; letter-spacing: 0.05em;
      margin-bottom: var(--sp-3);
    }
    .section-title {
      font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 300;
      line-height: 1.25; letter-spacing: -0.01em;
      color: var(--text-primary); margin-bottom: var(--sp-4);
    }
    .section-desc {
      font-size: 16px; line-height: 1.6;
      color: var(--text-secondary); max-width: 540px;
    }
    .section-desc code {
      font-family: var(--font-mono); font-size: 13px;
      background: var(--bg-elevated); padding: 1px 6px; color: var(--text-primary);
    }
    .eyebrow {
      font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--text-placeholder); margin-bottom: var(--sp-1);
    }

    /* Panel */
    .panel { border: 1px solid var(--border-subtle); background: var(--bg); }
    .panel__header {
      display: flex; justify-content: space-between; align-items: flex-start;
      padding: var(--sp-5) var(--sp-6);
      border-bottom: 1px solid var(--border-subtle);
    }
    .panel__header h3 { font-size: 16px; font-weight: 600; color: var(--text-primary); margin: 0; }

    /* Pills */
    .status-pill {
      display: inline-flex; align-items: center;
      height: 24px; padding: 0 var(--sp-3);
      font-family: var(--font-mono); font-size: 12px; font-weight: 500; white-space: nowrap;
    }
    .status-pill--healthy { background: rgba(66, 190, 101, 0.12); color: var(--green-50); }
    .status-pill--danger  { background: rgba(250, 77, 86, 0.12);  color: var(--red-50); }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; gap: var(--sp-2);
      height: 48px; padding: 0 var(--sp-5);
      font-family: var(--font-sans); font-size: 14px; font-weight: 500;
      text-decoration: none; cursor: pointer; border: none; white-space: nowrap;
      transition: background 120ms ease, color 120ms ease;
    }
    .btn--primary {
      background: var(--amber-60); color: var(--gray-100);
      width: 100%; justify-content: center; margin-top: var(--sp-5);
    }
    .btn--primary:hover { background: #b28600; }
    .btn--primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn--secondary {
      background: var(--bg-elevated); color: var(--text-primary);
      border: 1px solid var(--border-subtle);
    }
    .btn--secondary:hover { background: var(--bg-hover); }

    /* Inference */
    .inference-section { background: var(--bg-elevated); }
    .inference-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); }
    .preset-bar {
      display: flex; gap: var(--sp-2);
      padding: var(--sp-4) var(--sp-6);
      border-bottom: 1px solid var(--border-subtle);
    }
    .preset-btn {
      height: 28px; padding: 0 var(--sp-3);
      background: none; border: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);
      cursor: pointer; transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .preset-btn:hover, .preset-btn.is-active {
      background: var(--bg-elevated); color: var(--text-primary); border-color: var(--amber-60);
    }
    .inference-form { padding: var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-6); }
    .field { display: flex; flex-direction: column; gap: var(--sp-2); }
    .field__header { display: flex; justify-content: space-between; align-items: center; }
    .field__header label { font-size: 14px; color: var(--text-secondary); }
    .field__val {
      font-family: var(--font-mono); font-size: 14px; font-weight: 600;
      color: var(--amber-50); min-width: 36px; text-align: right;
    }
    input[type="range"] {
      -webkit-appearance: none; width: 100%; height: 2px;
      background: var(--border-strong); outline: none; cursor: pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; width: 16px; height: 16px;
      background: var(--amber-50); border-radius: 50%;
      cursor: pointer; transition: background 120ms ease;
    }
    input[type="range"]::-webkit-slider-thumb:hover { background: var(--amber-60); }
    input[type="range"]::-moz-range-thumb {
      width: 16px; height: 16px; background: var(--amber-50);
      border-radius: 50%; border: none; cursor: pointer;
    }
    .field__range-labels {
      display: flex; justify-content: space-between;
      font-family: var(--font-mono); font-size: 11px; color: var(--text-placeholder);
    }
    .result-stack { display: flex; flex-direction: column; gap: var(--sp-5); }
    .result-panel[data-tone="danger"]  { border-color: rgba(250, 77, 86, 0.3); }
    .result-panel[data-tone="healthy"] { border-color: rgba(66, 190, 101, 0.25); }
    .output-stats {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--border-subtle);
      border-top: 1px solid var(--border-subtle);
    }
    .output-stats > div {
      background: var(--bg); padding: var(--sp-4) var(--sp-5);
      display: flex; flex-direction: column; gap: var(--sp-1);
    }
    .output-stats dt { font-size: 12px; color: var(--text-placeholder); }
    .output-stats dd { font-family: var(--font-mono); font-size: 14px; color: var(--text-primary); font-weight: 500; }
    .output-stats dd.mono { font-size: 12px; }
    .result-status {
      padding: var(--sp-3) var(--sp-5);
      font-family: var(--font-mono); font-size: 12px; color: var(--red-50); min-height: 32px;
    }
    .latency-panel { background: var(--bg) !important; border-top: none; }
    .latency-bars { padding: var(--sp-5) var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-5); }
    .latency-bar { display: flex; flex-direction: column; gap: var(--sp-2); }
    .latency-bar__label { display: flex; justify-content: space-between; font-size: 13px; color: var(--text-secondary); }
    .latency-bar__ms { font-family: var(--font-mono); font-size: 13px; color: var(--text-primary); }
    .latency-bar__track { height: 4px; background: var(--border-strong); }
    .latency-bar__fill { height: 100%; background: var(--gray-70); transition: width 400ms ease; }
    .latency-bar__fill--accent { background: var(--amber-50); }
    .latency-note { padding: 0 var(--sp-6) var(--sp-5); font-size: 13px; color: var(--text-placeholder); }

    .artifact-ls {
      margin: 0 var(--sp-6) var(--sp-6);
      background: var(--gray-100); border: 1px solid var(--border-subtle);
      padding: var(--sp-4) var(--sp-5); font-family: var(--font-mono); font-size: 12px;
      overflow-x: hidden; white-space: pre-wrap; word-break: break-all;
    }
    .artifact-ls__prompt { color: var(--text-placeholder); margin-bottom: var(--sp-2); }
    .prompt { color: var(--green-50); }
    .artifact-ls__line { color: var(--text-secondary); line-height: 2; }
    .ls-perm { color: var(--text-placeholder); }
    .ls-size { color: var(--amber-50); margin: 0 var(--sp-4); }
    .ls-name { color: var(--text-primary); }
    .artifact-ls__hint { margin-top: var(--sp-2); color: var(--gray-60); }
    .drift-ls { margin: var(--sp-5) 0 0; }

    /* Drift */
    .drift-section { background: var(--bg-elevated); }
    .drift-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); margin-bottom: var(--sp-5); }
    .drift-desc {
      padding: var(--sp-5) var(--sp-6); font-size: 14px; line-height: 1.6;
      color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);
    }
    .drift-desc code {
      font-family: var(--font-mono); font-size: 12px;
      background: var(--bg-elevated); padding: 1px 6px; color: var(--text-primary);
    }
    .drift-toggle-row { padding: var(--sp-5) var(--sp-6); border-bottom: 1px solid var(--border-subtle); }
    .drift-toggle {
      display: inline-flex; align-items: center; gap: var(--sp-3);
      background: none; border: none; cursor: pointer; padding: 0;
    }
    .drift-toggle__track {
      position: relative; width: 44px; height: 24px;
      background: var(--bg-hover); border: 1px solid var(--border-strong);
      border-radius: 12px; transition: background 200ms ease, border-color 200ms ease;
    }
    .drift-toggle.is-active .drift-toggle__track {
      background: rgba(250, 77, 86, 0.2); border-color: var(--red-50);
    }
    .drift-toggle__thumb {
      position: absolute; top: 3px; left: 3px;
      width: 16px; height: 16px; border-radius: 50%;
      background: var(--gray-50); transition: transform 200ms ease, background 200ms ease;
    }
    .drift-toggle.is-active .drift-toggle__thumb {
      transform: translateX(20px); background: var(--red-50);
    }
    .drift-toggle__label {
      font-size: 14px; color: var(--text-secondary);
      transition: color 200ms ease;
    }
    .drift-toggle.is-active .drift-toggle__label { color: var(--red-50); }
    .schema-diff { margin: var(--sp-5) var(--sp-6); border: 1px solid var(--border-subtle); }
    .schema-diff[aria-hidden="true"] { display: none; }
    .schema-diff__header {
      display: flex; justify-content: space-between; align-items: center;
      padding: var(--sp-2) var(--sp-4);
      background: var(--bg-elevated); border-bottom: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 12px; color: var(--text-placeholder);
    }
    .schema-diff__badge {
      background: rgba(241, 194, 27, 0.12); color: var(--amber-50);
      padding: 1px 8px; font-size: 11px;
    }
    .schema-diff__code {
      padding: var(--sp-4); font-family: var(--font-mono); font-size: 12px;
      line-height: 1.7; color: var(--text-secondary); overflow-x: hidden;
      white-space: pre-wrap; word-break: break-all; margin: 0;
    }
    .diff-add { color: var(--green-50); }
    .drift-output {
      margin: 0; padding: var(--sp-5) var(--sp-6);
      font-family: var(--font-mono); font-size: 12px; line-height: 1.7;
      color: var(--text-secondary); overflow-x: hidden;
      white-space: pre-wrap; word-break: break-all;
      border-top: 1px solid var(--border-subtle);
    }
    .drift-output[data-tone="danger"] { color: var(--red-50); }
    .drift-explanation {
      padding: var(--sp-4) var(--sp-6) var(--sp-5);
      font-size: 13px; line-height: 1.65; color: var(--text-placeholder);
      border-top: 1px solid var(--border-subtle);
    }
    .drift-explanation code {
      font-family: var(--font-mono); font-size: 11px;
      background: var(--bg-elevated); padding: 1px 5px; color: var(--text-secondary);
    }
    .drift-code-panel { margin-top: 0; }
    .drift-code-panel pre {
      margin: 0 !important; padding: var(--sp-5) var(--sp-6) !important;
      background: transparent !important; border-radius: 0 !important;
      font-size: 13px !important; line-height: 1.7 !important;
      font-family: var(--font-mono) !important;
      white-space: pre-wrap !important; word-break: break-all !important; overflow-x: hidden;
    }

    /* Code section */
    .code-section { padding: var(--sp-11) 0; border-bottom: 1px solid var(--border-subtle); }
    .code-section__container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6); }
    .code-tabs { border: 1px solid var(--border-subtle); background: var(--bg); }
    .code-tabs__bar {
      display: flex; border-bottom: 1px solid var(--border-subtle);
      background: var(--bg-elevated); overflow-x: auto;
    }
    .code-tab {
      display: flex; align-items: center; gap: var(--sp-3);
      padding: 0 var(--sp-5); height: 48px;
      background: none; border: none; border-bottom: 2px solid transparent;
      color: var(--text-secondary); font-family: var(--font-sans); font-size: 14px;
      cursor: pointer; transition: color 120ms ease, background 120ms ease, border-color 120ms ease;
      white-space: nowrap;
    }
    .code-tab:hover { background: var(--bg-hover); color: var(--text-primary); }
    .code-tab.active { color: var(--text-primary); border-bottom-color: var(--amber-60); }
    .code-tab__num { font-family: var(--font-mono); font-size: 11px; color: var(--text-placeholder); }
    .code-tab.active .code-tab__num { color: var(--amber-50); }
    .code-tab__label { font-weight: 500; }
    .code-tab__file { font-family: var(--font-mono); font-size: 12px; color: var(--text-placeholder); }
    .code-tabs__panels { display: grid; grid-template-columns: 1fr; }
    .code-panel { grid-column: 1; grid-row: 1; min-height: 320px; opacity: 0; visibility: hidden; transition: opacity 220ms ease; pointer-events: none; }
    .code-panel.active { opacity: 1; visibility: visible; pointer-events: auto; }
    .code-panel pre {
      margin: 0 !important; padding: var(--sp-5) var(--sp-6) !important;
      background: transparent !important; border-radius: 0 !important;
      font-size: 13px !important; line-height: 1.7 !important;
      font-family: var(--font-mono) !important;
      white-space: pre-wrap !important; word-break: break-all !important; overflow-x: hidden;
    }
    .cta-strip {
      display: flex; align-items: center; gap: var(--sp-4);
      flex-wrap: wrap; margin-top: var(--sp-6);
    }
    .install-cmd {
      display: flex; align-items: center; gap: var(--sp-3);
      height: 48px; padding: 0 var(--sp-4);
      background: var(--bg-elevated); border: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 14px; color: var(--text-primary);
    }
    .install-cmd__prompt { color: var(--green-50); user-select: none; }
    .install-cmd__text { user-select: all; }
    .install-cmd__copy {
      display: flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; margin-left: var(--sp-2);
      background: none; border: none; color: var(--text-placeholder);
      cursor: pointer; transition: color 120ms ease; position: relative;
    }
    .install-cmd__copy:hover { color: var(--text-primary); }
    .install-cmd__copy .check-icon { position: absolute; opacity: 0; color: var(--green-50); }
    .install-cmd.copied .install-cmd__copy svg:first-child { opacity: 0; }
    .install-cmd.copied .install-cmd__copy .check-icon { opacity: 1; }

    /* Footer */
    .footer { padding: var(--sp-5) 0; border-top: 1px solid var(--border-subtle); }

    /* Scroll reveal (applied by JS) */
    .reveal-pending {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 560ms cubic-bezier(0.22,1,0.36,1), transform 560ms cubic-bezier(0.22,1,0.36,1);
    }
    .reveal-pending:nth-child(2) { transition-delay: 140ms; }
    .reveal-pending:nth-child(3) { transition-delay: 280ms; }
    .reveal-pending.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Result panel update flash — tone-aware border animation */
    @keyframes resultFlashHealthy {
      0%   { border-color: var(--green-50);           box-shadow: 0 0 0 3px rgba(66, 190, 101, 0.12); }
      60%  { border-color: var(--green-50);           box-shadow: none; }
      100% { border-color: rgba(66, 190, 101, 0.25); box-shadow: none; }
    }
    @keyframes resultFlashDanger {
      0%   { border-color: var(--red-50);             box-shadow: 0 0 0 3px rgba(250, 77, 86, 0.10); }
      60%  { border-color: var(--red-50);             box-shadow: none; }
      100% { border-color: rgba(250, 77, 86, 0.3);   box-shadow: none; }
    }
    .result-panel[data-tone="healthy"].result-updated {
      animation: resultFlashHealthy 800ms ease forwards;
    }
    .result-panel[data-tone="danger"].result-updated {
      animation: resultFlashDanger 800ms ease forwards;
    }
    .footer__container {
      max-width: var(--max-width); margin: 0 auto; padding: 0 var(--sp-6);
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer__left { display: flex; align-items: center; gap: var(--sp-2); font-size: 14px; color: var(--text-secondary); }
    .footer__name { font-weight: 600; }
    .footer__right {
      display: flex; align-items: center; gap: var(--sp-3);
      font-family: var(--font-mono); font-size: 12px; color: var(--text-placeholder);
    }
    .footer__right a { color: var(--text-placeholder); text-decoration: none; }
    .footer__right a:hover { color: var(--text-secondary); }
    .footer__sep { opacity: 0.4; }

    /* Animations */
    .anim-fade-up { opacity: 0; transform: translateY(28px); animation: fadeUp 720ms cubic-bezier(0.22,1,0.36,1) forwards; }
    .anim-delay-1 { animation-delay: 160ms; }
    .anim-delay-2 { animation-delay: 340ms; }
    .anim-delay-3 { animation-delay: 520ms; }
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    /* Responsive */
    @media (max-width: 900px) {
      .inference-grid,
      .drift-grid { grid-template-columns: 1fr; }
      .section-header { margin-bottom: var(--sp-5); }
    }
    @media (max-width: 640px) {
      .header { height: auto; min-height: var(--header-height); }
      .header__inner { padding: 0 var(--sp-4); flex-wrap: wrap; height: var(--header-height); }
      .header__menu-btn { display: flex; }
      .header__nav {
        display: none; flex-direction: column; width: 100%;
        border-top: 1px solid var(--border-subtle); background: var(--bg); order: 3;
      }
      .header--open .header__inner { height: auto; }
      .header--open .header__nav { display: flex; }
      .header__nav a {
        width: 100%; height: 48px; padding: 0 var(--sp-4);
        border-bottom: 1px solid var(--border-subtle);
      }
      .hero { padding: var(--sp-8) 0 var(--sp-7); }
      .hero__container { padding: 0 var(--sp-4); }
      .hero__title { font-size: 2rem; }
      .hero__lead { font-size: 15px; }
      .section { padding: var(--sp-8) 0; }
      .section__container,
      .code-section__container { padding: 0 var(--sp-4); }
