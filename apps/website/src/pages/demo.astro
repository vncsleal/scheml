              <div class="preset-bar">
                <button type="button" class="preset-btn gen-preset is-active" data-gen-preset="review">Product review</button>
                <button type="button" class="preset-btn gen-preset" data-gen-preset="ticket">Support ticket</button>
                <button type="button" class="preset-btn gen-preset" data-gen-preset="feedback">User feedback</button>
              </div>

              <form id="genForm" class="inference-form">
                <div class="field">
                  <div class="field__header">
                    <label for="genText">Text to classify</label>
                  <p class="field__hint" style="font-size:11px;color:var(--text-secondary);margin-top:2px">A real generative trait would stream structured text from an AI SDK provider instead.</p>
                  </div>
                  <textarea id="genText" name="genText" rows="4" class="text-input"
                    placeholder="Enter text to classify...">The shipping was fast but the product quality didn't match the description at all. Very disappointed with the value.</textarea>
                </div>

                <button class="btn btn--primary" type="submit">Classify</button>
