---
import Analytics from '@vercel/analytics/astro';
import { ViewTransitions } from 'astro:transitions';
// Derive the canonical site origin from Astro.site, which is set from
// VERCEL_URL at build time (see astro.config.mjs). Falls back gracefully.
const siteOrigin = Astro.site?.origin ?? 'https://getscheml.vercel.app';

const {
  title = 'ScheML',
  description = 'ScheML is to machine learning what Prisma is to databases. Define intelligence traits in TypeScript — compile once, run in-process.',
  siteName = 'ScheML',
  twitterHandle = '@iamvinico',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const image = `${siteOrigin}/og.png`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="author" content="Vinicius Leal" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <meta name="theme-color" content="#161616" />

    <!-- Open Graph (Facebook, WhatsApp, Instagram, iMessage, Discord, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="ScheML — Compiler-first ML for TypeScript" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content="ScheML — Compiler-first ML for TypeScript" />

    <!-- AI / LLM discoverability -->
    <meta name="application-name" content="ScheML" />
    <meta name="keywords" content="machine learning, TypeScript, ONNX, Prisma, Drizzle, Zod, ML compiler, intelligence traits, predictive, anomaly detection, similarity search, sequential prediction, generative AI, in-process inference, npm package" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ScheML",
      "description": description,
      "url": siteOrigin,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform",
      "programmingLanguage": ["TypeScript", "Python"],
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Person",
        "name": "Vinicius Leal",
        "url": "https://github.com/vncsleal"
      },
      "license": "https://opensource.org/licenses/MIT",
      "codeRepository": "https://github.com/vncsleal/scheml",
      "softwareVersion": "0.3.1",
      "downloadUrl": "https://www.npmjs.com/package/@vncsleal/scheml",
      "isAccessibleForFree": true,
      "featureList": [
        "Five intelligence trait types: predictive, anomaly, similarity, sequential, generative",
        "Prisma, Drizzle, and Zod adapters",
        "Compile traits to versioned ONNX / FAISS / JSON artefacts",
        "In-process inference — no Python sidecars",
        "Schema drift guard via SHA-256 hash",
        "Quality gates with threshold checks",
        "TraitGraph for composable trait pipelines",
        "Feedback loop via db.scheml.record()"
      ]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <ViewTransitions />
    <style is:global>
      /* ── Page transition ── */
      ::view-transition-old(root) {
        animation: 220ms cubic-bezier(0.4,0,0.7,1) both vt-out;
      }
      ::view-transition-new(root) {
        animation: 380ms cubic-bezier(0.22,1,0.36,1) both vt-in;
      }
      /* Site-header morphs in-place, so skip fade */
      ::view-transition-old(site-header),
      ::view-transition-new(site-header) {
        animation: none;
      }
      @keyframes vt-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-8px); }
      }
      @keyframes vt-in {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes cursor-blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
      }
    </style>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
