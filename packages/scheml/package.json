{
  "name": "@vncsleal/scheml",
  "version": "0.3.1",
  "description": "ScheML: compiler-first ML for TypeScript applications",
  "license": "MIT",
  "author": "Vinicius Leal <oi@iamvini.co> (https://github.com/vncsleal)",
  "homepage": "https://github.com/vncsleal/scheml#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vncsleal/scheml",
    "directory": "packages/scheml"
  },
  "bugs": {
    "url": "https://github.com/vncsleal/scheml/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "machine-learning",
    "typescript",
    "orm",
    "prisma",
    "drizzle",
    "typeorm",
    "onnx",
    "compiler",
    "runtime",
    "cli"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "python",
    "README.md"
  ],
  "bin": {
    "scheml": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write src",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "jiti": "^2.6.1",
    "onnxruntime-node": "^1.24.3",
    "ora": "^8.0.1",
    "yargs": "^17.7.2"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0",
    "ai": ">=4.0.0",
    "drizzle-orm": ">=0.29.0",
    "zod": ">=3.0.0",
    "typeorm": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/yargs": "^17.0.31",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
