{
  "name": "@vncsleal/prisml",
  "version": "0.1.2",
  "description": "PrisML: compiler-first ML for TypeScript + Prisma",
  "license": "MIT",
  "author": "Vinicius Leal <oi@iamvini.co> (https://github.com/vncsleal)",
  "repository": {
    "type": "git",
    "url": "https://github.com/vncsleal/prisml",
    "directory": "packages/prisml"
  },
  "bugs": {
    "url": "https://github.com/vncsleal/prisml/issues"
  },
  "keywords": [
    "machine-learning",
    "typescript",
    "prisma",
    "onnx",
    "compiler",
    "runtime",
    "cli"
  ],
  "publishConfig": {
