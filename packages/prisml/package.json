    "ora": "^8.0.1",
    "yargs": "^17.7.2"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
