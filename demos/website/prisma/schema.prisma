generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String   @id
  email          String   @unique
  createdAt      DateTime
  lastActiveAt   DateTime
  monthlySpend   Float
  supportTickets Int
  planTier       String
  willChurn      Boolean
}

model ServerMetric {
  id             String   @id
  recordedAt     DateTime
  cpuUsage       Float
  memoryPressure Float
  errorRate      Float
  isAnomalous    Boolean
}

model Product {
  id            String @id
  name          String
  categoryLabel String
  categoryIndex Int
  price         Float
  batteryHours  Float
  weightKg      Float
}

model EngagementEvent {
  id              String   @id
  createdAt       DateTime
  engagementScore Float
  willChurnSoon   Boolean
}