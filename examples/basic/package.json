{
  "name": "example-basic",
  "version": "0.1.0",
  "description": "Basic ScheML example: user lifetime value prediction",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "seed": "tsx prisma/seed.ts",
    "setup-demo": "pnpm run db:push && pnpm run generate && pnpm run seed",
    "train": "scheml train --config ./scheml.config.ts --schema ./prisma/schema.prisma",
    "train:demo": "scheml train --config ./scheml.config.ts --schema ./prisma/schema.prisma --output ../../apps/website/demo-artifacts",
    "infer": "tsx src/infer.ts"
  },
  "dependencies": {
    "@vncsleal/scheml": "workspace:*",
    "@prisma/client": "^5.7.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "prisma": "^5.7.0"
  }
}
