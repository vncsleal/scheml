generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id
  email               String   @unique
  createdAt           DateTime
  source              String
  monthlySpend        Float
  monthsActive        Int
  plan                String
  actualLifetimeValue Float
  lastActiveAt        DateTime
  supportTickets      Int
  willChurn           Boolean
}