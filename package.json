{
  "name": "@vncsleal/scheml-root",
  "version": "0.1.0",
  "description": "ScheML: Compiler-first ML library for TypeScript + Prisma",
  "private": true,
  "license": "MIT",
  "author": "Vinicius Leal <oi@iamvini.co> (https://github.com/vncsleal)",
  "repository": {
    "type": "git",
    "url": "https://github.com/vncsleal/scheml"
  },
  "bugs": {
    "url": "https://github.com/vncsleal/scheml/issues"
  },
  "keywords": [
    "machine-learning",
    "typescript",
    "prisma",
    "compiler",
    "onnx",
    "inference"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:demo-bundle": "pnpm --filter scheml-demo-producer build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch"
  },
  "workspaces": [
    "packages/*",
    "demos/*",
    "apps/*"
  ],
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "turbo": "^1.10.16",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
